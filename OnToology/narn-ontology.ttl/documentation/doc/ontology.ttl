                          <https://purl.org/dc/terms/modified> "2026-03-17"^^xsd:date ;
                          <https://purl.org/vocab/vann/preferredNamespacePrefix> "narn" ;
                          <https://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/narn/" .

