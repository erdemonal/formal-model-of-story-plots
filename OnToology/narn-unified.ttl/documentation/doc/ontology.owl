        <rdfs:comment xml:lang="en">An interval bounded by a distinct starting instant but lacking a defined ending point.</rdfs:comment>
        <rdfs:label xml:lang="en">starting interval</rdfs:label>
        <skos:altLabel xml:lang="en">begins with</skos:altLabel>
        <skos:example xml:lang="en">The life of an Elf exemplifies a starting interval since it begins at birth but possesses no natural conclusion.</skos:example>
