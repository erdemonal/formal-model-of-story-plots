<https://w3id.org/narn/plot/hasConflict> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                         rdfs:range <https://w3id.org/narn/plot/Conflict> ;
                                         rdfs:comment "A conflict central to the story."@en ;
                                         rdfs:label "has conflict"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "has tension"@en .


###  https://w3id.org/narn/plot/hasGenre
<https://w3id.org/narn/plot/hasGenre> rdf:type owl:ObjectProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                      rdfs:range <https://w3id.org/narn/plot/Genre> ;
                                      rdfs:comment "The genre(s) of the story."@en ;
                                      rdfs:label "has genre"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "genre is"@en .


###  https://w3id.org/narn/plot/hasNarrativeElement
<https://w3id.org/narn/plot/hasNarrativeElement> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                                 rdfs:range <https://w3id.org/narn/plot/NarrativeElement> ;
                                                 rdfs:comment "Links a story to its plot stages."@en ;
                                                 rdfs:label "has narrative element"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "has element"@en .


###  https://w3id.org/narn/plot/hasNarrativeUnit
<https://w3id.org/narn/plot/hasNarrativeUnit> rdf:type owl:ObjectProperty ,
                                                       owl:AsymmetricProperty ,
                                                       owl:IrreflexiveProperty ;
                                              rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                              rdfs:range <https://w3id.org/narn/plot/NarrativeUnit> ;
                                              rdfs:comment "Links a story to its structural units."@en ;
                                              rdfs:label "has narrative unit"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "divided into"@en .


###  https://w3id.org/narn/plot/hasRole
<https://w3id.org/narn/plot/hasRole> rdf:type owl:ObjectProperty ;
                                     rdfs:range <https://w3id.org/narn/plot/CharacterRole> ;
                                     rdfs:comment "The narrative role a character plays."@en ;
                                     rdfs:label "has role"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "plays role"@en .


###  https://w3id.org/narn/plot/hasTheme
<https://w3id.org/narn/plot/hasTheme> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                      rdfs:comment "A thematic element or motif in the story."@en ;
                                      rdfs:label "has theme"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "explores theme"@en .


###  https://w3id.org/narn/plot/involvedInDevice
<https://w3id.org/narn/plot/involvedInDevice> rdf:type owl:ObjectProperty ;
                                              rdfs:comment "Links a character role to a narrative device that affects them."@en ;
                                              rdfs:label "involved in device"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "affected by narrative device"@en .


###  https://w3id.org/narn/plot/isUnitOf
<https://w3id.org/narn/plot/isUnitOf> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <https://w3id.org/narn/plot/containsUnit> ;
                                      rdfs:comment "Inverse of containsUnit, relates a unit to its parent."@en ;
                                      rdfs:label "is unit of"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "belongs to"@en .


###  https://w3id.org/narn/plot/occursInUnit
<https://w3id.org/narn/plot/occursInUnit> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <https://w3id.org/narn/plot/NarrativeElement> ;
                                          rdfs:range <https://w3id.org/narn/plot/NarrativeUnit> ;
                                          rdfs:comment "The narrative unit in which this element appears."@en ;
                                          rdfs:label "occurs in unit"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "located in unit"@en .


###  https://w3id.org/narn/plot/usesDevice
<https://w3id.org/narn/plot/usesDevice> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                        rdfs:range <https://w3id.org/narn/plot/PlotDevice> ;
                                        rdfs:comment "Links a story to the plot devices it employs."@en ;
                                        rdfs:label "uses device"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "employs device"@en .


###  https://w3id.org/narn/rcc/DC
<https://w3id.org/narn/rcc/DC> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               rdfs:comment "Two regions share no points at all."@en ;
                               rdfs:label "disconnected"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "disjoint regions"@en .


###  https://w3id.org/narn/rcc/EC
<https://w3id.org/narn/rcc/EC> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/location/borders> ,
                                                  <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               owl:propertyDisjointWith <https://w3id.org/narn/rcc/NTPP> ;
                               rdfs:comment "Boundaries touch but interiors are disjoint."@en ;
                               rdfs:label "externally connected"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "touching regions"@en .


###  https://w3id.org/narn/rcc/EQ
<https://w3id.org/narn/rcc/EQ> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/location/contains> ,
                                                  <https://w3id.org/narn/location/isAPartOf> ,
                                                  <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:TransitiveProperty ,
                                        owl:ReflexiveProperty ;
                               rdfs:comment "Same spatial extent. Equivalence relation."@en ;
                               rdfs:label "equal"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "coextensive regions"@en .


###  https://w3id.org/narn/rcc/NTPP
<https://w3id.org/narn/rcc/NTPP> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/location/isAPartOf> ,
                                                    <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:TransitiveProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:comment "First region entirely inside second, boundaries do not touch."@en ;
                                 rdfs:label "non-tangential proper part"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "interior part"@en .


###  https://w3id.org/narn/rcc/NTPPi
<https://w3id.org/narn/rcc/NTPPi> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/location/contains> ,
                                                     <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                  owl:inverseOf <https://w3id.org/narn/rcc/NTPP> ;
                                  rdf:type owl:AsymmetricProperty ,
                                           owl:TransitiveProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:comment "First region entirely contains second, boundaries do not touch."@en ;
                                  rdfs:label "non-tangential proper part inverse"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "interior whole"@en .


###  https://w3id.org/narn/rcc/PO
<https://w3id.org/narn/rcc/PO> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               rdfs:comment "Part of each region is inside the other but neither is contained."@en ;
                               rdfs:label "partially overlapping"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "overlapping regions"@en .


###  https://w3id.org/narn/rcc/TPP
<https://w3id.org/narn/rcc/TPP> rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf <https://w3id.org/narn/location/isAPartOf> ,
                                                   <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                rdf:type owl:AsymmetricProperty ,
                                         owl:IrreflexiveProperty ;
                                rdfs:comment "First region entirely inside second, boundaries touch."@en ;
                                rdfs:label "tangential proper part"@en ;
                                <http://www.w3.org/2004/02/skos/core#altLabel> "tangential part"@en .


###  https://w3id.org/narn/rcc/TPPi
<https://w3id.org/narn/rcc/TPPi> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/location/contains> ,
                                                    <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                 owl:inverseOf <https://w3id.org/narn/rcc/TPP> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:comment "First region entirely contains second, boundaries touch."@en ;
                                 rdfs:label "tangential proper part inverse"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "tangential whole"@en .


###  https://w3id.org/narn/rcc/spatiallyRelatedTo
<https://w3id.org/narn/rcc/spatiallyRelatedTo> rdf:type owl:ObjectProperty ,
                                                        owl:SymmetricProperty ;
                                               rdfs:domain <https://w3id.org/narn/location/Place> ;
                                               rdfs:range <https://w3id.org/narn/location/Place> ;
                                               rdfs:comment "The most general spatial relation between two regions."@en ;
                                               rdfs:label "spatially related to"@en ;
                                               <http://www.w3.org/2004/02/skos/core#altLabel> "spatial relation"@en .


