                                            <http://www.w3.org/2004/02/skos/core#altLabel> "reigned over"@en .


###  https://w3id.org/narn/to/after
<https://w3id.org/narn/to/after> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                 owl:inverseOf <https://w3id.org/narn/to/before> ;
                                 rdf:type owl:TransitiveProperty ;
                                 rdfs:comment "Inverse of before. X starts after Y ends."@en ;
                                 rdfs:label "after"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "follows"@en .


###  https://w3id.org/narn/to/before
<https://w3id.org/narn/to/before> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ,
                                                     <https://w3id.org/narn/to/precedes> ;
                                  rdf:type owl:TransitiveProperty ;
                                  owl:propertyDisjointWith <https://w3id.org/narn/to/overlaps> ;
                                  rdfs:comment "X ends before Y starts."@en ;
                                  rdfs:label "before"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "precedes"@en .


###  https://w3id.org/narn/to/containsInterval
<https://w3id.org/narn/to/containsInterval> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                            owl:inverseOf <https://w3id.org/narn/to/during> ;
                                            rdf:type owl:TransitiveProperty ;
                                            rdfs:comment "Inverse of during. X entirely contains Y."@en ;
                                            rdfs:label "contains interval"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "temporally contains"@en .


###  https://w3id.org/narn/to/during
<https://w3id.org/narn/to/during> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                  rdf:type owl:TransitiveProperty ;
                                  rdfs:comment "X occurs entirely within Y."@en ;
                                  rdfs:label "during"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "contained in"@en .


###  https://w3id.org/narn/to/endsAt
<https://w3id.org/narn/to/endsAt> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/hasInstant> ;
                                  rdf:type owl:FunctionalProperty ,
                                           owl:AsymmetricProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                  rdfs:range <https://w3id.org/narn/to/Instant> ;
                                  owl:propertyDisjointWith <https://w3id.org/narn/to/startsAt> ;
                                  rdfs:comment "The unique ending instant."@en ;
                                  rdfs:label "ends at"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "ending point"@en .


###  https://w3id.org/narn/to/equals
<https://w3id.org/narn/to/equals> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                  rdf:type owl:SymmetricProperty ,
                                           owl:TransitiveProperty ,
                                           owl:ReflexiveProperty ;
                                  rdfs:comment "Same temporal extent."@en ;
                                  rdfs:label "equals"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "same time as"@en .


###  https://w3id.org/narn/to/finishedBy
<https://w3id.org/narn/to/finishedBy> rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                      owl:inverseOf <https://w3id.org/narn/to/finishes> ;
                                      rdf:type owl:AsymmetricProperty ,
                                               owl:TransitiveProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:comment "Inverse of finishes. X ends when Y ends but Y starts before X starts."@en ;
                                      rdfs:label "finished by"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "ended by"@en .


###  https://w3id.org/narn/to/finishes
<https://w3id.org/narn/to/finishes> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                    rdf:type owl:AsymmetricProperty ,
                                             owl:TransitiveProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:comment "X ends at same time as Y but starts after Y starts."@en ;
                                    rdfs:label "finishes"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "ends with"@en .


###  https://w3id.org/narn/to/hasInstant
<https://w3id.org/narn/to/hasInstant> rdf:type owl:ObjectProperty ,
                                               owl:AsymmetricProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                      rdfs:range <https://w3id.org/narn/to/Instant> ;
                                      rdfs:comment "Links an interval to an instant that falls within or bounds it."@en ;
                                      rdfs:label "has instant"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "at instant"@en .


###  https://w3id.org/narn/to/intervalRelation
<https://w3id.org/narn/to/intervalRelation> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                            rdfs:range <https://w3id.org/narn/to/Interval> ;
                                            rdfs:comment "General temporal relation between two intervals."@en ;
                                            rdfs:label "interval relation"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "Allen relation"@en .


###  https://w3id.org/narn/to/meets
<https://w3id.org/narn/to/meets> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ,
                                                    <https://w3id.org/narn/to/precedes> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 owl:propertyDisjointWith <https://w3id.org/narn/to/overlaps> ;
                                 rdfs:comment "X ends exactly when Y starts."@en ;
                                 rdfs:label "meets"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "immediately before"@en .


###  https://w3id.org/narn/to/metBy
<https://w3id.org/narn/to/metBy> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                 owl:inverseOf <https://w3id.org/narn/to/meets> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:comment "Inverse of meets. X starts exactly when Y ends."@en ;
                                 rdfs:label "met by"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "immediately after"@en .


###  https://w3id.org/narn/to/occursAfter
<https://w3id.org/narn/to/occursAfter> rdf:type owl:ObjectProperty ;
                                       owl:inverseOf <https://w3id.org/narn/to/occursBefore> ;
                                       rdf:type owl:TransitiveProperty ;
                                       rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                       rdfs:range <https://w3id.org/narn/to/Instant> ;
                                       rdfs:comment "Inverse of occursBefore."@en ;
                                       rdfs:label "occurs after"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "later than"@en .


###  https://w3id.org/narn/to/occursBefore
<https://w3id.org/narn/to/occursBefore> rdf:type owl:ObjectProperty ,
                                                 owl:TransitiveProperty ;
                                        rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                        rdfs:range <https://w3id.org/narn/to/Instant> ;
                                        owl:propertyDisjointWith <https://w3id.org/narn/to/occursSimultaneouslyTo> ;
                                        rdfs:comment "Instant strictly before another."@en ;
                                        rdfs:label "occurs before"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "earlier than"@en .


###  https://w3id.org/narn/to/occursDuring
<https://w3id.org/narn/to/occursDuring> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                        rdfs:range <https://w3id.org/narn/to/Interval> ;
                                        rdfs:comment "An instant falls within the extent of an interval."@en ;
                                        rdfs:label "occurs during"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "within timeframe of"@en .


###  https://w3id.org/narn/to/occursSimultaneouslyTo
<https://w3id.org/narn/to/occursSimultaneouslyTo> rdf:type owl:ObjectProperty ,
                                                           owl:SymmetricProperty ,
                                                           owl:TransitiveProperty ,
                                                           owl:ReflexiveProperty ;
                                                  rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                                  rdfs:range <https://w3id.org/narn/to/Instant> ;
                                                  rdfs:comment "Two instants at the same time."@en ;
                                                  rdfs:label "occurs simultaneously to"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "at same time as"@en .


###  https://w3id.org/narn/to/overlappedBy
<https://w3id.org/narn/to/overlappedBy> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                        owl:inverseOf <https://w3id.org/narn/to/overlaps> ;
                                        rdf:type owl:AsymmetricProperty ,
                                                 owl:IrreflexiveProperty ;
                                        rdfs:comment "Inverse of overlaps. Y starts before X, ends after X starts but before X ends."@en ;
                                        rdfs:label "overlapped by"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "partially after"@en .


###  https://w3id.org/narn/to/overlaps
<https://w3id.org/narn/to/overlaps> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                    rdf:type owl:AsymmetricProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:comment "X starts before Y, ends after Y starts but before Y ends."@en ;
                                    rdfs:label "overlaps"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "partially before"@en .


###  https://w3id.org/narn/to/precededBy
<https://w3id.org/narn/to/precededBy> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <https://w3id.org/narn/to/precedes> ;
                                      rdf:type owl:TransitiveProperty ;
                                      rdfs:comment "Inverse of precedes. X starts after or when Y ends."@en ;
                                      rdfs:label "preceded by"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "happens after"@en .


###  https://w3id.org/narn/to/precedes
<https://w3id.org/narn/to/precedes> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                    rdf:type owl:TransitiveProperty ;
                                    rdfs:comment "X ends before or when Y starts."@en ;
                                    rdfs:label "precedes"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "happens before"@en .


###  https://w3id.org/narn/to/startedBy
<https://w3id.org/narn/to/startedBy> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                     owl:inverseOf <https://w3id.org/narn/to/starts> ;
                                     rdf:type owl:AsymmetricProperty ,
                                              owl:TransitiveProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:comment "Inverse of starts. X starts when Y starts but Y ends after X ends."@en ;
                                     rdfs:label "started by"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "begun by"@en .


###  https://w3id.org/narn/to/starts
<https://w3id.org/narn/to/starts> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                  rdf:type owl:AsymmetricProperty ,
                                           owl:TransitiveProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:comment "X starts at same time as Y but ends before Y ends."@en ;
                                  rdfs:label "starts"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "begins with"@en .


###  https://w3id.org/narn/to/startsAt
<https://w3id.org/narn/to/startsAt> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/hasInstant> ;
                                    rdf:type owl:FunctionalProperty ,
                                             owl:AsymmetricProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                    rdfs:range <https://w3id.org/narn/to/Instant> ;
                                    rdfs:comment "The unique starting instant."@en ;
                                    rdfs:label "starts at"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "beginning point"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/narn/plot/publishedDate
<https://w3id.org/narn/plot/publishedDate> rdf:type owl:DatatypeProperty ,
                                                    owl:FunctionalProperty ;
                                           rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                           rdfs:range xsd:date ;
                                           rdfs:comment "The date the story was published."@en ;
                                           rdfs:label "published date"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "date published"@en .


###  https://w3id.org/narn/plot/unitIndex
<https://w3id.org/narn/plot/unitIndex> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://w3id.org/narn/plot/NarrativeUnit> ;
                                       rdfs:range xsd:positiveInteger ;
                                       rdfs:comment "The ordering position of a unit within its parent."@en ;
                                       rdfs:label "unit index"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "sequence number"@en .


###  https://w3id.org/narn/to/hasDateTime
<https://w3id.org/narn/to/hasDateTime> rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                       rdfs:range xsd:dateTime ;
                                       rdfs:comment "The calendar date and time of an instant."@en ;
                                       rdfs:label "has date time"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "dateTime value"@en .


###  https://w3id.org/narn/to/hasDuration
<https://w3id.org/narn/to/hasDuration> rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                       rdfs:range xsd:duration ;
                                       rdfs:comment "The length of time spanned by an interval."@en ;
                                       rdfs:label "has duration"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "time length"@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/narn/action/Action
<https://w3id.org/narn/action/Action> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/Event> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/action/performedBy> ;
                                                        owl:someValuesFrom owl:Thing
                                                      ] ;
                                      rdfs:comment "An intentional deed. Every action has at least one performer."@en ;
                                      rdfs:label "action"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "deed"@en .


###  https://w3id.org/narn/action/Attack
<https://w3id.org/narn/action/Attack> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/action/ViolentAction> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                        owl:someValuesFrom owl:Thing
                                                      ] ;
                                      owl:disjointWith <https://w3id.org/narn/action/Defend> ;
                                      rdfs:comment "An aggressive action aimed at harming a target."@en ;
                                      rdfs:label "attack"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "assault"@en .


###  https://w3id.org/narn/action/Build
<https://w3id.org/narn/action/Build> rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/CreationAction>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/creates> ;
                                                                                  owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf <https://w3id.org/narn/action/CreationAction> ;
                                     owl:disjointWith <https://w3id.org/narn/action/Forge> ;
                                     rdfs:comment "The action of constructing a structure or settlement."@en ;
                                     rdfs:label "build"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "construction"@en .


###  https://w3id.org/narn/action/Command
<https://w3id.org/narn/action/Command> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ;
                                       rdfs:comment "The action of giving an authoritative order."@en ;
                                       rdfs:label "command"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "order"@en .


###  https://w3id.org/narn/action/CommunicativeAction
<https://w3id.org/narn/action/CommunicativeAction> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/narn/action/Action> ,
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                                     owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                         owl:complementOf <https://w3id.org/narn/location/Place>
                                                                                       ]
                                                                   ] ;
                                                   owl:disjointWith <https://w3id.org/narn/action/MovementAction> ,
                                                                    <https://w3id.org/narn/action/TransferAction> ,
                                                                    <https://w3id.org/narn/action/ViolentAction> ;
                                                   rdfs:comment "An action involving communication between characters."@en ;
                                                   rdfs:label "communicative action"@en ;
                                                   <http://www.w3.org/2004/02/skos/core#altLabel> "speech act"@en .


###  https://w3id.org/narn/action/CreationAction
<https://w3id.org/narn/action/CreationAction> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/action/Action> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://w3id.org/narn/event/creates> ;
                                                                owl:someValuesFrom owl:Thing
                                                              ] ;
                                              owl:disjointWith <https://w3id.org/narn/action/TransferAction> ;
                                              rdfs:comment "An action that produces or transforms something."@en ;
                                              rdfs:label "creation action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "making"@en .


###  https://w3id.org/narn/action/Deceive
<https://w3id.org/narn/action/Deceive> rdf:type owl:Class ;
                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/CommunicativeAction>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <https://w3id.org/narn/action/hasIntention> ;
                                                                                    owl:someValuesFrom <https://w3id.org/narn/action/MisleadingIntention>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ;
                                       rdfs:comment "The action of intentionally misleading another character."@en ;
                                       rdfs:label "deceive"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "deception"@en .


###  https://w3id.org/narn/action/Defend
<https://w3id.org/narn/action/Defend> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/action/ViolentAction> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                        owl:someValuesFrom owl:Thing
                                                      ] ;
                                      rdfs:comment "An action of protecting oneself or others from attack."@en ;
                                      rdfs:label "defend"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "defence"@en .


###  https://w3id.org/narn/action/Escape
<https://w3id.org/narn/action/Escape> rdf:type owl:Class ;
                                      rdfs:comment "The intention of getting away from danger."@en ;
                                      rdfs:label "escape"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "evasion"@en .


###  https://w3id.org/narn/action/Flee
<https://w3id.org/narn/action/Flee> rdf:type owl:Class ;
                                    owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/MovementAction>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://w3id.org/narn/action/hasIntention> ;
                                                                                 owl:someValuesFrom <https://w3id.org/narn/action/Escape>
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/MovementAction> ;
                                    rdfs:comment "The action of running away from danger or pursuit."@en ;
                                    rdfs:label "flee"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "flight"@en .


###  https://w3id.org/narn/action/Forge
<https://w3id.org/narn/action/Forge> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/action/CreationAction> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/creates> ;
                                                       owl:someValuesFrom owl:Thing
                                                     ] ;
                                     rdfs:comment "The action of creating or reshaping an object, especially a weapon."@en ;
                                     rdfs:label "forge"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "smithing"@en .


###  https://w3id.org/narn/action/Give
<https://w3id.org/narn/action/Give> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/TransferAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasRecipient> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasInstrument> ;
                                                      owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                    ] ;
                                    owl:disjointWith <https://w3id.org/narn/action/Take> ;
                                    rdfs:comment "The action of voluntarily transferring something to another."@en ;
                                    rdfs:label "give"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "bestowal"@en .


###  https://w3id.org/narn/action/GoTo
<https://w3id.org/narn/action/GoTo> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/MovementAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ;
                                    rdfs:comment "The action of deliberately travelling to a destination."@en ;
                                    rdfs:label "go to"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "travel to"@en .


###  https://w3id.org/narn/action/Kill
<https://w3id.org/narn/action/Kill> rdf:type owl:Class ;
                                    owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/ViolentAction>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://w3id.org/narn/action/hasResult> ;
                                                                                 owl:someValuesFrom <https://w3id.org/narn/event/Death>
                                                                               ]
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/ViolentAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasResult> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/event/Death>
                                                    ] ;
                                    rdfs:comment "The action of causing the death of another."@en ;
                                    rdfs:label "kill"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "slaying"@en .


###  https://w3id.org/narn/action/MisleadingIntention
<https://w3id.org/narn/action/MisleadingIntention> rdf:type owl:Class ;
                                                   rdfs:comment "The intention of making another believe something false."@en ;
                                                   rdfs:label "misleading intention"@en ;
                                                   <http://www.w3.org/2004/02/skos/core#altLabel> "intent to deceive"@en .


###  https://w3id.org/narn/action/MovementAction
<https://w3id.org/narn/action/MovementAction> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/action/Action> ,
                                                              <https://w3id.org/narn/event/MovementEvent> ;
                                              owl:disjointWith <https://w3id.org/narn/action/ViolentAction> ;
                                              rdfs:comment "An action involving deliberate physical movement."@en ;
                                              rdfs:label "movement action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "locomotion"@en .


###  https://w3id.org/narn/action/Reveal
<https://w3id.org/narn/action/Reveal> rdf:type owl:Class ;
                                      owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/CommunicativeAction>
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <https://w3id.org/narn/action/hasResult> ;
                                                                                   owl:someValuesFrom <https://w3id.org/narn/event/Discovery>
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] ;
                                      rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ;
                                      rdfs:comment "The action of disclosing previously hidden information."@en ;
                                      rdfs:label "reveal"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "disclosure"@en .


###  https://w3id.org/narn/action/Speak
<https://w3id.org/narn/action/Speak> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ;
                                     rdfs:comment "The action of verbal communication."@en ;
                                     rdfs:label "speak"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "utterance"@en .


###  https://w3id.org/narn/action/Take
<https://w3id.org/narn/action/Take> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/TransferAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ;
                                    rdfs:comment "The action of acquiring something, possibly by force."@en ;
                                    rdfs:label "take"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "seizure"@en .


###  https://w3id.org/narn/action/TransferAction
<https://w3id.org/narn/action/TransferAction> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/action/Action> ;
                                              rdfs:comment "An action involving the transfer of possession."@en ;
                                              rdfs:label "transfer action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "transfer"@en .


###  https://w3id.org/narn/action/ViolentAction
<https://w3id.org/narn/action/ViolentAction> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/narn/action/Action> ;
                                             rdfs:comment "An action involving physical violence or force."@en ;
                                             rdfs:label "violent action"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "violent deed"@en .


###  https://w3id.org/narn/event/Battle
<https://w3id.org/narn/event/Battle> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ;
                                     rdfs:comment "A large scale violent confrontation."@en ;
                                     rdfs:label "battle"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "armed conflict"@en .


###  https://w3id.org/narn/event/Betrayal
<https://w3id.org/narn/event/Betrayal> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                       owl:disjointWith <https://w3id.org/narn/event/Meeting> ;
                                       rdfs:comment "An act of disloyalty or treachery."@en ;
                                       rdfs:label "betrayal"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "treachery"@en .


###  https://w3id.org/narn/event/Birth
<https://w3id.org/narn/event/Birth> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/LifeEvent> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/begets> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/occursAt> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ;
                                    owl:disjointWith <https://w3id.org/narn/event/Death> ,
                                                     <https://w3id.org/narn/event/Marriage> ,
                                                     <https://w3id.org/narn/event/Murder> ;
                                    rdfs:comment "A character being born. Every birth begets at least one character."@en ;
                                    rdfs:label "birth"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "nativity"@en .


###  https://w3id.org/narn/event/Captivity
<https://w3id.org/narn/event/Captivity> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "A character is held prisoner."@en ;
                                        rdfs:label "captivity"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "imprisonment"@en .


###  https://w3id.org/narn/event/ConflictEvent
<https://w3id.org/narn/event/ConflictEvent> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                            owl:disjointWith <https://w3id.org/narn/event/MovementEvent> ,
                                                             <https://w3id.org/narn/event/SocialEvent> ;
                                            rdfs:comment "An event involving antagonism or violence."@en ;
                                            rdfs:label "conflict event"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "clash"@en .


###  https://w3id.org/narn/event/Coronation
<https://w3id.org/narn/event/Coronation> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                                         ] ;
                                         rdfs:comment "A ceremony of crowning a ruler."@en ;
                                         rdfs:label "coronation"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "crowning ceremony"@en .


###  https://w3id.org/narn/event/Council
<https://w3id.org/narn/event/Council> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                      rdfs:comment "A formal meeting for deliberation or the reach of a consensus."@en ;
                                      rdfs:label "council"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "deliberation"@en .


###  https://w3id.org/narn/event/Curse
<https://w3id.org/narn/event/Curse> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                    owl:disjointWith <https://w3id.org/narn/event/Prophecy> ;
                                    rdfs:comment "A supernatural imprecation bringing misfortune."@en ;
                                    rdfs:label "curse"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "malediction"@en .


###  https://w3id.org/narn/event/Death
<https://w3id.org/narn/event/Death> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/LifeEvent> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/hasVictim> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ;
                                    rdfs:comment "A character dying. Every death has at least one victim."@en ;
                                    rdfs:label "death"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "demise"@en .


###  https://w3id.org/narn/event/Discovery
<https://w3id.org/narn/event/Discovery> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "An event where something hidden is found or revealed."@en ;
                                        rdfs:label "discovery"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "revelation"@en .


###  https://w3id.org/narn/event/Duel
<https://w3id.org/narn/event/Duel> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/event/hasParticipant> ;
                                                     owl:cardinality "2"^^xsd:nonNegativeInteger
                                                   ] ;
                                   rdfs:comment "A fight between exactly two combatants."@en ;
                                   rdfs:label "duel"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "single combat"@en .


###  https://w3id.org/narn/event/Enchantment
<https://w3id.org/narn/event/Enchantment> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                          rdfs:comment "A magical spell or charm placed on a character."@en ;
                                          rdfs:label "enchantment"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "spell"@en .


###  https://w3id.org/narn/event/Event
<https://w3id.org/narn/event/Event> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/to/FiniteInterval> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/hasParticipant> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/occursAt> ;
                                                      owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ;
                                    rdfs:comment """A spatio-temporal occurrence involving participants at places.
        Every event is a finite temporal interval."""@en ;
                                    rdfs:label "event"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "occurrence"@en .


###  https://w3id.org/narn/event/Exile
<https://w3id.org/narn/event/Exile> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/MovementEvent> ;
                                    rdfs:comment "Forced departure from homeland."@en ;
                                    rdfs:label "exile"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "banishment"@en .


###  https://w3id.org/narn/event/Feast
<https://w3id.org/narn/event/Feast> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                    rdfs:comment "A large celebratory meal or banquet."@en ;
                                    rdfs:label "feast"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "banquet"@en .


###  https://w3id.org/narn/event/Flight
<https://w3id.org/narn/event/Flight> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/MovementEvent> ;
                                     rdfs:comment "Characters flee from danger."@en ;
                                     rdfs:label "flight"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "escape"@en .


###  https://w3id.org/narn/event/LifeEvent
<https://w3id.org/narn/event/LifeEvent> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "A significant moment in a character's life."@en ;
                                        rdfs:label "life event"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "life occurrence"@en .


###  https://w3id.org/narn/event/Marriage
<https://w3id.org/narn/event/Marriage> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/event/LifeEvent> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/narn/event/hasParticipant> ;
                                                         owl:cardinality "2"^^xsd:nonNegativeInteger
                                                       ] ;
                                       rdfs:comment "Two characters getting married. Involves exactly 2 participants."@en ;
                                       rdfs:label "marriage"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "wedding"@en .


###  https://w3id.org/narn/event/Meeting
<https://w3id.org/narn/event/Meeting> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                      rdfs:comment "An encounter or gathering of characters."@en ;
                                      rdfs:label "meeting"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "encounter"@en .


###  https://w3id.org/narn/event/MovementEvent
<https://w3id.org/narn/event/MovementEvent> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                            rdfs:comment "An event involving physical movement of characters between places."@en ;
                                            rdfs:label "movement event"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "movement"@en .


###  https://w3id.org/narn/event/Murder
<https://w3id.org/narn/event/Murder> rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/event/Death>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                                                  owl:someValuesFrom owl:Thing
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/Death> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                       owl:someValuesFrom owl:Thing
                                                     ] ;
                                     owl:disjointWith <https://w3id.org/narn/event/Suicide> ;
                                     rdfs:comment "A death caused intentionally by another. Has at least one agent."@en ;
                                     rdfs:label "murder"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "homicide"@en .


###  https://w3id.org/narn/event/Prophecy
<https://w3id.org/narn/event/Prophecy> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                       rdfs:comment "A prediction of future events, often supernatural."@en ;
                                       rdfs:label "prophecy"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "foretelling"@en .


###  https://w3id.org/narn/event/Siege
<https://w3id.org/narn/event/Siege> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/occursAt> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/location/Settlement>
                                                    ] ;
                                    rdfs:comment "A military blockade of a city or fortress."@en ;
                                    rdfs:label "siege"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "blockade"@en .


###  https://w3id.org/narn/event/SocialEvent
<https://w3id.org/narn/event/SocialEvent> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                          rdfs:comment "An event involving social interaction between characters."@en ;
                                          rdfs:label "social event"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "social gathering"@en .


###  https://w3id.org/narn/event/Suicide
<https://w3id.org/narn/event/Suicide> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/Death> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/event/hasVictim> ;
                                                        owl:cardinality "1"^^xsd:nonNegativeInteger
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                      ] ;
                                      rdfs:comment "A death where the victim is also the agent. At most one agent."@en ;
                                      rdfs:label "suicide"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "self-killing"@en .


###  https://w3id.org/narn/event/Travel
<https://w3id.org/narn/event/Travel> rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/event/MovementEvent>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/hasDestination> ;
                                                                                  owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/hasOrigin> ;
                                                                                  owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/MovementEvent> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/hasDestination> ;
                                                       owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/hasOrigin> ;
                                                       owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                     ] ;
                                     rdfs:comment "A journey. Every travel has origin and destination."@en ;
                                     rdfs:label "travel"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "journey"@en .


###  https://w3id.org/narn/event/Trial
<https://w3id.org/narn/event/Trial> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                    rdfs:comment "A judicial examination or hearing."@en ;
                                    rdfs:label "trial"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "judgement"@en .


###  https://w3id.org/narn/event/War
<https://w3id.org/narn/event/War> rdf:type owl:Class ;
                                  owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/event/ConflictEvent>
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty <https://w3id.org/narn/event/hasSubEvent> ;
                                                                               owl:someValuesFrom <https://w3id.org/narn/event/Battle>
                                                                             ]
                                                                           ) ;
                                                        rdf:type owl:Class
                                                      ] ;
                                  rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ;
                                  rdfs:comment "A prolonged conflict with multiple battles."@en ;
                                  rdfs:label "war"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "prolonged conflict"@en .


###  https://w3id.org/narn/location/Building
<https://w3id.org/narn/location/Building> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                          owl:disjointWith <https://w3id.org/narn/location/NaturalArea> ;
                                          rdfs:comment "A constructed structure."@en ;
                                          rdfs:label "building"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "structure"@en .


###  https://w3id.org/narn/location/City
<https://w3id.org/narn/location/City> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                      owl:disjointWith <https://w3id.org/narn/location/Village> ;
                                      rdfs:comment "A large and significant settlement."@en ;
                                      rdfs:label "city"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "urban area"@en .


###  https://w3id.org/narn/location/Continent
<https://w3id.org/narn/location/Continent> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/location/LandArea> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://w3id.org/narn/location/isAPartOf> ;
                                                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                 owl:complementOf <https://w3id.org/narn/location/LandArea>
                                                                               ]
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty [ owl:inverseOf <https://w3id.org/narn/location/isTheCapitalOf>
                                                                            ] ;
                                                             owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                             owl:onClass <https://w3id.org/narn/location/Settlement>
                                                           ] ;
                                           rdfs:comment "A major landmass."@en ;
                                           rdfs:label "continent"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "landmass"@en .


###  https://w3id.org/narn/location/Desert
<https://w3id.org/narn/location/Desert> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                        owl:disjointWith <https://w3id.org/narn/location/Forest> ;
                                        rdfs:comment "A barren, arid area with little vegetation."@en ;
                                        rdfs:label "desert"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "wasteland"@en .


###  https://w3id.org/narn/location/Forest
<https://w3id.org/narn/location/Forest> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/WoodedArea> ;
                                        rdfs:comment "A large, dense wooded area."@en ;
                                        rdfs:label "forest"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "wood"@en .


###  https://w3id.org/narn/location/Fortress
<https://w3id.org/narn/location/Fortress> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                          rdfs:comment "A fortified place, typically a military stronghold."@en ;
                                          rdfs:label "fortress"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "stronghold"@en .


###  https://w3id.org/narn/location/Hill
<https://w3id.org/narn/location/Hill> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                      rdfs:comment "A naturally raised area of land, smaller than a mountain."@en ;
                                      rdfs:label "hill"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "hillock"@en .


###  https://w3id.org/narn/location/Lake
<https://w3id.org/narn/location/Lake> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                      rdfs:comment "A large body of water surrounded by land."@en ;
                                      rdfs:label "lake"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "body of water"@en .


###  https://w3id.org/narn/location/LandArea
<https://w3id.org/narn/location/LandArea> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                          rdfs:comment "A place that is primarily defined by its land territory."@en ;
                                          rdfs:label "land area"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "land"@en .


###  https://w3id.org/narn/location/Mountain
<https://w3id.org/narn/location/Mountain> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                          owl:disjointWith <https://w3id.org/narn/location/River> ,
                                                           <https://w3id.org/narn/location/Sea> ;
                                          rdfs:comment "A large natural elevation of the earth's surface."@en ;
                                          rdfs:label "mountain"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "peak"@en .


###  https://w3id.org/narn/location/NaturalArea
<https://w3id.org/narn/location/NaturalArea> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                             owl:disjointWith <https://w3id.org/narn/location/Settlement> ;
                                             rdfs:comment "A place defined by natural geographic features rather than habitation."@en ;
                                             rdfs:label "natural area"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "natural feature"@en .


###  https://w3id.org/narn/location/Place
<https://w3id.org/narn/location/Place> rdf:type owl:Class ;
                                       rdfs:comment "A named location that has geographic or spatial significance in a story."@en ;
                                       rdfs:label "place"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "location"@en .


###  https://w3id.org/narn/location/Realm
<https://w3id.org/narn/location/Realm> rdf:type owl:Class ;
                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/location/LandArea>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty [ owl:inverseOf <https://w3id.org/narn/location/isTheCapitalOf>
                                                                                                   ] ;
                                                                                    owl:someValuesFrom <https://w3id.org/narn/location/Settlement>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://w3id.org/narn/location/LandArea> ;
                                       rdfs:comment "A territory under the rule of a king or sovereign authority."@en ;
                                       rdfs:label "realm"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "kingdom"@en .


###  https://w3id.org/narn/location/Region
<https://w3id.org/narn/location/Region> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                        rdfs:comment "A large geographic area, typically contains multiple subplaces."@en ;
                                        rdfs:label "region"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "area"@en .


###  https://w3id.org/narn/location/River
<https://w3id.org/narn/location/River> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                       rdfs:comment "A large natural stream of water."@en ;
                                       rdfs:label "river"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "waterway"@en .


###  https://w3id.org/narn/location/Sea
<https://w3id.org/narn/location/Sea> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                     rdfs:comment "A large body of salt water."@en ;
                                     rdfs:label "sea"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "ocean"@en .


###  https://w3id.org/narn/location/Settlement
<https://w3id.org/narn/location/Settlement> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/location/Place> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://w3id.org/narn/location/isAPartOf> ;
                                                              owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                            ] ;
                                            rdfs:comment "A place where people live permanently."@en ;
                                            rdfs:label "settlement"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "inhabited place"@en .


###  https://w3id.org/narn/location/Town
<https://w3id.org/narn/location/Town> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                      owl:disjointWith <https://w3id.org/narn/location/Village> ;
                                      rdfs:comment "A settlement larger than a village but smaller than a city."@en ;
                                      rdfs:label "town"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "township"@en .


###  https://w3id.org/narn/location/UndergroundCity
<https://w3id.org/narn/location/UndergroundCity> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/location/City>
                                                                                            <https://w3id.org/narn/location/UndergroundPlace>
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "A city built underground, within caves or excavated halls."@en ;
                                                 rdfs:label "underground city"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "subterranean city"@en .


###  https://w3id.org/narn/location/UndergroundPlace
<https://w3id.org/narn/location/UndergroundPlace> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                                  rdfs:comment "A place located beneath the surface of the earth."@en ;
                                                  rdfs:label "underground place"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "subterranean place"@en .


###  https://w3id.org/narn/location/Valley
<https://w3id.org/narn/location/Valley> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                        rdfs:comment "A low area of land between hills or mountains."@en ;
                                        rdfs:label "valley"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "vale"@en .


###  https://w3id.org/narn/location/Village
<https://w3id.org/narn/location/Village> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                         rdfs:comment "A small settlement, typically in a rural area."@en ;
                                         rdfs:label "village"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "hamlet"@en .


###  https://w3id.org/narn/location/WildArea
<https://w3id.org/narn/location/WildArea> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                          rdfs:comment "An uncultivated, uninhabited region."@en ;
                                          rdfs:label "wild area"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "wilderness"@en .


###  https://w3id.org/narn/location/WoodedArea
<https://w3id.org/narn/location/WoodedArea> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                            rdfs:comment "A land area predominantly covered by trees."@en ;
                                            rdfs:label "wooded area"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "woodland"@en .


###  https://w3id.org/narn/plot/Act
<https://w3id.org/narn/plot/Act> rdf:type owl:Class ;
                                 rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ;
                                 rdfs:comment "A major division in drama or narrative, often five in classical structure."@en ;
                                 rdfs:label "act"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "story act"@en .


###  https://w3id.org/narn/plot/Anagnorisis
<https://w3id.org/narn/plot/Anagnorisis> rdf:type owl:Class ;
                                         owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/plot/PlotDevice>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <https://w3id.org/narn/plot/correspondsToEvent> ;
                                                                                      owl:someValuesFrom <https://w3id.org/narn/event/Discovery>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                         rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                         rdfs:comment "The point in a play, novel, etc., in which a principal character recognizes or discovers another character's true identity or the true nature of their own circumstances."@en ;
                                         rdfs:label "anagnorisis"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "moment of recognition"@en .


###  https://w3id.org/narn/plot/Antagonist
<https://w3id.org/narn/plot/Antagonist> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                        owl:disjointWith <https://w3id.org/narn/plot/Protagonist> ;
                                        rdfs:comment "The character who opposes the protagonist."@en ;
                                        rdfs:label "antagonist"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "villain"@en .


###  https://w3id.org/narn/plot/Chapter
<https://w3id.org/narn/plot/Chapter> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ;
                                     rdfs:comment "A numbered or titled section of a narrative."@en ;
                                     rdfs:label "chapter"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "story chapter"@en .


###  https://w3id.org/narn/plot/CharacterRole
<https://w3id.org/narn/plot/CharacterRole> rdf:type owl:Class ;
                                           rdfs:comment "The narrative function a character plays in the story."@en ;
                                           rdfs:label "character role"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "story role"@en .


###  https://w3id.org/narn/plot/Climax
<https://w3id.org/narn/plot/Climax> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                    owl:disjointWith <https://w3id.org/narn/plot/Exposition> ,
                                                     <https://w3id.org/narn/plot/Resolution> ;
                                    rdfs:comment "The turning point; the moment of highest tension."@en ;
                                    rdfs:label "climax"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "turning point"@en .


###  https://w3id.org/narn/plot/Conflict
<https://w3id.org/narn/plot/Conflict> rdf:type owl:Class ;
                                      owl:disjointWith <https://w3id.org/narn/plot/Genre> ;
                                      rdfs:comment "A struggle between opposing forces driving the plot."@en ;
                                      rdfs:label "conflict"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "tension"@en .


###  https://w3id.org/narn/plot/Denouement
<https://w3id.org/narn/plot/Denouement> rdf:type owl:Class ;
                                        owl:equivalentClass <https://w3id.org/narn/plot/Resolution> ;
                                        rdfs:comment "Equivalent to resolution. The unravelling of the plot."@en ;
                                        rdfs:label "denouement"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "final outcome"@en .


###  https://w3id.org/narn/plot/DramaticIrony
<https://w3id.org/narn/plot/DramaticIrony> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                           rdfs:comment "When the audience knows more than the characters."@en ;
                                           rdfs:label "dramatic irony"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "audience knowledge gap"@en .


###  https://w3id.org/narn/plot/Epic
<https://w3id.org/narn/plot/Epic> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://w3id.org/narn/plot/Genre> ;
                                  rdfs:comment "A long narrative involving heroic deeds and grand scale."@en ;
                                  rdfs:label "epic"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "epic genre"@en .


###  https://w3id.org/narn/plot/Exposition
<https://w3id.org/narn/plot/Exposition> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                        owl:disjointWith <https://w3id.org/narn/plot/Resolution> ;
                                        rdfs:comment "Introduction of setting, characters, and background."@en ;
                                        rdfs:label "exposition"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "setup"@en .


###  https://w3id.org/narn/plot/ExternalConflict
<https://w3id.org/narn/plot/ExternalConflict> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/plot/Conflict> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://w3id.org/narn/plot/conflictInvolves> ;
                                                                owl:minCardinality "2"^^xsd:nonNegativeInteger
                                                              ] ;
                                              owl:disjointWith <https://w3id.org/narn/plot/InternalConflict> ;
                                              rdfs:comment "Conflict between a character and an external force (antagonist, nature, society)."@en ;
                                              rdfs:label "external conflict"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "outer struggle"@en .


###  https://w3id.org/narn/plot/FallingAction
<https://w3id.org/narn/plot/FallingAction> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                           owl:disjointWith <https://w3id.org/narn/plot/RisingAction> ;
                                           rdfs:comment "Events after the climax leading to the resolution."@en ;
                                           rdfs:label "falling action"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "unwinding"@en .


###  https://w3id.org/narn/plot/Fantasy
<https://w3id.org/narn/plot/Fantasy> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/plot/Genre> ;
                                     rdfs:comment "A story with magical or supernatural elements."@en ;
                                     rdfs:label "fantasy"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "fantasy genre"@en .


###  https://w3id.org/narn/plot/Flashback
<https://w3id.org/narn/plot/Flashback> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                       rdfs:comment "A scene set in a time earlier than the main story."@en ;
                                       rdfs:label "flashback"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "retrospection"@en .


###  https://w3id.org/narn/plot/Foreshadowing
<https://w3id.org/narn/plot/Foreshadowing> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://w3id.org/narn/plot/foreshadowsEvent> ;
                                                             owl:allValuesFrom <https://w3id.org/narn/event/Event>
                                                           ] ;
                                           rdfs:comment "Hints or clues about future events in the story."@en ;
                                           rdfs:label "foreshadowing"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "hint of future events"@en .


###  https://w3id.org/narn/plot/Genre
<https://w3id.org/narn/plot/Genre> rdf:type owl:Class ;
                                   rdfs:comment "A category of narrative with shared conventions."@en ;
                                   rdfs:label "genre"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "literary genre"@en .


###  https://w3id.org/narn/plot/IncitingIncident
<https://w3id.org/narn/plot/IncitingIncident> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                              owl:disjointWith <https://w3id.org/narn/plot/Resolution> ;
                                              rdfs:comment "The event that sets the main conflict in motion."@en ;
                                              rdfs:label "inciting incident"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "catalyst"@en .


###  https://w3id.org/narn/plot/InternalConflict
<https://w3id.org/narn/plot/InternalConflict> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/plot/Conflict> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://w3id.org/narn/plot/conflictInvolves> ;
                                                                owl:cardinality "1"^^xsd:nonNegativeInteger
                                                              ] ;
                                              rdfs:comment "Conflict within a character (e.g. moral dilemma, fear)."@en ;
                                              rdfs:label "internal conflict"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "inner struggle"@en .


###  https://w3id.org/narn/plot/MacGuffin
<https://w3id.org/narn/plot/MacGuffin> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                       rdfs:comment "An object or goal that motivates the plot but has no intrinsic importance."@en ;
                                       rdfs:label "MacGuffin"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "plot motivator"@en .


###  https://w3id.org/narn/plot/Mentor
<https://w3id.org/narn/plot/Mentor> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                    rdfs:comment "A character who guides or teaches the protagonist."@en ;
                                    rdfs:label "mentor"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "guide figure"@en .


###  https://w3id.org/narn/plot/NarrativeElement
<https://w3id.org/narn/plot/NarrativeElement> rdf:type owl:Class ;
                                              owl:disjointWith <https://w3id.org/narn/plot/PlotDevice> ;
                                              rdfs:comment "A stage in the narrative arc."@en ;
                                              rdfs:label "narrative element"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "story element"@en .


###  https://w3id.org/narn/plot/NarrativeUnit
<https://w3id.org/narn/plot/NarrativeUnit> rdf:type owl:Class ;
                                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://w3id.org/narn/plot/containsUnit> ;
                                                             owl:allValuesFrom <https://w3id.org/narn/plot/NarrativeUnit>
                                                           ] ;
                                           rdfs:comment "A structural division of a story."@en ;
                                           rdfs:label "narrative unit"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "story division"@en .


###  https://w3id.org/narn/plot/Part
<https://w3id.org/narn/plot/Part> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <https://w3id.org/narn/plot/containsUnit> ;
                                                    owl:someValuesFrom <https://w3id.org/narn/plot/Chapter>
                                                  ] ;
                                  rdfs:comment "A major division of a story containing chapters."@en ;
                                  rdfs:label "part"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "story part"@en .


###  https://w3id.org/narn/plot/Peripeteia
<https://w3id.org/narn/plot/Peripeteia> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                        rdfs:comment "A sudden reversal of fortune or change in circumstances."@en ;
                                        rdfs:label "peripeteia"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "reversal of fortune"@en .


###  https://w3id.org/narn/plot/PlotDevice
<https://w3id.org/narn/plot/PlotDevice> rdf:type owl:Class ;
                                        rdfs:comment "A technique used to advance or structure the plot."@en ;
                                        rdfs:label "plot device"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "narrative device"@en .


###  https://w3id.org/narn/plot/PlotTwist
<https://w3id.org/narn/plot/PlotTwist> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                       rdfs:comment "An unexpected revelation that changes the story's direction."@en ;
                                       rdfs:label "plot twist"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "unexpected turn"@en .


###  https://w3id.org/narn/plot/Protagonist
<https://w3id.org/narn/plot/Protagonist> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                         rdfs:comment "The main character; the one driving the action."@en ;
                                         rdfs:label "protagonist"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "main character"@en .


###  https://w3id.org/narn/plot/Resolution
<https://w3id.org/narn/plot/Resolution> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                        rdfs:comment "The outcome; how the conflict is resolved."@en ;
                                        rdfs:label "resolution"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "conclusion"@en .


###  https://w3id.org/narn/plot/RisingAction
<https://w3id.org/narn/plot/RisingAction> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                          rdfs:comment "Series of events building tension toward the climax."@en ;
                                          rdfs:label "rising action"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "complication"@en .


###  https://w3id.org/narn/plot/Scene
<https://w3id.org/narn/plot/Scene> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/plot/containsUnit> ;
                                                     owl:allValuesFrom owl:Nothing
                                                   ] ;
                                   rdfs:comment "The smallest narrative unit; a continuous action in one setting."@en ;
                                   rdfs:label "scene"@en ;
