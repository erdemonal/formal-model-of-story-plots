@prefix : <https://w3id.org/narn/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/narn/> .

<https://w3id.org/narn/> rdf:type owl:Ontology ;
                          rdfs:comment "An OWL ontology for modeling story plots and narrative structures. It provides a formal vocabulary to represent characters, locations, events, actions, and temporal relations within a narrative."@en ;
                          rdfs:label "Formal Model of Story Plots"@en ;
                          <https://purl.org/dc/terms/created> "2026-03-17"^^xsd:date ;
                          <https://purl.org/dc/terms/creator> <https://w3id.org/people/erdemonal/me> ;
                          <https://purl.org/dc/terms/modified> "2026-03-19"^^xsd:date ;
                          <https://purl.org/vocab/vann/preferredNamespacePrefix> "narn" ;
                          <https://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/narn/" .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
<http://www.w3.org/2004/02/skos/core#example> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/created
<https://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/creator
<https://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/modified
<https://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  https://purl.org/vocab/vann/preferredNamespacePrefix
<https://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  https://purl.org/vocab/vann/preferredNamespaceUri
<https://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#duration
xsd:duration rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/narn/action/causesByAction
<https://w3id.org/narn/action/causesByAction> rdf:type owl:ObjectProperty ;
                                              owl:propertyChainAxiom ( [ owl:inverseOf <https://w3id.org/narn/action/performedBy>
                                                                       ]
                                                                       <https://w3id.org/narn/action/hasResult>
                                                                     ) ;
                                              rdfs:comment "If an agent performs an action with a result, the agent indirectly causes that result."@en ;
                                              rdfs:label "causes by action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "brings about"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Turambar causes the death of Glaurung by performing the slaying."@en .


###  https://w3id.org/narn/action/hasInstrument
<https://w3id.org/narn/action/hasInstrument> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://w3id.org/narn/event/hasCause> ;
                                             rdf:type owl:IrreflexiveProperty ;
                                             rdfs:domain <https://w3id.org/narn/action/Action> ;
                                             owl:propertyDisjointWith <https://w3id.org/narn/action/hasTarget> ,
                                                                      <https://w3id.org/narn/action/performedBy> ;
                                             rdfs:comment "An object used to perform the action (e.g. a sword)."@en ;
                                             rdfs:label "has instrument"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "using"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "The Slaying of Glaurung has instrument Gurthang."@en .


###  https://w3id.org/narn/action/hasIntention
<https://w3id.org/narn/action/hasIntention> rdf:type owl:ObjectProperty ,
                                                     owl:FunctionalProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain <https://w3id.org/narn/action/Action> ;
                                            rdfs:comment "The goal or purpose behind the action."@en ;
                                            rdfs:label "has intention"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "aims to"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Túrin's flight from Doriath has the intention of escaping judgement."@en .


###  https://w3id.org/narn/action/hasRecipient
<https://w3id.org/narn/action/hasRecipient> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://w3id.org/narn/event/hasParticipant> ;
                                            rdf:type owl:IrreflexiveProperty ;
                                            rdfs:domain <https://w3id.org/narn/action/TransferAction> ;
                                            owl:propertyDisjointWith <https://w3id.org/narn/action/performedBy> ;
                                            rdfs:comment "The character who receives something in a transfer action."@en ;
                                            rdfs:label "has recipient"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "received by"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Beleg's gift of Anglachel has recipient Túrin."@en .


###  https://w3id.org/narn/action/hasResult
<https://w3id.org/narn/action/hasResult> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://w3id.org/narn/event/causes> ;
                                         rdfs:domain <https://w3id.org/narn/action/Action> ;
                                         rdfs:range <https://w3id.org/narn/event/Event> ;
                                         rdfs:comment "The event or state that results from the action."@en ;
                                         rdfs:label "has result"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "results in"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Brandir's speech results in the truth about Níniel being revealed."@en .


###  https://w3id.org/narn/action/hasTarget
<https://w3id.org/narn/action/hasTarget> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://w3id.org/narn/event/hasPatient> ;
                                         rdf:type owl:AsymmetricProperty ,
                                                  owl:IrreflexiveProperty ;
                                         rdfs:domain <https://w3id.org/narn/action/Action> ;
                                         rdfs:comment "The entity that the action is directed towards."@en ;
                                         rdfs:label "has target"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "directed at"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "The Slaying of Glaurung has target Glaurung."@en .


###  https://w3id.org/narn/action/performedBy
<https://w3id.org/narn/action/performedBy> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://w3id.org/narn/event/hasAgent> ;
                                           rdfs:domain <https://w3id.org/narn/action/Action> ;
                                           rdfs:comment "The agent who intentionally performs the action."@en ;
                                           rdfs:label "performed by"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "done by"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "The Slaying of Glaurung was performed by Turambar."@en .


###  https://w3id.org/narn/event/begets
<https://w3id.org/narn/event/begets> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://w3id.org/narn/event/hasParticipant> ;
                                     rdfs:domain <https://w3id.org/narn/event/Birth> ;
                                     rdfs:comment "The character brought into existence by a birth event."@en ;
                                     rdfs:label "begets"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "brings forth"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The birth of Túrin begets Túrin."@en .


###  https://w3id.org/narn/event/causes
<https://w3id.org/narn/event/causes> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://w3id.org/narn/event/precedes> ;
                                     rdf:type owl:AsymmetricProperty ,
                                              owl:TransitiveProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:domain <https://w3id.org/narn/event/Event> ;
                                     rdfs:range <https://w3id.org/narn/event/Event> ;
                                     rdfs:comment "This event causally leads to another event."@en ;
                                     rdfs:label "causes"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "leads to"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The death of Saeros causes the exile of Túrin from Doriath."@en .


###  https://w3id.org/narn/event/creates
<https://w3id.org/narn/event/creates> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <https://w3id.org/narn/event/Event> ;
                                      rdfs:comment "An entity produced or created by the event."@en ;
                                      rdfs:label "creates"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "results in"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The reforging of Anglachel creates Gurthang."@en .


###  https://w3id.org/narn/event/hasAgent
<https://w3id.org/narn/event/hasAgent> rdf:type owl:ObjectProperty ;
                                       rdfs:subPropertyOf <https://w3id.org/narn/event/hasParticipant> ;
                                       rdf:type owl:IrreflexiveProperty ;
                                       rdfs:domain <https://w3id.org/narn/event/Event> ;
                                       owl:propertyDisjointWith <https://w3id.org/narn/event/hasWitness> ;
                                       rdfs:comment "The entity that intentionally causes or performs the event."@en ;
                                       rdfs:label "has agent"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "done by"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The death of Saeros has agent Túrin."@en .


###  https://w3id.org/narn/event/hasCause
<https://w3id.org/narn/event/hasCause> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <https://w3id.org/narn/event/Event> ;
                                       rdfs:comment "An entity involved as a contributing cause in the event."@en ;
                                       rdfs:label "has cause"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "caused by"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The death of Beleg has cause Anglachel."@en .


###  https://w3id.org/narn/event/hasDestination
<https://w3id.org/narn/event/hasDestination> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://w3id.org/narn/event/occursAt> ;
                                             rdfs:domain <https://w3id.org/narn/event/MovementEvent> ;
                                             rdfs:range <https://w3id.org/narn/location/Place> ;
                                             owl:propertyDisjointWith <https://w3id.org/narn/event/hasOrigin> ;
                                             rdfs:comment "The ending place of a movement event."@en ;
                                             rdfs:label "has destination"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "arrives at"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "Túrin's journey has destination Doriath."@en .


###  https://w3id.org/narn/event/hasOrigin
<https://w3id.org/narn/event/hasOrigin> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf <https://w3id.org/narn/event/occursAt> ;
                                        rdfs:domain <https://w3id.org/narn/event/MovementEvent> ;
                                        rdfs:range <https://w3id.org/narn/location/Place> ;
                                        rdfs:comment "The starting place of a movement event."@en ;
                                        rdfs:label "has origin"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "departs from"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Túrin's journey to Doriath has origin Dor-lómin."@en .


###  https://w3id.org/narn/event/hasParticipant
<https://w3id.org/narn/event/hasParticipant> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://w3id.org/narn/event/Event> ;
                                             rdfs:comment "An entity that takes part in the event."@en ;
                                             rdfs:label "has participant"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "involves"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears has participant Húrin."@en .


###  https://w3id.org/narn/event/hasPatient
<https://w3id.org/narn/event/hasPatient> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://w3id.org/narn/event/hasParticipant> ;
                                         rdfs:domain <https://w3id.org/narn/event/Event> ;
                                         rdfs:comment "The entity affected by the event."@en ;
                                         rdfs:label "has patient"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "affects"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Glaurung hypnotises Níniel, with Níniel as the patient."@en .


###  https://w3id.org/narn/event/hasSubEvent
<https://w3id.org/narn/event/hasSubEvent> rdf:type owl:ObjectProperty ,
                                                   owl:AsymmetricProperty ,
                                                   owl:TransitiveProperty ,
                                                   owl:IrreflexiveProperty ;
                                          rdfs:domain <https://w3id.org/narn/event/Event> ;
                                          rdfs:range <https://w3id.org/narn/event/Event> ;
                                          rdfs:comment "A smaller event that occurs as part of this one."@en ;
                                          rdfs:label "has subevent"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "contains event"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The Wars of Beleriand has subevent the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/event/hasTraveller
<https://w3id.org/narn/event/hasTraveller> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://w3id.org/narn/event/hasParticipant> ;
                                           rdfs:domain <https://w3id.org/narn/event/Travel> ;
                                           rdfs:comment "The character who undertakes the travel."@en ;
                                           rdfs:label "has traveller"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "travelled by"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Túrin, Gethron and Grithnir are travellers in the journey to Doriath."@en .


###  https://w3id.org/narn/event/hasVictim
<https://w3id.org/narn/event/hasVictim> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf <https://w3id.org/narn/event/hasPatient> ;
                                        rdfs:domain <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "The entity that suffers harm in the event."@en ;
                                        rdfs:label "has victim"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "harms"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The death of Beleg has victim Beleg."@en .


###  https://w3id.org/narn/event/hasWitness
<https://w3id.org/narn/event/hasWitness> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://w3id.org/narn/event/hasParticipant> ;
                                         rdfs:domain <https://w3id.org/narn/event/Event> ;
                                         rdfs:comment "An entity that observes the event without acting."@en ;
                                         rdfs:label "has witness"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "observed by"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Mîm's betrayal has witness Andróg."@en .


###  https://w3id.org/narn/event/isBegottenIn
<https://w3id.org/narn/event/isBegottenIn> rdf:type owl:ObjectProperty ;
                                           owl:inverseOf <https://w3id.org/narn/event/begets> ;
                                           rdfs:domain owl:Thing ;
                                           rdfs:range <https://w3id.org/narn/event/Birth> ;
                                           rdfs:comment "Inverse of begets. Links a character to the birth event that brings them into existence."@en ;
                                           rdfs:label "is begotten in"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Túrin is begotten in the birth of Túrin."@en .


###  https://w3id.org/narn/event/isCausedBy
<https://w3id.org/narn/event/isCausedBy> rdf:type owl:ObjectProperty ;
                                         owl:inverseOf <https://w3id.org/narn/event/causes> ;
                                         rdfs:comment "Inverse of causes. This event results from another."@en ;
                                         rdfs:label "is caused by"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "results from"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "The exile of Túrin is caused by the death of Saeros."@en .


###  https://w3id.org/narn/event/isSubEventOf
<https://w3id.org/narn/event/isSubEventOf> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://w3id.org/narn/to/during> ;
                                           owl:inverseOf <https://w3id.org/narn/event/hasSubEvent> ;
                                           rdfs:comment "This event is part of a larger event."@en ;
                                           rdfs:label "is subevent of"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "part of event"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad is a subevent of the Wars of Beleriand."@en .


###  https://w3id.org/narn/event/occursAt
<https://w3id.org/narn/event/occursAt> rdf:type owl:ObjectProperty ,
                                                owl:IrreflexiveProperty ;
                                       rdfs:domain <https://w3id.org/narn/event/Event> ;
                                       rdfs:range <https://w3id.org/narn/location/Place> ;
                                       rdfs:comment "The place where the event occurs."@en ;
                                       rdfs:label "occurs at"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "takes place at"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The Captivity of Húrin occurs at Angband."@en .


###  https://w3id.org/narn/event/precedes
<https://w3id.org/narn/event/precedes> rdf:type owl:ObjectProperty ;
                                       rdfs:subPropertyOf <https://w3id.org/narn/to/precedes> ;
                                       rdf:type owl:AsymmetricProperty ,
                                                owl:TransitiveProperty ,
                                                owl:IrreflexiveProperty ;
                                       rdfs:domain <https://w3id.org/narn/event/Event> ;
                                       rdfs:range <https://w3id.org/narn/event/Event> ;
                                       rdfs:comment "This event occurs before another event."@en ;
                                       rdfs:label "precedes"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "comes before"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad precedes Túrin's journey to Doriath."@en .


###  https://w3id.org/narn/location/borders
<https://w3id.org/narn/location/borders> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://w3id.org/narn/location/hasSpatialRelation> ;
                                         rdf:type owl:SymmetricProperty ,
                                                  owl:IrreflexiveProperty ;
                                         owl:propertyDisjointWith <https://w3id.org/narn/rcc/DC> ;
                                         rdfs:comment "Two places share a boundary but neither contains the other."@en ;
                                         rdfs:label "borders"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "adjacent to"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Doriath borders Brethil."@en .


###  https://w3id.org/narn/location/contains
<https://w3id.org/narn/location/contains> rdf:type owl:ObjectProperty ;
                                          rdfs:subPropertyOf <https://w3id.org/narn/location/hasSpatialRelation> ;
                                          owl:inverseOf <https://w3id.org/narn/location/isAPartOf> ;
                                          rdf:type owl:TransitiveProperty ;
                                          rdfs:domain <https://w3id.org/narn/location/Place> ;
                                          rdfs:range <https://w3id.org/narn/location/Place> ;
                                          owl:propertyDisjointWith <https://w3id.org/narn/rcc/DC> ,
                                                                   <https://w3id.org/narn/rcc/EC> ,
                                                                   <https://w3id.org/narn/rcc/PO> ;
                                          rdfs:comment "Inverse of isAPartOf."@en ;
                                          rdfs:label "contains"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "includes"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Beleriand contains Doriath."@en .


###  https://w3id.org/narn/location/hasSpatialRelation
<https://w3id.org/narn/location/hasSpatialRelation> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/narn/location/Place> ;
                                                    rdfs:range <https://w3id.org/narn/location/Place> ;
                                                    rdfs:comment "A general spatial relation between two places."@en ;
                                                    rdfs:label "has spatial relation"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#altLabel> "spatially related to"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#example> "Doriath has a spatial relation to Brethil, as they border each other."@en .


###  https://w3id.org/narn/location/isAPartOf
<https://w3id.org/narn/location/isAPartOf> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://w3id.org/narn/location/hasSpatialRelation> ;
                                           rdf:type owl:TransitiveProperty ;
                                           rdfs:domain <https://w3id.org/narn/location/Place> ;
                                           rdfs:range <https://w3id.org/narn/location/Place> ;
                                           owl:propertyDisjointWith <https://w3id.org/narn/rcc/DC> ,
                                                                    <https://w3id.org/narn/rcc/EC> ,
                                                                    <https://w3id.org/narn/rcc/PO> ;
                                           rdfs:comment "Indicates that a place constitutes a subarea of another place."@en ;
                                           rdfs:label "is a part of"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "part of"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Dor-lómin is a part of Hithlum."@en .


###  https://w3id.org/narn/location/isNear
<https://w3id.org/narn/location/isNear> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf <https://w3id.org/narn/location/hasSpatialRelation> ;
                                        rdf:type owl:SymmetricProperty ,
                                                 owl:IrreflexiveProperty ;
                                        owl:propertyDisjointWith <https://w3id.org/narn/rcc/DC> ;
                                        rdfs:comment "Two places are in proximity."@en ;
                                        rdfs:label "is near"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "close to"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The river Narog is near Nargothrond."@en .


###  https://w3id.org/narn/location/isStrictlyInsideOf
<https://w3id.org/narn/location/isStrictlyInsideOf> rdf:type owl:ObjectProperty ;
                                                    rdfs:subPropertyOf <https://w3id.org/narn/location/isAPartOf> ;
                                                    rdf:type owl:AsymmetricProperty ,
                                                             owl:TransitiveProperty ,
                                                             owl:IrreflexiveProperty ;
                                                    rdfs:comment "Stricter form of isAPartOf where boundaries do not touch."@en ;
                                                    rdfs:label "is strictly inside of"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#altLabel> "strictly within"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#example> "Gondolin is strictly inside of Tumladen."@en .


###  https://w3id.org/narn/location/isTheCapitalOf
<https://w3id.org/narn/location/isTheCapitalOf> rdf:type owl:ObjectProperty ,
                                                         owl:FunctionalProperty ;
                                                rdfs:domain <https://w3id.org/narn/location/Settlement> ;
                                                rdfs:range <https://w3id.org/narn/location/Realm> ;
                                                rdfs:comment "A settlement is the capital of a realm."@en ;
                                                rdfs:label "is the capital of"@en ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "capital of"@en ;
                                                <http://www.w3.org/2004/02/skos/core#example> "Menegroth is the capital of Doriath."@en .


###  https://w3id.org/narn/plot/conflictInvolves
<https://w3id.org/narn/plot/conflictInvolves> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/narn/plot/Conflict> ;
                                              owl:propertyDisjointWith <https://w3id.org/narn/plot/hasAuthor> ;
                                              rdfs:comment "A character or entity involved in the conflict."@en ;
                                              rdfs:label "conflict involves"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "tension involves"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Morgoth's curse involves Morgoth and Húrin."@en .


###  https://w3id.org/narn/plot/containsUnit
<https://w3id.org/narn/plot/containsUnit> rdf:type owl:ObjectProperty ,
                                                   owl:TransitiveProperty ;
                                          rdfs:domain <https://w3id.org/narn/plot/NarrativeUnit> ;
                                          rdfs:range <https://w3id.org/narn/plot/NarrativeUnit> ;
                                          rdfs:comment "Relates a narrative unit to its contained subunits."@en ;
                                          rdfs:label "contains unit"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "includes unit"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Part I contains the chapter Túrin in Dor-lómin."@en .


###  https://w3id.org/narn/plot/correspondsToEvent
<https://w3id.org/narn/plot/correspondsToEvent> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <https://w3id.org/narn/plot/NarrativeElement> ;
                                                rdfs:range <https://w3id.org/narn/event/Event> ;
                                                rdfs:comment "Maps a narrative element to the event it represents."@en ;
                                                rdfs:label "corresponds to event"@en ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "maps to event"@en ;
                                                <http://www.w3.org/2004/02/skos/core#example> "The Climax corresponds to the Slaying of Glaurung."@en .


###  https://w3id.org/narn/plot/deviceInvolvesCharacter
<https://w3id.org/narn/plot/deviceInvolvesCharacter> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/narn/plot/PlotDevice> ;
                                                     rdfs:comment "A character involved in or affected by this plot device."@en ;
                                                     rdfs:label "device involves character"@en ;
                                                     <http://www.w3.org/2004/02/skos/core#altLabel> "device concerns"@en ;
                                                     <http://www.w3.org/2004/02/skos/core#example> "The Anagnorisis device involves Níniel and Turambar."@en .


###  https://w3id.org/narn/plot/follows
<https://w3id.org/narn/plot/follows> rdf:type owl:ObjectProperty ,
                                              owl:AsymmetricProperty ,
                                              owl:TransitiveProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:domain <https://w3id.org/narn/plot/NarrativeUnit> ;
                                     rdfs:range <https://w3id.org/narn/plot/NarrativeUnit> ;
                                     rdfs:comment "One narrative unit sequentially comes after another."@en ;
                                     rdfs:label "follows"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "comes after"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Part II follows Part I in the Narn."@en .


###  https://w3id.org/narn/plot/foreshadowsEvent
<https://w3id.org/narn/plot/foreshadowsEvent> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/narn/plot/Foreshadowing> ;
                                              rdfs:range <https://w3id.org/narn/event/Event> ;
                                              rdfs:comment "The event that this foreshadowing hints at."@en ;
                                              rdfs:label "foreshadows event"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "hints at"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Morgoth's curse foreshadows the death of Turambar."@en .


###  https://w3id.org/narn/plot/hasAuthor
<https://w3id.org/narn/plot/hasAuthor> rdf:type owl:ObjectProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                       rdfs:comment "The author of the story."@en ;
                                       rdfs:label "has author"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "written by"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The Narn has author J.R.R. Tolkien."@en .


###  https://w3id.org/narn/plot/hasConflict
<https://w3id.org/narn/plot/hasConflict> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                         rdfs:range <https://w3id.org/narn/plot/Conflict> ;
                                         rdfs:comment "A conflict central to the story."@en ;
                                         rdfs:label "has conflict"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "has tension"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Morgoth's curse against Húrin's family is a conflict in the Narn."@en .


###  https://w3id.org/narn/plot/hasGenre
<https://w3id.org/narn/plot/hasGenre> rdf:type owl:ObjectProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                      rdfs:range <https://w3id.org/narn/plot/Genre> ;
                                      rdfs:comment "The genre(s) of the story."@en ;
                                      rdfs:label "has genre"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "genre is"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The Narn has genre Tragedy, Epic, and Fantasy."@en .


###  https://w3id.org/narn/plot/hasNarrativeElement
<https://w3id.org/narn/plot/hasNarrativeElement> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                                 rdfs:range <https://w3id.org/narn/plot/NarrativeElement> ;
                                                 rdfs:comment "Links a story to its plot stages."@en ;
                                                 rdfs:label "has narrative element"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "has element"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#example> "The Narn includes narrative elements like Exposition and Climax."@en .


###  https://w3id.org/narn/plot/hasNarrativeUnit
<https://w3id.org/narn/plot/hasNarrativeUnit> rdf:type owl:ObjectProperty ,
                                                       owl:AsymmetricProperty ,
                                                       owl:IrreflexiveProperty ;
                                              rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                              rdfs:range <https://w3id.org/narn/plot/NarrativeUnit> ;
                                              rdfs:comment "Links a story to its structural units."@en ;
                                              rdfs:label "has narrative unit"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "divided into"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "The Narn has narrative units Part I, Part II, Part III."@en .


###  https://w3id.org/narn/plot/hasRole
<https://w3id.org/narn/plot/hasRole> rdf:type owl:ObjectProperty ;
                                     rdfs:range <https://w3id.org/narn/plot/CharacterRole> ;
                                     rdfs:comment "The narrative role a character plays."@en ;
                                     rdfs:label "has role"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "plays role"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Túrin has role Protagonist and Tragic Hero."@en .


###  https://w3id.org/narn/plot/hasTheme
<https://w3id.org/narn/plot/hasTheme> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                      rdfs:comment "A thematic element or motif in the story."@en ;
                                      rdfs:label "has theme"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "explores theme"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The Narn explores themes like fate and pride."@en .


###  https://w3id.org/narn/plot/involvedInDevice
<https://w3id.org/narn/plot/involvedInDevice> rdf:type owl:ObjectProperty ;
                                              rdfs:comment "Links a character role to a narrative device that affects them."@en ;
                                              rdfs:label "involved in device"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "affected by narrative device"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Túrin is involved in the Peripeteia device."@en .


###  https://w3id.org/narn/plot/isUnitOf
<https://w3id.org/narn/plot/isUnitOf> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <https://w3id.org/narn/plot/containsUnit> ;
                                      rdfs:comment "Inverse of containsUnit, relates a unit to its parent."@en ;
                                      rdfs:label "is unit of"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "belongs to"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The chapter Túrin in Dor-lómin is a unit of Part I."@en .


###  https://w3id.org/narn/plot/occursInUnit
<https://w3id.org/narn/plot/occursInUnit> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <https://w3id.org/narn/plot/NarrativeElement> ;
                                          rdfs:range <https://w3id.org/narn/plot/NarrativeUnit> ;
                                          rdfs:comment "The narrative unit in which this element appears."@en ;
                                          rdfs:label "occurs in unit"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "located in unit"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The Falling Action occurs in Part III."@en .


###  https://w3id.org/narn/plot/usesDevice
<https://w3id.org/narn/plot/usesDevice> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                        rdfs:range <https://w3id.org/narn/plot/PlotDevice> ;
                                        rdfs:comment "Links a story to the plot devices it employs."@en ;
                                        rdfs:label "uses device"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "employs device"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The Narn uses devices: Dramatic Irony, Anagnorisis, Peripeteia."@en .


###  https://w3id.org/narn/rcc/DC
<https://w3id.org/narn/rcc/DC> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               rdfs:comment "Describes a spatial relation where two regions are strictly disjoint and share no spatial points."@en ;
                               rdfs:label "disconnected"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "disjoint regions"@en ;
                               <http://www.w3.org/2004/02/skos/core#example> "Angband and Doriath are disconnected since they share no spatial regions."@en .


###  https://w3id.org/narn/rcc/EC
<https://w3id.org/narn/rcc/EC> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/location/borders> ,
                                                  <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               owl:propertyDisjointWith <https://w3id.org/narn/rcc/NTPP> ;
                               rdfs:comment "Denotes a relation where the boundaries of two regions intersect while their interiors remain disjoint."@en ;
                               rdfs:label "externally connected"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "touching regions"@en ;
                               <http://www.w3.org/2004/02/skos/core#example> "Brethil is externally connected to Doriath because their boundaries touch."@en .


###  https://w3id.org/narn/rcc/EQ
<https://w3id.org/narn/rcc/EQ> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/location/contains> ,
                                                  <https://w3id.org/narn/location/isAPartOf> ,
                                                  <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:TransitiveProperty ,
                                        owl:ReflexiveProperty ;
                               rdfs:comment "Represents spatial equivalence where two distinct entities occupy the exact identical spatial extent."@en ;
                               rdfs:label "equal"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "coextensive regions"@en ;
                               <http://www.w3.org/2004/02/skos/core#example> "The Thousand Caves and Menegroth are spatially equal entities."@en .


###  https://w3id.org/narn/rcc/NTPP
<https://w3id.org/narn/rcc/NTPP> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/location/isAPartOf> ,
                                                    <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:TransitiveProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:comment "Specifies a relation where the primary region is strictly contained within the interior of the secondary region with no shared boundary points."@en ;
                                 rdfs:label "non-tangential proper part"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "interior part"@en ;
                                 <http://www.w3.org/2004/02/skos/core#example> "Dor-lómin is a non-tangential proper part of Hithlum as it is completely enclosed."@en .


###  https://w3id.org/narn/rcc/NTPPi
<https://w3id.org/narn/rcc/NTPPi> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/location/contains> ,
                                                     <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                  owl:inverseOf <https://w3id.org/narn/rcc/NTPP> ;
                                  rdf:type owl:AsymmetricProperty ,
                                           owl:TransitiveProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:comment "The inverse relation where the primary region completely and strictly contains the secondary region within its interior."@en ;
                                  rdfs:label "non-tangential proper part inverse"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "interior whole"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "Hithlum is the non-tangential proper part inverse of Dor-lómin."@en .


###  https://w3id.org/narn/rcc/PO
<https://w3id.org/narn/rcc/PO> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                               rdf:type owl:SymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               rdfs:comment "Indicates that two regions share a common interior subset without either fully subsuming the other."@en ;
                               rdfs:label "partially overlapping"@en ;
                               <http://www.w3.org/2004/02/skos/core#altLabel> "overlapping regions"@en ;
                               <http://www.w3.org/2004/02/skos/core#example> "The wild lands partially overlap with Brethil."@en .


###  https://w3id.org/narn/rcc/TPP
<https://w3id.org/narn/rcc/TPP> rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf <https://w3id.org/narn/location/isAPartOf> ,
                                                   <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                rdf:type owl:AsymmetricProperty ,
                                         owl:IrreflexiveProperty ;
                                rdfs:comment "Defines a state where the primary region is entirely subsumed by the secondary region while sharing at least one boundary point."@en ;
                                rdfs:label "tangential proper part"@en ;
                                <http://www.w3.org/2004/02/skos/core#altLabel> "tangential part"@en ;
                                <http://www.w3.org/2004/02/skos/core#example> "Hithlum is a tangential proper part of Beleriand."@en .


###  https://w3id.org/narn/rcc/TPPi
<https://w3id.org/narn/rcc/TPPi> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/location/contains> ,
                                                    <https://w3id.org/narn/rcc/spatiallyRelatedTo> ;
                                 owl:inverseOf <https://w3id.org/narn/rcc/TPP> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:comment "The inverse relation where the primary region completely subsumes the secondary region while sharing boundary points."@en ;
                                 rdfs:label "tangential proper part inverse"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "tangential whole"@en ;
                                 <http://www.w3.org/2004/02/skos/core#example> "Beleriand represents the tangential proper part inverse of Hithlum."@en .


###  https://w3id.org/narn/rcc/spatiallyRelatedTo
<https://w3id.org/narn/rcc/spatiallyRelatedTo> rdf:type owl:ObjectProperty ,
                                                        owl:SymmetricProperty ;
                                               rdfs:domain <https://w3id.org/narn/location/Place> ;
                                               rdfs:range <https://w3id.org/narn/location/Place> ;
                                               rdfs:comment "The most general spatial relation between two regions."@en ;
                                               rdfs:label "spatially related to"@en ;
                                               <http://www.w3.org/2004/02/skos/core#altLabel> "spatial relation"@en ;
                                               <http://www.w3.org/2004/02/skos/core#example> "Doriath is spatially related to Brethil."@en .


###  https://w3id.org/narn/social/committedSuicide
<https://w3id.org/narn/social/committedSuicide> rdf:type owl:ObjectProperty ;
                                                rdfs:comment "Denotes the tragic act of a character intentionally taking their own life."@en ;
                                                rdfs:label "committed suicide"@en ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "took own life"@en ;
                                                <http://www.w3.org/2004/02/skos/core#example> "Túrin fell into despair and committed suicide with his sword Gurthang."@en .


###  https://w3id.org/narn/social/cursed
<https://w3id.org/narn/social/cursed> rdf:type owl:ObjectProperty ;
                                      rdfs:comment "Describes an act where a character invokes supernatural malevolence or a curse upon another."@en ;
                                      rdfs:label "cursed"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "placed a curse on"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Mîm sought revenge and cursed Andróg after the killing of Khîm."@en .


###  https://w3id.org/narn/social/feared
<https://w3id.org/narn/social/feared> rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf <https://w3id.org/narn/social/hasEmotionalRelationWith> ;
                                      rdfs:comment "Denotes a state of dread or apprehension regarding another character."@en ;
                                      rdfs:label "feared"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "had fear of"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Glaurung recognized the threat and feared Túrin."@en .


###  https://w3id.org/narn/social/hasEmotionalRelationWith
<https://w3id.org/narn/social/hasEmotionalRelationWith> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain owl:Thing ;
                                                        rdfs:range owl:Thing ;
                                                        rdfs:comment "Defines a broad emotional directedness or sentiment from one character toward another."@en ;
                                                        rdfs:label "has emotional relation with"@en ;
                                                        <http://www.w3.org/2004/02/skos/core#altLabel> "feels towards"@en ;
                                                        <http://www.w3.org/2004/02/skos/core#example> "Saeros holds a deep emotional relation rooted in hatred towards Túrin."@en .


###  https://w3id.org/narn/social/hasFriend
<https://w3id.org/narn/social/hasFriend> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://w3id.org/narn/social/hasEmotionalRelationWith> ;
                                         rdf:type owl:SymmetricProperty ,
                                                  owl:IrreflexiveProperty ;
                                         owl:propertyDisjointWith <https://w3id.org/narn/social/isAnEnemyOf> ;
                                         rdfs:comment "Represents a symmetric and mutual bond of friendship between two entities."@en ;
                                         rdfs:label "has friend"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "is a friend of"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Túrin maintains a mutual friendship and has friend Sador."@en .


###  https://w3id.org/narn/social/hasValence
<https://w3id.org/narn/social/hasValence> rdf:type owl:ObjectProperty ,
                                                   owl:FunctionalProperty ;
                                          rdfs:range <https://w3id.org/narn/social/EmotionalValence> ;
                                          rdfs:comment "Functionally assigns a specific emotional state or valence to a relational entity."@en ;
                                          rdfs:label "has valence"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "has sentiment"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Húrin acts functionally and has valence positive."@en .


###  https://w3id.org/narn/social/hated
<https://w3id.org/narn/social/hated> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://w3id.org/narn/social/hasEmotionalRelationWith> ;
                                     rdfs:comment "Indicates a profound sentiment of malice or hatred directed at another entity."@en ;
                                     rdfs:label "hated"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "had hatred for"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Saeros harbored intense resentment and hated Túrin."@en .


###  https://w3id.org/narn/social/hypnotised
<https://w3id.org/narn/social/hypnotised> rdf:type owl:ObjectProperty ;
                                          rdfs:comment "Indicates the act of subjecting another character to a mental spell or hypnotic enchantment."@en ;
                                          rdfs:label "hypnotised"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "cast a spell on"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Glaurung used his power and hypnotised Níniel."@en .


###  https://w3id.org/narn/social/isAKinsmanOf
<https://w3id.org/narn/social/isAKinsmanOf> rdf:type owl:ObjectProperty ,
                                                     owl:SymmetricProperty ;
                                            rdfs:comment "Represents a symmetric bond based on shared familial lineage or blood relation."@en ;
                                            rdfs:label "is a kinsman of"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "kin of"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Túrin shares a bloodline and is a kinsman of Nienor."@en .


###  https://w3id.org/narn/social/isAnEnemyOf
<https://w3id.org/narn/social/isAnEnemyOf> rdf:type owl:ObjectProperty ,
                                                    owl:SymmetricProperty ,
                                                    owl:IrreflexiveProperty ;
                                           owl:propertyDisjointWith <https://w3id.org/narn/social/wasServedBy> ;
                                           rdfs:comment "Defines a fundamentally antagonistic and hostile relationship."@en ;
                                           rdfs:label "is an enemy of"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "foe of"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Morgoth stands as a prime antagonist and is an enemy of Húrin."@en .


###  https://w3id.org/narn/social/isMarriedTo
<https://w3id.org/narn/social/isMarriedTo> rdf:type owl:ObjectProperty ,
                                                    owl:SymmetricProperty ,
                                                    owl:IrreflexiveProperty ;
                                           rdfs:comment "Denotes a formal and symmetric matrimonial relationship between two entities."@en ;
                                           rdfs:label "is married to"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "wed to"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Turambar formalized his bond and is married to Níniel."@en .


###  https://w3id.org/narn/social/killed
<https://w3id.org/narn/social/killed> rdf:type owl:ObjectProperty ,
                                               owl:AsymmetricProperty ,
                                               owl:IrreflexiveProperty ;
                                      owl:propertyDisjointWith <https://w3id.org/narn/social/served> ;
                                      rdfs:comment "Indicates a fatal action where the subject directly causes the death of the object."@en ;
                                      rdfs:label "killed"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "slew"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Túrin engaged in a fatal conflict and killed Saeros."@en .


###  https://w3id.org/narn/social/livedIn
<https://w3id.org/narn/social/livedIn> rdf:type owl:ObjectProperty ;
                                       rdfs:range <https://w3id.org/narn/location/Place> ;
                                       owl:propertyChainAxiom ( <https://w3id.org/narn/social/served>
                                                                <https://w3id.org/narn/social/wasTheKingOf>
                                                              ) ;
                                       rdfs:comment "Indicates a geographical location where a character resided for a significant duration."@en ;
                                       rdfs:label "lived in"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "dwelt in"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Túrin spent parts of his life and lived in Dor-lómin and Doriath."@en .


###  https://w3id.org/narn/social/loved
<https://w3id.org/narn/social/loved> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://w3id.org/narn/social/hasEmotionalRelationWith> ;
                                     rdfs:comment "Indicates a profound sentiment of affection or love directed at another entity."@en ;
                                     rdfs:label "loved"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "had love for"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Húrin held a deep affection and loved Morwen."@en .


###  https://w3id.org/narn/social/mutuallyLoved
<https://w3id.org/narn/social/mutuallyLoved> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://w3id.org/narn/social/loved> ;
                                             rdf:type owl:SymmetricProperty ;
                                             rdfs:comment "Describes a symmetric emotional state where two characters share reciprocal affection."@en ;
                                             rdfs:label "mutually loved"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "reciprocally loved"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "Turambar and Níniel shared a bond and mutually loved each other."@en .


###  https://w3id.org/narn/social/ruled
<https://w3id.org/narn/social/ruled> rdf:type owl:ObjectProperty ;
                                     owl:equivalentProperty <https://w3id.org/narn/social/wasTheKingOf> ;
                                     rdfs:comment "Functions as an equivalent property signifying sovereign rule over a domain."@en ;
                                     rdfs:label "ruled"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "governed"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Thingol governed and ruled Doriath."@en .


###  https://w3id.org/narn/social/served
<https://w3id.org/narn/social/served> rdf:type owl:ObjectProperty ,
                                               owl:AsymmetricProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:domain owl:Thing ;
                                      rdfs:range owl:Thing ;
                                      rdfs:comment "Indicates a hierarchical relationship where one character acts as a subordinate to another."@en ;
                                      rdfs:label "served"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "was in service of"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Sador was loyal and served Húrin."@en .


###  https://w3id.org/narn/social/wasHeldCaptiveIn
<https://w3id.org/narn/social/wasHeldCaptiveIn> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf <https://w3id.org/narn/social/livedIn> ;
                                                rdfs:range <https://w3id.org/narn/location/Place> ;
                                                rdfs:comment "Specifies a location where a character was forcibly imprisoned or contained."@en ;
                                                rdfs:label "was held captive in"@en ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "imprisoned in"@en ;
                                                <http://www.w3.org/2004/02/skos/core#example> "Húrin suffered greatly and was held captive in Angband."@en .


###  https://w3id.org/narn/social/wasKilledBy
<https://w3id.org/narn/social/wasKilledBy> rdf:type owl:ObjectProperty ;
                                           owl:inverseOf <https://w3id.org/narn/social/killed> ;
                                           rdfs:comment "The inverse relation specifying the perpetrator of a fatal action against the subject."@en ;
                                           rdfs:label "was killed by"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "slain by"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Beleg suffered a tragic fate and was killed by Gorthol."@en .


###  https://w3id.org/narn/social/wasServedBy
<https://w3id.org/narn/social/wasServedBy> rdf:type owl:ObjectProperty ;
                                           owl:inverseOf <https://w3id.org/narn/social/served> ;
                                           rdfs:comment "The inverse relation designating the superior who receives service."@en ;
                                           rdfs:label "was served by"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "had as servant"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Húrin held authority and was served by Sador."@en .


###  https://w3id.org/narn/social/wasTheBestFriendOf
<https://w3id.org/narn/social/wasTheBestFriendOf> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf <https://w3id.org/narn/social/hasFriend> ;
                                                  rdf:type owl:SymmetricProperty ;
                                                  rdfs:comment "Specifies an exceptionally close and prioritized bond of mutual friendship."@en ;
                                                  rdfs:label "was the best friend of"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "closest companion of"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#example> "Beleg proved his loyalty and was the best friend of Túrin."@en .


###  https://w3id.org/narn/social/wasTheChieftainOf
<https://w3id.org/narn/social/wasTheChieftainOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:range <https://w3id.org/narn/location/Place> ;
                                                 rdfs:comment "Specifies the domain or people over which a character exercised tribal leadership."@en ;
                                                 rdfs:label "was the chieftain of"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "led as chief"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#example> "Brandir guided his people and was the chieftain of Brethil."@en .


###  https://w3id.org/narn/social/wasTheKingOf
<https://w3id.org/narn/social/wasTheKingOf> rdf:type owl:ObjectProperty ,
                                                     owl:AsymmetricProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:range <https://w3id.org/narn/location/Place> ;
                                            rdfs:comment "Specifies the geographical or political domain over which a character held absolute royal authority."@en ;
                                            rdfs:label "was the king of"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "reigned over"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Thingol held supreme authority and was the king of Doriath."@en .


###  https://w3id.org/narn/to/after
<https://w3id.org/narn/to/after> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                 owl:inverseOf <https://w3id.org/narn/to/before> ;
                                 rdf:type owl:TransitiveProperty ;
                                 rdfs:comment "The primary interval commences strictly subsequent to the conclusion of the secondary interval."@en ;
                                 rdfs:label "after"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "follows"@en ;
                                 <http://www.w3.org/2004/02/skos/core#example> "The interval of Nienor's birth occurs strictly after the conclusion of the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/to/before
<https://w3id.org/narn/to/before> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ,
                                                     <https://w3id.org/narn/to/precedes> ;
                                  rdf:type owl:TransitiveProperty ;
                                  owl:propertyDisjointWith <https://w3id.org/narn/to/overlaps> ;
                                  rdfs:comment "The primary interval concludes strictly prior to the commencement of the secondary interval."@en ;
                                  rdfs:label "before"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "precedes"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The interval of Túrin's birth occurs strictly before the interval of Lalaith's birth."@en .


###  https://w3id.org/narn/to/containsInterval
<https://w3id.org/narn/to/containsInterval> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                            owl:inverseOf <https://w3id.org/narn/to/during> ;
                                            rdf:type owl:TransitiveProperty ;
                                            rdfs:comment "The primary interval strictly and completely encloses the chronological boundaries of the secondary interval."@en ;
                                            rdfs:label "contains interval"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "temporally contains"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn temporally contains the interval of Túrin's time in Doriath."@en .


###  https://w3id.org/narn/to/during
<https://w3id.org/narn/to/during> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                  rdf:type owl:TransitiveProperty ;
                                  rdfs:comment "The primary interval is strictly and completely enclosed within the chronological boundaries of the secondary interval."@en ;
                                  rdfs:label "during"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "contained in"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The interval representing the killing of Khîm occurs strictly during Túrin's habitation at Amon Rûdh."@en .


###  https://w3id.org/narn/to/endsAt
<https://w3id.org/narn/to/endsAt> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/hasInstant> ;
                                  rdf:type owl:FunctionalProperty ,
                                           owl:AsymmetricProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                  rdfs:range <https://w3id.org/narn/to/Instant> ;
                                  owl:propertyDisjointWith <https://w3id.org/narn/to/startsAt> ;
                                  rdfs:comment "The absolute ending instant bounding the conclusion of a temporal interval."@en ;
                                  rdfs:label "ends at"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "ending point"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears ends at the precise instant of the final retreat."@en .


###  https://w3id.org/narn/to/equals
<https://w3id.org/narn/to/equals> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                  rdf:type owl:SymmetricProperty ,
                                           owl:TransitiveProperty ,
                                           owl:ReflexiveProperty ;
                                  rdfs:comment "Absolute chronological equivalence where two intervals share identical starting and ending instants."@en ;
                                  rdfs:label "equals"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "same time as"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The temporal span of the Siege of Nargothrond equals the chronological span of the Fall of Nargothrond."@en .


###  https://w3id.org/narn/to/finishedBy
<https://w3id.org/narn/to/finishedBy> rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                      owl:inverseOf <https://w3id.org/narn/to/finishes> ;
                                      rdf:type owl:AsymmetricProperty ,
                                               owl:TransitiveProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:comment "Both intervals share identical ending instants while the primary interval commences strictly before the secondary interval begins."@en ;
                                      rdfs:label "finished by"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "ended by"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn is finished by the interval representing the death of Turambar."@en .


###  https://w3id.org/narn/to/finishes
<https://w3id.org/narn/to/finishes> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                    rdf:type owl:AsymmetricProperty ,
                                             owl:TransitiveProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:comment "Both intervals share identical ending instants while the primary interval commences strictly after the secondary interval begins."@en ;
                                    rdfs:label "finishes"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "ends with"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The interval representing the death of Turambar finishes the overarching timeline of the Narn."@en .


###  https://w3id.org/narn/to/hasInstant
<https://w3id.org/narn/to/hasInstant> rdf:type owl:ObjectProperty ,
                                               owl:AsymmetricProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                      rdfs:range <https://w3id.org/narn/to/Instant> ;
                                      rdfs:comment "The association between a temporal interval and a specific instant contained within or bounding it."@en ;
                                      rdfs:label "has instant"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "at instant"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn has an instant mapped to the moment of Túrin's birth."@en .


###  https://w3id.org/narn/to/intervalRelation
<https://w3id.org/narn/to/intervalRelation> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                            rdfs:range <https://w3id.org/narn/to/Interval> ;
                                            rdfs:comment "A topological temporal relation between two distinct intervals."@en ;
                                            rdfs:label "interval relation"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "Allen relation"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "The relational mapping between the birth of Túrin and the birth of Lalaith constitutes an interval relation."@en .


###  https://w3id.org/narn/to/meets
<https://w3id.org/narn/to/meets> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ,
                                                    <https://w3id.org/narn/to/precedes> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 owl:propertyDisjointWith <https://w3id.org/narn/to/overlaps> ;
                                 rdfs:comment "The ending instant of the primary interval is chronologically identical to the starting instant of the secondary interval."@en ;
                                 rdfs:label "meets"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "immediately before"@en ;
                                 <http://www.w3.org/2004/02/skos/core#example> "The chronological span of the Nirnaeth Arnoediad meets the interval of Húrin's captivity without any intervening gap."@en .


###  https://w3id.org/narn/to/metBy
<https://w3id.org/narn/to/metBy> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                 owl:inverseOf <https://w3id.org/narn/to/meets> ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:comment "The starting instant of the primary interval is chronologically identical to the ending instant of the secondary interval."@en ;
                                 rdfs:label "met by"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "immediately after"@en ;
                                 <http://www.w3.org/2004/02/skos/core#example> "The interval of Húrin's captivity is met by the conclusion of the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/to/occursAfter
<https://w3id.org/narn/to/occursAfter> rdf:type owl:ObjectProperty ;
                                       owl:inverseOf <https://w3id.org/narn/to/occursBefore> ;
                                       rdf:type owl:TransitiveProperty ;
                                       rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                       rdfs:range <https://w3id.org/narn/to/Instant> ;
                                       rdfs:comment "A temporal relation placing the first instant chronologically subsequent to the second."@en ;
                                       rdfs:label "occurs after"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "later than"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The moment of Nienor's birth occurs after the moment of Lalaith's birth."@en .


###  https://w3id.org/narn/to/occursBefore
<https://w3id.org/narn/to/occursBefore> rdf:type owl:ObjectProperty ,
                                                 owl:TransitiveProperty ;
                                        rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                        rdfs:range <https://w3id.org/narn/to/Instant> ;
                                        owl:propertyDisjointWith <https://w3id.org/narn/to/occursSimultaneouslyTo> ;
                                        rdfs:comment "A temporal relation placing the first instant chronologically prior to the second."@en ;
                                        rdfs:label "occurs before"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "earlier than"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The moment of Túrin's birth occurs before the moment of Lalaith's birth."@en .


###  https://w3id.org/narn/to/occursDuring
<https://w3id.org/narn/to/occursDuring> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                        rdfs:range <https://w3id.org/narn/to/Interval> ;
                                        rdfs:comment "The enclosure of a specific instant strictly within the temporal boundaries of an interval."@en ;
                                        rdfs:label "occurs during"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "within timeframe of"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The precise moment of Khîm's death occurs during the interval of Túrin's habitation at Amon Rûdh."@en .


###  https://w3id.org/narn/to/occursSimultaneouslyTo
<https://w3id.org/narn/to/occursSimultaneouslyTo> rdf:type owl:ObjectProperty ,
                                                           owl:SymmetricProperty ,
                                                           owl:TransitiveProperty ,
                                                           owl:ReflexiveProperty ;
                                                  rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                                  rdfs:range <https://w3id.org/narn/to/Instant> ;
                                                  rdfs:comment "A temporal relation linking two distinct instants that occupy the exact same chronological position."@en ;
                                                  rdfs:label "occurs simultaneously to"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "at same time as"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#example> "Two separate observations mapping to the exact same chronological instant occur simultaneously."@en .


###  https://w3id.org/narn/to/overlappedBy
<https://w3id.org/narn/to/overlappedBy> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                        owl:inverseOf <https://w3id.org/narn/to/overlaps> ;
                                        rdf:type owl:AsymmetricProperty ,
                                                 owl:IrreflexiveProperty ;
                                        rdfs:comment "The primary interval begins strictly within the duration of the secondary interval and concludes after it."@en ;
                                        rdfs:label "overlapped by"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "partially after"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Túrin's time at Amon Rûdh is overlapped by the preceding interval of his time among the outlaws."@en .


###  https://w3id.org/narn/to/overlaps
<https://w3id.org/narn/to/overlaps> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                    rdf:type owl:AsymmetricProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:comment "The primary interval begins before the secondary interval and concludes strictly within its duration."@en ;
                                    rdfs:label "overlaps"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "partially before"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The interval of Túrin's time among the outlaws overlaps with the beginning of his time at Amon Rûdh."@en .


###  https://w3id.org/narn/to/precededBy
<https://w3id.org/narn/to/precededBy> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <https://w3id.org/narn/to/precedes> ;
                                      rdf:type owl:TransitiveProperty ;
                                      rdfs:comment "The primary interval commences either strictly subsequent to or exactly at the conclusion of the secondary interval."@en ;
                                      rdfs:label "preceded by"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "happens after"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Túrin's journey to Doriath is temporally preceded by the span of the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/to/precedes
<https://w3id.org/narn/to/precedes> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                    rdf:type owl:TransitiveProperty ;
                                    rdfs:comment "The primary interval concludes either strictly prior to or exactly at the commencement of the secondary interval."@en ;
                                    rdfs:label "precedes"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "happens before"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The span of the Nirnaeth Arnoediad temporally precedes Túrin's journey to Doriath."@en .


###  https://w3id.org/narn/to/startedBy
<https://w3id.org/narn/to/startedBy> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                     owl:inverseOf <https://w3id.org/narn/to/starts> ;
                                     rdf:type owl:AsymmetricProperty ,
                                              owl:TransitiveProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:comment "Both intervals share identical starting instants while the primary interval extends strictly beyond the conclusion of the secondary interval."@en ;
                                     rdfs:label "started by"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "begun by"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn is started by the interval representing the birth of Túrin."@en .


###  https://w3id.org/narn/to/starts
<https://w3id.org/narn/to/starts> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <https://w3id.org/narn/to/intervalRelation> ;
                                  rdf:type owl:AsymmetricProperty ,
                                           owl:TransitiveProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:comment "Both intervals share identical starting instants while the primary interval concludes strictly before the secondary interval."@en ;
                                  rdfs:label "starts"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "begins with"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The interval representing the birth of Túrin starts the overarching timeline of the Narn."@en .


###  https://w3id.org/narn/to/startsAt
<https://w3id.org/narn/to/startsAt> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf <https://w3id.org/narn/to/hasInstant> ;
                                    rdf:type owl:FunctionalProperty ,
                                             owl:AsymmetricProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                    rdfs:range <https://w3id.org/narn/to/Instant> ;
                                    rdfs:comment "The absolute starting instant bounding the beginning of a temporal interval."@en ;
                                    rdfs:label "starts at"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "beginning point"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The chronological span of the Narn starts at the moment of Túrin's birth."@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/narn/plot/publishedDate
<https://w3id.org/narn/plot/publishedDate> rdf:type owl:DatatypeProperty ,
                                                    owl:FunctionalProperty ;
                                           rdfs:domain <https://w3id.org/narn/plot/Story> ;
                                           rdfs:range xsd:date ;
                                           rdfs:comment "The date the story was published."@en ;
                                           rdfs:label "published date"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "date published"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "The Narn was published on 2007-04-17."@en .


###  https://w3id.org/narn/plot/unitIndex
<https://w3id.org/narn/plot/unitIndex> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://w3id.org/narn/plot/NarrativeUnit> ;
                                       rdfs:range xsd:positiveInteger ;
                                       rdfs:comment "The ordering position of a unit within its parent."@en ;
                                       rdfs:label "unit index"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "sequence number"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Part I has unit index 1."@en .


###  https://w3id.org/narn/to/hasDateTime
<https://w3id.org/narn/to/hasDateTime> rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://w3id.org/narn/to/Instant> ;
                                       rdfs:range xsd:dateTime ;
                                       rdfs:comment "The standardized chronological date and time value of a specific temporal instant."@en ;
                                       rdfs:label "has date time"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "dateTime value"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The instant of publication maps to a specific dateTime value in the standard calendar."@en .


###  https://w3id.org/narn/to/hasDuration
<https://w3id.org/narn/to/hasDuration> rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain <https://w3id.org/narn/to/Interval> ;
                                       rdfs:range xsd:duration ;
                                       rdfs:comment "The absolute temporal length spanned by a defined interval."@en ;
                                       rdfs:label "has duration"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "time length"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The interval representing Túrin's time in Doriath has a duration measured in several years."@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/narn/action/Action
<https://w3id.org/narn/action/Action> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/Event> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/action/performedBy> ;
                                                        owl:someValuesFrom owl:Thing
                                                      ] ;
                                      rdfs:comment "An intentional deed. Every action has at least one performer."@en ;
                                      rdfs:label "action"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "deed"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Túrin killing Saeros is an action performed by Túrin."@en .


###  https://w3id.org/narn/action/Attack
<https://w3id.org/narn/action/Attack> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/action/ViolentAction> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                        owl:someValuesFrom owl:Thing
                                                      ] ;
                                      owl:disjointWith <https://w3id.org/narn/action/Defend> ;
                                      rdfs:comment "An aggressive action aimed at harming a target."@en ;
                                      rdfs:label "attack"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "assault"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Túrin attacks the Orcs at Amon Rûdh using Anglachel."@en .


###  https://w3id.org/narn/action/Build
<https://w3id.org/narn/action/Build> rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/CreationAction>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/creates> ;
                                                                                  owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf <https://w3id.org/narn/action/CreationAction> ;
                                     owl:disjointWith <https://w3id.org/narn/action/Forge> ;
                                     rdfs:comment "The action of constructing a structure or settlement."@en ;
                                     rdfs:label "build"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "construction"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The Elves built the hidden city of Gondolin in Tumladen."@en .


###  https://w3id.org/narn/action/Command
<https://w3id.org/narn/action/Command> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ;
                                       rdfs:comment "The action of giving an authoritative order."@en ;
                                       rdfs:label "command"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "order"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Morgoth orders his servants to attack Nargothrond."@en .


###  https://w3id.org/narn/action/CommunicativeAction
<https://w3id.org/narn/action/CommunicativeAction> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/narn/action/Action> ,
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                                     owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                         owl:complementOf <https://w3id.org/narn/location/Place>
                                                                                       ]
                                                                   ] ;
                                                   owl:disjointWith <https://w3id.org/narn/action/MovementAction> ,
                                                                    <https://w3id.org/narn/action/TransferAction> ,
                                                                    <https://w3id.org/narn/action/ViolentAction> ;
                                                   rdfs:comment "An action involving communication between characters."@en ;
                                                   rdfs:label "communicative action"@en ;
                                                   <http://www.w3.org/2004/02/skos/core#altLabel> "speech act"@en ;
                                                   <http://www.w3.org/2004/02/skos/core#example> "Turambar speaks to Túrin about his journey."@en .


###  https://w3id.org/narn/action/CreationAction
<https://w3id.org/narn/action/CreationAction> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/action/Action> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://w3id.org/narn/event/creates> ;
                                                                owl:someValuesFrom owl:Thing
                                                              ] ;
                                              owl:disjointWith <https://w3id.org/narn/action/TransferAction> ;
                                              rdfs:comment "An action that produces or transforms something."@en ;
                                              rdfs:label "creation action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "making"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "The smiths of Nargothrond reforge Anglachel into Gurthang."@en .


###  https://w3id.org/narn/action/Deceive
<https://w3id.org/narn/action/Deceive> rdf:type owl:Class ;
                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/CommunicativeAction>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <https://w3id.org/narn/action/hasIntention> ;
                                                                                    owl:someValuesFrom <https://w3id.org/narn/action/MisleadingIntention>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ;
                                       rdfs:comment "The action of intentionally misleading another character."@en ;
                                       rdfs:label "deceive"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "deception"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Glaurung deceives and hypnotises Níniel at Nargothrond."@en .


###  https://w3id.org/narn/action/Defend
<https://w3id.org/narn/action/Defend> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/action/ViolentAction> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                        owl:someValuesFrom owl:Thing
                                                      ] ;
                                      rdfs:comment "An action of protecting oneself or others from attack."@en ;
                                      rdfs:label "defend"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "defence"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Beleg defends Túrin's camp from Orc raids."@en .


###  https://w3id.org/narn/action/Escape
<https://w3id.org/narn/action/Escape> rdf:type owl:Class ;
                                      rdfs:comment "The intention of getting away from danger."@en ;
                                      rdfs:label "escape"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "evasion"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Túrin's intention when fleeing Doriath is escape from judgement."@en .


###  https://w3id.org/narn/action/Flee
<https://w3id.org/narn/action/Flee> rdf:type owl:Class ;
                                    owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/MovementAction>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://w3id.org/narn/action/hasIntention> ;
                                                                                 owl:someValuesFrom <https://w3id.org/narn/action/Escape>
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/MovementAction> ;
                                    rdfs:comment "The action of running away from danger or pursuit."@en ;
                                    rdfs:label "flee"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "flight"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Túrin flees Doriath after killing Saeros."@en .


###  https://w3id.org/narn/action/Forge
<https://w3id.org/narn/action/Forge> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/action/CreationAction> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/creates> ;
                                                       owl:someValuesFrom owl:Thing
                                                     ] ;
                                     rdfs:comment "The action of creating or reshaping an object, especially a weapon."@en ;
                                     rdfs:label "forge"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "smithing"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The reforging of Anglachel into Gurthang in Nargothrond."@en .


###  https://w3id.org/narn/action/Give
<https://w3id.org/narn/action/Give> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/TransferAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasRecipient> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasInstrument> ;
                                                      owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                    ] ;
                                    owl:disjointWith <https://w3id.org/narn/action/Take> ;
                                    rdfs:comment "The action of voluntarily transferring something to another."@en ;
                                    rdfs:label "give"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "bestowal"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Beleg gives Anglachel to Túrin to rescue him."@en .


###  https://w3id.org/narn/action/GoTo
<https://w3id.org/narn/action/GoTo> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/MovementAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ;
                                    rdfs:comment "The action of deliberately travelling to a destination."@en ;
                                    rdfs:label "go to"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "travel to"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Túrin goes to Nargothrond seeking refuge."@en .


###  https://w3id.org/narn/action/Kill
<https://w3id.org/narn/action/Kill> rdf:type owl:Class ;
                                    owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/ViolentAction>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://w3id.org/narn/action/hasResult> ;
                                                                                 owl:someValuesFrom <https://w3id.org/narn/event/Death>
                                                                               ]
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/ViolentAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasResult> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/event/Death>
                                                    ] ;
                                    rdfs:comment "The action of causing the death of another."@en ;
                                    rdfs:label "kill"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "slaying"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Túrin kills Saeros in Doriath."@en .


###  https://w3id.org/narn/action/MisleadingIntention
<https://w3id.org/narn/action/MisleadingIntention> rdf:type owl:Class ;
                                                   rdfs:comment "The intention of making another believe something false."@en ;
                                                   rdfs:label "misleading intention"@en ;
                                                   <http://www.w3.org/2004/02/skos/core#altLabel> "intent to deceive"@en ;
                                                   <http://www.w3.org/2004/02/skos/core#example> "Glaurung's intention when hypnotising Níniel is to mislead her about her identity."@en .


###  https://w3id.org/narn/action/MovementAction
<https://w3id.org/narn/action/MovementAction> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/action/Action> ,
                                                              <https://w3id.org/narn/event/MovementEvent> ;
                                              owl:disjointWith <https://w3id.org/narn/action/ViolentAction> ;
                                              rdfs:comment "An action involving deliberate physical movement."@en ;
                                              rdfs:label "movement action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "locomotion"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Túrin travels to Nargothrond after the death of Beleg."@en .


###  https://w3id.org/narn/action/Reveal
<https://w3id.org/narn/action/Reveal> rdf:type owl:Class ;
                                      owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/action/CommunicativeAction>
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <https://w3id.org/narn/action/hasResult> ;
                                                                                   owl:someValuesFrom <https://w3id.org/narn/event/Discovery>
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] ;
                                      rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ;
                                      rdfs:comment "The action of disclosing previously hidden information."@en ;
                                      rdfs:label "reveal"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "disclosure"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "The truth about Níniel is revealed after the slaying of Glaurung."@en .


###  https://w3id.org/narn/action/Speak
<https://w3id.org/narn/action/Speak> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/action/CommunicativeAction> ;
                                     rdfs:comment "The action of verbal communication."@en ;
                                     rdfs:label "speak"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "utterance"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Brandir speaks the truth to Turambar about Níniel's identity."@en .


###  https://w3id.org/narn/action/Take
<https://w3id.org/narn/action/Take> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/action/TransferAction> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/action/hasTarget> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ;
                                    rdfs:comment "The action of acquiring something, possibly by force."@en ;
                                    rdfs:label "take"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "seizure"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Morgoth takes Húrin captive after the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/action/TransferAction
<https://w3id.org/narn/action/TransferAction> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/action/Action> ;
                                              rdfs:comment "An action involving the transfer of possession."@en ;
                                              rdfs:label "transfer action"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "transfer"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Beleg brings Anglachel to Túrin."@en .


###  https://w3id.org/narn/action/ViolentAction
<https://w3id.org/narn/action/ViolentAction> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/narn/action/Action> ;
                                             rdfs:comment "An action involving physical violence or force."@en ;
                                             rdfs:label "violent action"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "violent deed"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "The Slaying of Glaurung is a violent action performed by Turambar."@en .


###  https://w3id.org/narn/event/Battle
<https://w3id.org/narn/event/Battle> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ;
                                     rdfs:comment "A large scale violent confrontation."@en ;
                                     rdfs:label "battle"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "armed conflict"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad is the Battle of Unnumbered Tears."@en .


###  https://w3id.org/narn/event/Betrayal
<https://w3id.org/narn/event/Betrayal> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                       owl:disjointWith <https://w3id.org/narn/event/Meeting> ;
                                       rdfs:comment "An act of disloyalty involving betrayal of trust."@en ;
                                       rdfs:label "betrayal"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "treachery"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Mîm betrays Túrin to the Orcs at Amon Rûdh."@en .


###  https://w3id.org/narn/event/Birth
<https://w3id.org/narn/event/Birth> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/LifeEvent> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/begets> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/occursAt> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ;
                                    owl:disjointWith <https://w3id.org/narn/event/Death> ,
                                                     <https://w3id.org/narn/event/Marriage> ,
                                                     <https://w3id.org/narn/event/Murder> ;
                                    rdfs:comment "The coming into existence of a character."@en ;
                                    rdfs:label "birth"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "nativity"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The birth of Túrin takes place in Dor-lómin."@en .


###  https://w3id.org/narn/event/Captivity
<https://w3id.org/narn/event/Captivity> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "An event in which a character is held as a prisoner."@en ;
                                        rdfs:label "captivity"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "imprisonment"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The captivity of Húrin in Angband by Morgoth."@en .


###  https://w3id.org/narn/event/ConflictEvent
<https://w3id.org/narn/event/ConflictEvent> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                            owl:disjointWith <https://w3id.org/narn/event/MovementEvent> ,
                                                             <https://w3id.org/narn/event/SocialEvent> ;
                                            rdfs:comment "An event characterised by antagonism or violence."@en ;
                                            rdfs:label "conflict event"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "clash"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad is a conflict event in Beleriand."@en .


###  https://w3id.org/narn/event/Coronation
<https://w3id.org/narn/event/Coronation> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                                         ] ;
                                         rdfs:comment "A ceremony of crowning a ruler."@en ;
                                         rdfs:label "coronation"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "crowning ceremony"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Turgon is crowned King of Gondolin."@en .


###  https://w3id.org/narn/event/Council
<https://w3id.org/narn/event/Council> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                      rdfs:comment "A formal meeting for deliberation or the reaching of a consensus."@en ;
                                      rdfs:label "council"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "deliberation"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "A council of the Elves in Nargothrond."@en .


###  https://w3id.org/narn/event/Curse
<https://w3id.org/narn/event/Curse> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                    owl:disjointWith <https://w3id.org/narn/event/Prophecy> ;
                                    rdfs:comment "A supernatural imprecation bringing misfortune."@en ;
                                    rdfs:label "curse"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "malediction"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Mîm curses Andróg after the killing of Khîm."@en .


###  https://w3id.org/narn/event/Death
<https://w3id.org/narn/event/Death> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/LifeEvent> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/hasVictim> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ;
                                    rdfs:comment "The death of a character."@en ;
                                    rdfs:label "death"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "demise"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The death of Beleg is caused by Túrin."@en .


###  https://w3id.org/narn/event/Discovery
<https://w3id.org/narn/event/Discovery> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "An event where something hidden is found or revealed."@en ;
                                        rdfs:label "discovery"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "revelation"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The truth about Níniel's identity is revealed."@en .


###  https://w3id.org/narn/event/Duel
<https://w3id.org/narn/event/Duel> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/event/hasParticipant> ;
                                                     owl:cardinality "2"^^xsd:nonNegativeInteger
                                                   ] ;
                                   rdfs:comment "A fight between exactly two combatants."@en ;
                                   rdfs:label "duel"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "single combat"@en ;
                                   <http://www.w3.org/2004/02/skos/core#example> "The duel between Turambar and Glaurung at Cabed-en-Aras."@en .


###  https://w3id.org/narn/event/Enchantment
<https://w3id.org/narn/event/Enchantment> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                          rdfs:comment "A magical effect imposed on a character."@en ;
                                          rdfs:label "enchantment"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "spell"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Glaurung hypnotises Níniel at Nargothrond."@en .


###  https://w3id.org/narn/event/Event
<https://w3id.org/narn/event/Event> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/to/FiniteInterval> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/hasParticipant> ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/occursAt> ;
                                                      owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ;
                                    rdfs:comment "A spatio-temporal occurrence involving participants and locations. Every event is a finite temporal interval."@en ;
                                    rdfs:label "event"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "occurrence"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears is an event occurring in Beleriand."@en .


###  https://w3id.org/narn/event/Exile
<https://w3id.org/narn/event/Exile> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/MovementEvent> ;
                                    rdfs:comment "A forced departure from the homeland."@en ;
                                    rdfs:label "exile"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "banishment"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The exile of Túrin from Doriath after the death of Saeros."@en .


###  https://w3id.org/narn/event/Feast
<https://w3id.org/narn/event/Feast> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                    rdfs:comment "A large celebratory meal or banquet."@en ;
                                    rdfs:label "feast"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "banquet"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "A feast held in the halls of Menegroth."@en .


###  https://w3id.org/narn/event/Flight
<https://w3id.org/narn/event/Flight> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/MovementEvent> ;
                                     rdfs:comment "An event in which characters flee from danger."@en ;
                                     rdfs:label "flight"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "escape"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The flight of survivors from the fall of Nargothrond."@en .


###  https://w3id.org/narn/event/LifeEvent
<https://w3id.org/narn/event/LifeEvent> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                        rdfs:comment "A significant moment in a character's life."@en ;
                                        rdfs:label "life event"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "life occurrence"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The birth of Túrin in Dor-lómin is a life event."@en .


###  https://w3id.org/narn/event/Marriage
<https://w3id.org/narn/event/Marriage> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/event/LifeEvent> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://w3id.org/narn/event/hasParticipant> ;
                                                         owl:cardinality "2"^^xsd:nonNegativeInteger
                                                       ] ;
                                       rdfs:comment "A formal union between two characters."@en ;
                                       rdfs:label "marriage"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "wedding"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The marriage of Turambar and Níniel in Brethil."@en .


###  https://w3id.org/narn/event/Meeting
<https://w3id.org/narn/event/Meeting> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                      rdfs:comment "An encounter or gathering of characters."@en ;
                                      rdfs:label "meeting"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "encounter"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Túrin meets Beleg in the wild."@en .


###  https://w3id.org/narn/event/MovementEvent
<https://w3id.org/narn/event/MovementEvent> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                            rdfs:comment "An event involving physical movement of characters between places."@en ;
                                            rdfs:label "movement event"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "movement"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Túrin travels from Dor-lómin to Doriath."@en .


###  https://w3id.org/narn/event/Murder
<https://w3id.org/narn/event/Murder> rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/event/Death>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                                                  owl:someValuesFrom owl:Thing
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/Death> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                       owl:someValuesFrom owl:Thing
                                                     ] ;
                                     owl:disjointWith <https://w3id.org/narn/event/Suicide> ;
                                     rdfs:comment "A death caused intentionally by another."@en ;
                                     rdfs:label "murder"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "homicide"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The death of Saeros is caused by Túrin."@en .


###  https://w3id.org/narn/event/Prophecy
<https://w3id.org/narn/event/Prophecy> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                       rdfs:comment "A prediction of future events, often supernatural."@en ;
                                       rdfs:label "prophecy"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "foretelling"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Morgoth's doom: thou shalt see with my eyes."@en .


###  https://w3id.org/narn/event/Siege
<https://w3id.org/narn/event/Siege> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/event/occursAt> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/location/Settlement>
                                                    ] ;
                                    rdfs:comment "A military blockade of a city or fortress."@en ;
                                    rdfs:label "siege"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "blockade"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The siege and sack of Nargothrond."@en .


###  https://w3id.org/narn/event/SocialEvent
<https://w3id.org/narn/event/SocialEvent> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/event/Event> ;
                                          rdfs:comment "An event involving social interaction between characters."@en ;
                                          rdfs:label "social event"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "social gathering"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The trial of Túrin in absence at Menegroth."@en .


###  https://w3id.org/narn/event/Suicide
<https://w3id.org/narn/event/Suicide> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/event/Death> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/event/hasVictim> ;
                                                        owl:cardinality "1"^^xsd:nonNegativeInteger
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/event/hasAgent> ;
                                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                      ] ;
                                      rdfs:comment "A form of death in which the agent and the victim are identical."@en ;
                                      rdfs:label "suicide"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "self-destruction"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Turambar dies by falling on his own sword Gurthang."@en .


###  https://w3id.org/narn/event/Travel
<https://w3id.org/narn/event/Travel> rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/event/MovementEvent>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/hasDestination> ;
                                                                                  owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://w3id.org/narn/event/hasOrigin> ;
                                                                                  owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf <https://w3id.org/narn/event/MovementEvent> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/hasDestination> ;
                                                       owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <https://w3id.org/narn/event/hasOrigin> ;
                                                       owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                     ] ;
                                     rdfs:comment "A journey. Every travel has origin and destination."@en ;
                                     rdfs:label "travel"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "journey"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Túrin travels from Dor-lómin to Doriath."@en .


###  https://w3id.org/narn/event/Trial
<https://w3id.org/narn/event/Trial> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/event/SocialEvent> ;
                                    rdfs:comment "A judicial examination or hearing."@en ;
                                    rdfs:label "trial"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "judgement"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The trial of Túrin in absence, where Nellas testifies."@en .


###  https://w3id.org/narn/event/War
<https://w3id.org/narn/event/War> rdf:type owl:Class ;
                                  owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/event/ConflictEvent>
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty <https://w3id.org/narn/event/hasSubEvent> ;
                                                                               owl:someValuesFrom <https://w3id.org/narn/event/Battle>
                                                                             ]
                                                                           ) ;
                                                        rdf:type owl:Class
                                                      ] ;
                                  rdfs:subClassOf <https://w3id.org/narn/event/ConflictEvent> ;
                                  rdfs:comment "A prolonged conflict composed of multiple battles."@en ;
                                  rdfs:label "war"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "prolonged conflict"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The Wars of Beleriand include the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/location/Building
<https://w3id.org/narn/location/Building> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                          owl:disjointWith <https://w3id.org/narn/location/NaturalArea> ;
                                          rdfs:comment "A constructed structure."@en ;
                                          rdfs:label "building"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "structure"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The great hall of Menegroth is a building within the city."@en .


###  https://w3id.org/narn/location/City
<https://w3id.org/narn/location/City> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                      owl:disjointWith <https://w3id.org/narn/location/Village> ;
                                      rdfs:comment "A large and significant settlement."@en ;
                                      rdfs:label "city"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "urban area"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Gondolin is a hidden city in Tumladen."@en .


###  https://w3id.org/narn/location/Continent
<https://w3id.org/narn/location/Continent> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/location/LandArea> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://w3id.org/narn/location/isAPartOf> ;
                                                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                 owl:complementOf <https://w3id.org/narn/location/LandArea>
                                                                               ]
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty [ owl:inverseOf <https://w3id.org/narn/location/isTheCapitalOf>
                                                                            ] ;
                                                             owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                             owl:onClass <https://w3id.org/narn/location/Settlement>
                                                           ] ;
                                           rdfs:comment "A major landmass."@en ;
                                           rdfs:label "continent"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "landmass"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Endor is a continent within Arda."@en .


###  https://w3id.org/narn/location/Desert
<https://w3id.org/narn/location/Desert> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                        owl:disjointWith <https://w3id.org/narn/location/Forest> ;
                                        rdfs:comment "A barren, arid area with little vegetation."@en ;
                                        rdfs:label "desert"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "wasteland"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The Anfauglith is a desert north of Beleriand."@en .


###  https://w3id.org/narn/location/Forest
<https://w3id.org/narn/location/Forest> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/WoodedArea> ;
                                        rdfs:comment "A large, dense wooded area."@en ;
                                        rdfs:label "forest"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "wood"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Brethil is a forest where Túrin lived under the name Turambar."@en .


###  https://w3id.org/narn/location/Fortress
<https://w3id.org/narn/location/Fortress> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                          rdfs:comment "A fortified place, typically a military stronghold."@en ;
                                          rdfs:label "fortress"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "stronghold"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Angband is Morgoth's fortress in the Iron Mountains."@en .


###  https://w3id.org/narn/location/Hill
<https://w3id.org/narn/location/Hill> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                      rdfs:comment "A naturally raised area of land, smaller than a mountain."@en ;
                                      rdfs:label "hill"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "hillock"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Amon Rûdh is a hill where Túrin hid with Mîm."@en .


###  https://w3id.org/narn/location/Lake
<https://w3id.org/narn/location/Lake> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                      rdfs:comment "A large body of water surrounded by land."@en ;
                                      rdfs:label "lake"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "body of water"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "There is a lake near the hidden city of Gondolin."@en .


###  https://w3id.org/narn/location/LandArea
<https://w3id.org/narn/location/LandArea> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                          rdfs:comment "A place that is primarily defined by its land territory."@en ;
                                          rdfs:label "land area"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "land"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Dor-lómin is a land area in Hithlum."@en .


###  https://w3id.org/narn/location/Mountain
<https://w3id.org/narn/location/Mountain> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                          owl:disjointWith <https://w3id.org/narn/location/River> ,
                                                           <https://w3id.org/narn/location/Sea> ;
                                          rdfs:comment "A large natural elevation of the earth's surface."@en ;
                                          rdfs:label "mountain"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "peak"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Ered Wethrin borders Hithlum."@en .


###  https://w3id.org/narn/location/NaturalArea
<https://w3id.org/narn/location/NaturalArea> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                             owl:disjointWith <https://w3id.org/narn/location/Settlement> ;
                                             rdfs:comment "A place defined by natural geographic features rather than habitation."@en ;
                                             rdfs:label "natural area"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "natural feature"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "Brethil is a natural area east of Doriath."@en .


###  https://w3id.org/narn/location/Place
<https://w3id.org/narn/location/Place> rdf:type owl:Class ;
                                       rdfs:comment "A named location that has geographic or spatial significance in a story."@en ;
                                       rdfs:label "place"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "location"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Beleriand is a place in Middle-earth."@en .


###  https://w3id.org/narn/location/Realm
<https://w3id.org/narn/location/Realm> rdf:type owl:Class ;
                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/location/LandArea>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty [ owl:inverseOf <https://w3id.org/narn/location/isTheCapitalOf>
                                                                                                   ] ;
                                                                                    owl:someValuesFrom <https://w3id.org/narn/location/Settlement>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://w3id.org/narn/location/LandArea> ;
                                       rdfs:comment "A territory under the rule of a king or sovereign authority."@en ;
                                       rdfs:label "realm"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "kingdom"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Doriath is a realm ruled by King Thingol, with Menegroth as its capital."@en .


###  https://w3id.org/narn/location/Region
<https://w3id.org/narn/location/Region> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                        rdfs:comment "A large geographic area, typically contains multiple subplaces."@en ;
                                        rdfs:label "region"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "area"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Beleriand is a region containing Doriath, Hithlum, and Brethil."@en .


###  https://w3id.org/narn/location/River
<https://w3id.org/narn/location/River> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                       rdfs:comment "A large natural stream of water."@en ;
                                       rdfs:label "river"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "waterway"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The river Narog flows near Nargothrond."@en .


###  https://w3id.org/narn/location/Sea
<https://w3id.org/narn/location/Sea> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                     rdfs:comment "A large body of salt water."@en ;
                                     rdfs:label "sea"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "ocean"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Belegaer is the Great Sea west of Middle-earth."@en .


###  https://w3id.org/narn/location/Settlement
<https://w3id.org/narn/location/Settlement> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/location/Place> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://w3id.org/narn/location/isAPartOf> ;
                                                              owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                            ] ;
                                            rdfs:comment "A place where people live permanently."@en ;
                                            rdfs:label "settlement"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "inhabited place"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Menegroth is a settlement within Doriath."@en .


###  https://w3id.org/narn/location/Town
<https://w3id.org/narn/location/Town> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                      owl:disjointWith <https://w3id.org/narn/location/Village> ;
                                      rdfs:comment "A settlement larger than a village but smaller than a city."@en ;
                                      rdfs:label "town"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "township"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "There is a town along the road between Doriath and Nargothrond."@en .


###  https://w3id.org/narn/location/UndergroundCity
<https://w3id.org/narn/location/UndergroundCity> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/location/City>
                                                                                            <https://w3id.org/narn/location/UndergroundPlace>
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "A city built underground, within caves or excavated halls."@en ;
                                                 rdfs:label "underground city"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "subterranean city"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#example> "Menegroth is an underground city, the capital of Doriath."@en .


###  https://w3id.org/narn/location/UndergroundPlace
<https://w3id.org/narn/location/UndergroundPlace> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://w3id.org/narn/location/Place> ;
                                                  rdfs:comment "A place located beneath the surface of the earth."@en ;
                                                  rdfs:label "underground place"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "subterranean place"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#example> "Menegroth and Nargothrond are underground places."@en .


###  https://w3id.org/narn/location/Valley
<https://w3id.org/narn/location/Valley> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                        rdfs:comment "A low area of land between hills or mountains."@en ;
                                        rdfs:label "valley"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "vale"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Tumladen is the valley where Gondolin was built."@en .


###  https://w3id.org/narn/location/Village
<https://w3id.org/narn/location/Village> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/location/Settlement> ;
                                         rdfs:comment "A small settlement, typically in a rural area."@en ;
                                         rdfs:label "village"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "hamlet"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "There is a small village in Brethil where woodsmen live."@en .


###  https://w3id.org/narn/location/WildArea
<https://w3id.org/narn/location/WildArea> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                          rdfs:comment "An uncultivated, uninhabited region."@en ;
                                          rdfs:label "wild area"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "wilderness"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The wild lands between Doriath and Nargothrond."@en .


###  https://w3id.org/narn/location/WoodedArea
<https://w3id.org/narn/location/WoodedArea> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/location/NaturalArea> ;
                                            rdfs:comment "A land area predominantly covered by trees."@en ;
                                            rdfs:label "wooded area"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "woodland"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Brethil is a wooded area in Beleriand."@en .


###  https://w3id.org/narn/plot/Act
<https://w3id.org/narn/plot/Act> rdf:type owl:Class ;
                                 rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ;
                                 rdfs:comment "A major division in drama or narrative, often five in classical structure."@en ;
                                 rdfs:label "act"@en ;
                                 <http://www.w3.org/2004/02/skos/core#altLabel> "story act"@en ;
                                 <http://www.w3.org/2004/02/skos/core#example> "Act III of a five act tragedy."@en .


###  https://w3id.org/narn/plot/Anagnorisis
<https://w3id.org/narn/plot/Anagnorisis> rdf:type owl:Class ;
                                         owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/plot/PlotDevice>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <https://w3id.org/narn/plot/correspondsToEvent> ;
                                                                                      owl:someValuesFrom <https://w3id.org/narn/event/Discovery>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                         rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                         rdfs:comment "A moment where a character makes a critical discovery about an identity or situation."@en ;
                                         rdfs:label "anagnorisis"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "moment of recognition"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Níniel discovers she is Nienor, sister of Túrin."@en .


###  https://w3id.org/narn/plot/Antagonist
<https://w3id.org/narn/plot/Antagonist> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                        owl:disjointWith <https://w3id.org/narn/plot/Protagonist> ;
                                        rdfs:comment "The character who opposes the protagonist."@en ;
                                        rdfs:label "antagonist"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "villain"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Glaurung is the antagonist who opposes Túrin."@en .


###  https://w3id.org/narn/plot/Chapter
<https://w3id.org/narn/plot/Chapter> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ;
                                     rdfs:comment "A numbered or titled section of a narrative."@en ;
                                     rdfs:label "chapter"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "story chapter"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "Túrin in Dor-lómin is a chapter in the Narn."@en .


###  https://w3id.org/narn/plot/CharacterRole
<https://w3id.org/narn/plot/CharacterRole> rdf:type owl:Class ;
                                           rdfs:comment "The narrative function a character plays in the story."@en ;
                                           rdfs:label "character role"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "story role"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Túrin has the role of Protagonist and Tragic Hero."@en .


###  https://w3id.org/narn/plot/Climax
<https://w3id.org/narn/plot/Climax> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                    owl:disjointWith <https://w3id.org/narn/plot/Exposition> ,
                                                     <https://w3id.org/narn/plot/Resolution> ;
                                    rdfs:comment "The turning point; the moment of highest tension."@en ;
                                    rdfs:label "climax"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "turning point"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The slaying of Glaurung and the truth about Níniel revealed."@en .


###  https://w3id.org/narn/plot/Conflict
<https://w3id.org/narn/plot/Conflict> rdf:type owl:Class ;
                                      owl:disjointWith <https://w3id.org/narn/plot/Genre> ;
                                      rdfs:comment "A struggle between opposing forces driving the plot."@en ;
                                      rdfs:label "conflict"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "tension"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Morgoth's curse against Húrin's family is a central conflict."@en .


###  https://w3id.org/narn/plot/Denouement
<https://w3id.org/narn/plot/Denouement> rdf:type owl:Class ;
                                        owl:equivalentClass <https://w3id.org/narn/plot/Resolution> ;
                                        rdfs:comment "The final unravelling of the plot."@en ;
                                        rdfs:label "denouement"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "final outcome"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Both Níniel and Turambar perish in the denouement of the Narn."@en .


###  https://w3id.org/narn/plot/DramaticIrony
<https://w3id.org/narn/plot/DramaticIrony> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                           rdfs:comment "When the audience knows more than the characters."@en ;
                                           rdfs:label "dramatic irony"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "audience knowledge gap"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "The audience knows Túrin's identity while others do not."@en .


###  https://w3id.org/narn/plot/Epic
<https://w3id.org/narn/plot/Epic> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://w3id.org/narn/plot/Genre> ;
                                  rdfs:comment "A long narrative involving heroic deeds and grand scale."@en ;
                                  rdfs:label "epic"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "epic genre"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "The Narn is an epic spanning wars, exiles, and dragon slaying."@en .


###  https://w3id.org/narn/plot/Exposition
<https://w3id.org/narn/plot/Exposition> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                        owl:disjointWith <https://w3id.org/narn/plot/Resolution> ;
                                        rdfs:comment "Introduction of setting, characters, and background."@en ;
                                        rdfs:label "exposition"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "setup"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Húrin's family and the curse of Morgoth."@en .


###  https://w3id.org/narn/plot/ExternalConflict
<https://w3id.org/narn/plot/ExternalConflict> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/plot/Conflict> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://w3id.org/narn/plot/conflictInvolves> ;
                                                                owl:minCardinality "2"^^xsd:nonNegativeInteger
                                                              ] ;
                                              owl:disjointWith <https://w3id.org/narn/plot/InternalConflict> ;
                                              rdfs:comment "Conflict between a character and an external force such as an antagonist, nature, or society."@en ;
                                              rdfs:label "external conflict"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "outer struggle"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Morgoth's curse against Húrin's family involves Morgoth and Húrin."@en .


###  https://w3id.org/narn/plot/FallingAction
<https://w3id.org/narn/plot/FallingAction> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                           owl:disjointWith <https://w3id.org/narn/plot/RisingAction> ;
                                           rdfs:comment "Events after the climax leading to the resolution."@en ;
                                           rdfs:label "falling action"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "unwinding"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "The aftermath of the revelation and the deaths that follow."@en .


###  https://w3id.org/narn/plot/Fantasy
<https://w3id.org/narn/plot/Fantasy> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/plot/Genre> ;
                                     rdfs:comment "A story with magical or supernatural elements."@en ;
                                     rdfs:label "fantasy"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "fantasy genre"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The Narn is a fantasy with dragons, curses, and enchantments."@en .


###  https://w3id.org/narn/plot/Flashback
<https://w3id.org/narn/plot/Flashback> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                       rdfs:comment "A scene set in a time earlier than the main story."@en ;
                                       rdfs:label "flashback"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "retrospection"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Húrin's memories of his family before the war."@en .


###  https://w3id.org/narn/plot/Foreshadowing
<https://w3id.org/narn/plot/Foreshadowing> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://w3id.org/narn/plot/foreshadowsEvent> ;
                                                             owl:allValuesFrom <https://w3id.org/narn/event/Event>
                                                           ] ;
                                           rdfs:comment "Hints or clues about future events in the story."@en ;
                                           rdfs:label "foreshadowing"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "hint of future events"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Morgoth's curse foreshadows all the tragedies that befall Húrin's children."@en .


###  https://w3id.org/narn/plot/Genre
<https://w3id.org/narn/plot/Genre> rdf:type owl:Class ;
                                   rdfs:comment "A category of narrative with shared conventions."@en ;
                                   rdfs:label "genre"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "literary genre"@en ;
                                   <http://www.w3.org/2004/02/skos/core#example> "The Narn fits into genres like Tragedy and Epic."@en .


###  https://w3id.org/narn/plot/IncitingIncident
<https://w3id.org/narn/plot/IncitingIncident> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                              owl:disjointWith <https://w3id.org/narn/plot/Resolution> ;
                                              rdfs:comment "The event that sets the main conflict in motion."@en ;
                                              rdfs:label "inciting incident"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "catalyst"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Túrin is sent to Doriath, setting his wanderings in motion."@en .


###  https://w3id.org/narn/plot/InternalConflict
<https://w3id.org/narn/plot/InternalConflict> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/narn/plot/Conflict> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://w3id.org/narn/plot/conflictInvolves> ;
                                                                owl:cardinality "1"^^xsd:nonNegativeInteger
                                                              ] ;
                                              rdfs:comment "Conflict within a character such as a moral dilemma or fear."@en ;
                                              rdfs:label "internal conflict"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "inner struggle"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "Túrin's struggle against fate and his own pride."@en .


###  https://w3id.org/narn/plot/MacGuffin
<https://w3id.org/narn/plot/MacGuffin> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                       rdfs:comment "An object or goal that motivates the plot but has no intrinsic importance."@en ;
                                       rdfs:label "MacGuffin"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "plot motivator"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "The Dragon-helm marks Túrin's identity wherever he goes."@en .


###  https://w3id.org/narn/plot/Mentor
<https://w3id.org/narn/plot/Mentor> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                    rdfs:comment "A character who guides or teaches the protagonist."@en ;
                                    rdfs:label "mentor"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "guide figure"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Beleg serves as mentor to the young Túrin."@en .


###  https://w3id.org/narn/plot/NarrativeElement
<https://w3id.org/narn/plot/NarrativeElement> rdf:type owl:Class ;
                                              owl:disjointWith <https://w3id.org/narn/plot/PlotDevice> ;
                                              rdfs:comment "A stage in the narrative arc."@en ;
                                              rdfs:label "narrative element"@en ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "story element"@en ;
                                              <http://www.w3.org/2004/02/skos/core#example> "The Climax of the Narn is a narrative element."@en .


###  https://w3id.org/narn/plot/NarrativeUnit
<https://w3id.org/narn/plot/NarrativeUnit> rdf:type owl:Class ;
                                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://w3id.org/narn/plot/containsUnit> ;
                                                             owl:allValuesFrom <https://w3id.org/narn/plot/NarrativeUnit>
                                                           ] ;
                                           rdfs:comment "A structural division of a story."@en ;
                                           rdfs:label "narrative unit"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "story division"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "Part I: The Childhood of Túrin is a narrative unit."@en .


###  https://w3id.org/narn/plot/Part
<https://w3id.org/narn/plot/Part> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <https://w3id.org/narn/plot/containsUnit> ;
                                                    owl:someValuesFrom <https://w3id.org/narn/plot/Chapter>
                                                  ] ;
                                  rdfs:comment "A major division of a story containing chapters."@en ;
                                  rdfs:label "part"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "story part"@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "Part III: Túrin in Nargothrond and Brethil is a major story part."@en .


###  https://w3id.org/narn/plot/Peripeteia
<https://w3id.org/narn/plot/Peripeteia> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                        rdfs:comment "A sudden reversal of fortune or change in circumstances."@en ;
                                        rdfs:label "peripeteia"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "reversal of fortune"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Turambar's triumph over Glaurung turns to ruin when the truth is revealed."@en .


###  https://w3id.org/narn/plot/PlotDevice
<https://w3id.org/narn/plot/PlotDevice> rdf:type owl:Class ;
                                        rdfs:comment "A technique used to advance or structure the plot."@en ;
                                        rdfs:label "plot device"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "narrative device"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Dramatic irony is a plot device used throughout the Narn."@en .


###  https://w3id.org/narn/plot/PlotTwist
<https://w3id.org/narn/plot/PlotTwist> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/narn/plot/PlotDevice> ;
                                       rdfs:comment "An unexpected revelation that changes the story's direction."@en ;
                                       rdfs:label "plot twist"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "unexpected turn"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Níniel's true identity as Nienor, sister of Túrin."@en .


###  https://w3id.org/narn/plot/Protagonist
<https://w3id.org/narn/plot/Protagonist> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                         rdfs:comment "The main character; the one driving the action."@en ;
                                         rdfs:label "protagonist"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "main character"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Túrin is the protagonist of the Narn."@en .


###  https://w3id.org/narn/plot/Resolution
<https://w3id.org/narn/plot/Resolution> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                        rdfs:comment "The outcome; how the conflict is resolved."@en ;
                                        rdfs:label "resolution"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "conclusion"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "The deaths of Níniel and Turambar resolve the Narn."@en .


###  https://w3id.org/narn/plot/RisingAction
<https://w3id.org/narn/plot/RisingAction> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeElement> ;
                                          rdfs:comment "Series of events building tension toward the climax."@en ;
                                          rdfs:label "rising action"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "complication"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Túrin's wanderings and tragedies such as the death of his father, his exile, and battles."@en .


###  https://w3id.org/narn/plot/Scene
<https://w3id.org/narn/plot/Scene> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/narn/plot/NarrativeUnit> ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/plot/containsUnit> ;
                                                     owl:allValuesFrom owl:Nothing
                                                   ] ;
                                   rdfs:comment "The smallest narrative unit; a continuous action in one setting."@en ;
                                   rdfs:label "scene"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "story scene"@en ;
                                   <http://www.w3.org/2004/02/skos/core#example> "The scene where Túrin accidentally kills Beleg."@en .


###  https://w3id.org/narn/plot/Story
<https://w3id.org/narn/plot/Story> rdf:type owl:Class ;
                                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/plot/hasNarrativeElement> ;
                                                     owl:someValuesFrom <https://w3id.org/narn/plot/Climax>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/plot/hasNarrativeElement> ;
                                                     owl:someValuesFrom <https://w3id.org/narn/plot/Resolution>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/narn/plot/hasNarrativeUnit> ;
                                                     owl:someValuesFrom <https://w3id.org/narn/plot/NarrativeUnit>
                                                   ] ;
                                   rdfs:comment "A complete narrative work."@en ;
                                   rdfs:label "story"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "narrative"@en ;
                                   <http://www.w3.org/2004/02/skos/core#example> "The Narn i Chîn Húrin is a story by J.R.R. Tolkien."@en .


###  https://w3id.org/narn/plot/Tragedy
<https://w3id.org/narn/plot/Tragedy> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/narn/plot/Genre> ;
                                     rdfs:comment "A story where the protagonist suffers a downfall."@en ;
                                     rdfs:label "tragedy"@en ;
                                     <http://www.w3.org/2004/02/skos/core#altLabel> "tragic genre"@en ;
                                     <http://www.w3.org/2004/02/skos/core#example> "The Narn is a tragedy: Túrin and Nienor both perish."@en .


###  https://w3id.org/narn/plot/TragicHero
<https://w3id.org/narn/plot/TragicHero> rdf:type owl:Class ;
                                        owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/plot/Protagonist>
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <https://w3id.org/narn/plot/involvedInDevice> ;
                                                                                     owl:someValuesFrom <https://w3id.org/narn/plot/Peripeteia>
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ] ;
                                        rdfs:subClassOf <https://w3id.org/narn/plot/CharacterRole> ;
                                        rdfs:comment "A protagonist whose flaw leads to their downfall."@en ;
                                        rdfs:label "tragic hero"@en ;
                                        <http://www.w3.org/2004/02/skos/core#altLabel> "tragic protagonist"@en ;
                                        <http://www.w3.org/2004/02/skos/core#example> "Túrin is a tragic hero whose pride leads to his downfall."@en .


###  https://w3id.org/narn/social/Ally
<https://w3id.org/narn/social/Ally> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/social/SocialRole> ;
                                    owl:disjointWith <https://w3id.org/narn/social/Outlaw> ;
                                    rdfs:comment "Represents an individual united with others in a formal or informal alliance."@en ;
                                    rdfs:label "ally"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "companion"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Beleg stands as a steadfast ally to Túrin."@en .


###  https://w3id.org/narn/social/Chieftain
<https://w3id.org/narn/social/Chieftain> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/narn/social/PoliticalRole> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://w3id.org/narn/social/wasTheChieftainOf> ;
                                                           owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                         ] ;
                                         rdfs:comment "Denotes the principal leader or head of a specific people or tribal group."@en ;
                                         rdfs:label "chieftain"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "chief"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "Brandir acts as the chieftain leading the people of Brethil."@en .


###  https://w3id.org/narn/social/EmotionalValence
<https://w3id.org/narn/social/EmotionalValence> rdf:type owl:Class ;
                                                owl:equivalentClass [ rdf:type owl:Class ;
                                                                      owl:oneOf ( <https://w3id.org/narn/social/ambivalent>
                                                                                  <https://w3id.org/narn/social/negative>
                                                                                  <https://w3id.org/narn/social/positive>
                                                                                )
                                                                    ] ;
                                                rdfs:comment "Defines a classification of emotional sentiments comprising positive negative or ambivalent states."@en ;
                                                rdfs:label "emotional valence"@en ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "sentiment type"@en ;
                                                <http://www.w3.org/2004/02/skos/core#example> "Húrin possesses a positive valence whereas Glaurung possesses a negative valence."@en .


###  https://w3id.org/narn/social/King
<https://w3id.org/narn/social/King> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/social/PoliticalRole> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/social/wasTheKingOf> ;
                                                      owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/social/wasServedBy> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/social/Servant>
                                                    ] ;
                                    owl:disjointWith <https://w3id.org/narn/social/Servant> ;
                                    rdfs:comment "Designates the supreme sovereign or monarch of a defined realm or kingdom."@en ;
                                    rdfs:label "king"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "monarch"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "Thingol serves as the King governing the realm of Doriath."@en .


###  https://w3id.org/narn/social/Leader
<https://w3id.org/narn/social/Leader> rdf:type owl:Class ;
                                      owl:equivalentClass [ rdf:type owl:Class ;
                                                            owl:unionOf ( <https://w3id.org/narn/social/Chieftain>
                                                                          <https://w3id.org/narn/social/King>
                                                                        )
                                                          ] ;
                                      rdfs:comment "A general classification encompassing sovereign figures such as a King or a Chieftain."@en ;
                                      rdfs:label "leader"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "ruler"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Figures such as King Thingol and Chieftain Brandir act as leaders."@en .


###  https://w3id.org/narn/social/MilitaryRole
<https://w3id.org/narn/social/MilitaryRole> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/social/SocialRole> ;
                                            rdfs:comment "A social role structurally related to military leadership or combat functions."@en ;
                                            rdfs:label "military role"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "military position"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Serving as a captain or general in the armies of Beleriand represents a military role."@en .


###  https://w3id.org/narn/social/NonLeader
<https://w3id.org/narn/social/NonLeader> rdf:type owl:Class ;
                                         owl:equivalentClass [ rdf:type owl:Class ;
                                                               owl:complementOf <https://w3id.org/narn/social/Leader>
                                                             ] ;
                                         rdfs:comment "Categorizes individuals who hold no sovereign or primary leadership authority."@en ;
                                         rdfs:label "non-leader"@en ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "non-ruler"@en ;
                                         <http://www.w3.org/2004/02/skos/core#example> "A servant like Sador is classified as a non-leader."@en .


###  https://w3id.org/narn/social/Outlaw
<https://w3id.org/narn/social/Outlaw> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/narn/social/SocialRole> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://w3id.org/narn/social/isAnEnemyOf> ;
                                                        owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                      ] ;
                                      rdfs:comment "Classifies an individual existing outside the protection and constraints of organized legal structures."@en ;
                                      rdfs:label "outlaw"@en ;
                                      <http://www.w3.org/2004/02/skos/core#altLabel> "fugitive"@en ;
                                      <http://www.w3.org/2004/02/skos/core#example> "Forweg and Andróg operate as outlaws in the wild lands."@en .


###  https://w3id.org/narn/social/PoliticalRole
<https://w3id.org/narn/social/PoliticalRole> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/narn/social/SocialRole> ;
                                             rdfs:comment "A specific social role involving governance or formal political authority."@en ;
                                             rdfs:label "political role"@en ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "political position"@en ;
                                             <http://www.w3.org/2004/02/skos/core#example> "The positions of King and Chieftain serve as political roles."@en .


###  https://w3id.org/narn/social/PositiveRelation
<https://w3id.org/narn/social/PositiveRelation> rdf:type owl:Class ;
                                                owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <https://w3id.org/narn/social/hasValence> ;
                                                                      owl:hasValue <https://w3id.org/narn/social/positive>
                                                                    ] ;
                                                rdfs:comment "Denotes a relational bond characterized by a strictly positive emotional valence."@en ;
                                                rdfs:label "positive relation"@en ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "positive bond"@en ;
                                                <http://www.w3.org/2004/02/skos/core#example> "Húrin maintains a positive relation due to his affirmative emotional valence."@en .


###  https://w3id.org/narn/social/RoyalServant
<https://w3id.org/narn/social/RoyalServant> rdf:type owl:Class ;
                                            owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/social/Servant>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://w3id.org/narn/social/served> ;
                                                                                         owl:someValuesFrom <https://w3id.org/narn/social/King>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                            rdfs:comment "Designates a servant specifically sworn to the service of a royal monarch."@en ;
                                            rdfs:label "royal servant"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "royal attendant"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "Beleg qualifies as a royal servant by virtue of serving King Thingol."@en .


###  https://w3id.org/narn/social/Servant
<https://w3id.org/narn/social/Servant> rdf:type owl:Class ;
                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/social/SocialRole>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <https://w3id.org/narn/social/served> ;
                                                                                    owl:someValuesFrom owl:Thing
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://w3id.org/narn/social/SocialRole> ;
                                       rdfs:comment "Identifies an individual bound to the service and assistance of another figure."@en ;
                                       rdfs:label "servant"@en ;
                                       <http://www.w3.org/2004/02/skos/core#altLabel> "attendant"@en ;
                                       <http://www.w3.org/2004/02/skos/core#example> "Sador operates as a servant in the household of Húrin."@en .


###  https://w3id.org/narn/social/SocialRole
<https://w3id.org/narn/social/SocialRole> rdf:type owl:Class ;
                                          rdfs:comment "A defined structural position that a character occupies within a social context."@en ;
                                          rdfs:label "social role"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "role"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "Thingol occupies the social role of a King."@en .


###  https://w3id.org/narn/social/SuicidalCharacter
<https://w3id.org/narn/social/SuicidalCharacter> rdf:type owl:Class ;
                                                 owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <https://w3id.org/narn/social/committedSuicide> ;
                                                                       owl:hasSelf "true"^^xsd:boolean
                                                                     ] ;
                                                 rdfs:comment "Identifies a narrative figure who intentionally caused their own death."@en ;
                                                 rdfs:label "suicidal character"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "self slain character"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#example> "Both Túrin and Níniel are categorized as suicidal characters."@en .


###  https://w3id.org/narn/to/EndingInterval
<https://w3id.org/narn/to/EndingInterval> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/narn/to/Interval> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://w3id.org/narn/to/endsAt> ;
                                                            owl:someValuesFrom <https://w3id.org/narn/to/Instant>
                                                          ] ;
                                          rdfs:comment "An interval bounded by a distinct ending instant but lacking a defined starting point."@en ;
                                          rdfs:label "ending interval"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "ending point"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "A historical epoch stretching back indefinitely but concluding at a specific catastrophe represents an ending interval."@en .


###  https://w3id.org/narn/to/EternalInterval
<https://w3id.org/narn/to/EternalInterval> rdf:type owl:Class ;
                                           owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/to/InfiniteInterval>
                                                                                      [ rdf:type owl:Class ;
                                                                                        owl:complementOf <https://w3id.org/narn/to/EndingInterval>
                                                                                      ]
                                                                                      [ rdf:type owl:Class ;
                                                                                        owl:complementOf <https://w3id.org/narn/to/StartingInterval>
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ;
                                           rdfs:subClassOf <https://w3id.org/narn/to/InfiniteInterval> ;
                                           owl:disjointWith <https://w3id.org/narn/to/FiniteInterval> ;
                                           rdfs:comment "A temporally unbounded interval extending infinitely into both the past and the future."@en ;
                                           rdfs:label "eternal interval"@en ;
                                           <http://www.w3.org/2004/02/skos/core#altLabel> "everlasting interval"@en ;
                                           <http://www.w3.org/2004/02/skos/core#example> "The continuous existence of the universe Eä serves as an eternal interval."@en .


###  https://w3id.org/narn/to/FiniteInterval
<https://w3id.org/narn/to/FiniteInterval> rdf:type owl:Class ;
                                          owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/to/Interval>
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <https://w3id.org/narn/to/endsAt> ;
                                                                                       owl:someValuesFrom <https://w3id.org/narn/to/Instant>
                                                                                     ]
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <https://w3id.org/narn/to/startsAt> ;
                                                                                       owl:someValuesFrom <https://w3id.org/narn/to/Instant>
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ] ;
                                          rdfs:subClassOf <https://w3id.org/narn/to/EndingInterval> ,
                                                          <https://w3id.org/narn/to/Interval> ,
                                                          <https://w3id.org/narn/to/StartingInterval> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://w3id.org/narn/to/startsAt> ;
                                                            owl:allValuesFrom <https://w3id.org/narn/to/Instant>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://w3id.org/narn/to/endsAt> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass <https://w3id.org/narn/to/Instant>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://w3id.org/narn/to/startsAt> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass <https://w3id.org/narn/to/Instant>
                                                          ] ;
                                          owl:disjointWith <https://w3id.org/narn/to/InfiniteInterval> ;
                                          rdfs:comment "A bounded temporal interval defined by both a distinct starting instant and a distinct ending instant."@en ;
                                          rdfs:label "finite interval"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "bounded interval"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears constitutes a finite interval possessing defined chronological boundaries."@en .


###  https://w3id.org/narn/to/InfiniteInterval
<https://w3id.org/narn/to/InfiniteInterval> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/narn/to/Interval> ;
                                            rdfs:comment "A temporal interval extending infinitely in at least one direction."@en ;
                                            rdfs:label "infinite interval"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "unbounded interval"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "The lifespan of an immortal Elf represents an infinite interval extending continuously into the future."@en .


###  https://w3id.org/narn/to/Instant
<https://w3id.org/narn/to/Instant> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/narn/to/TemporalEntity> ;
                                   owl:disjointWith <https://w3id.org/narn/to/Interval> ;
                                   rdfs:comment "A temporal entity representing a single point in time with a duration of strictly zero."@en ;
                                   rdfs:label "instant"@en ;
                                   <http://www.w3.org/2004/02/skos/core#altLabel> "time point"@en ;
                                   <http://www.w3.org/2004/02/skos/core#example> "The precise moment of Túrin's birth constitutes an instant."@en .


###  https://w3id.org/narn/to/Interval
<https://w3id.org/narn/to/Interval> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://w3id.org/narn/to/TemporalEntity> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <https://w3id.org/narn/to/hasInstant> ;
                                                      owl:allValuesFrom <https://w3id.org/narn/to/Instant>
                                                    ] ;
                                    rdfs:comment "A continuous temporal entity characterized by a strictly positive duration."@en ;
                                    rdfs:label "interval"@en ;
                                    <http://www.w3.org/2004/02/skos/core#altLabel> "time span"@en ;
                                    <http://www.w3.org/2004/02/skos/core#example> "The complete timeline of the Narn represents a temporal interval."@en .


###  https://w3id.org/narn/to/StartingInterval
<https://w3id.org/narn/to/StartingInterval> rdf:type owl:Class ;
                                            owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/narn/to/Interval>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://w3id.org/narn/to/startsAt> ;
                                                                                         owl:someValuesFrom <https://w3id.org/narn/to/Instant>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                            rdfs:subClassOf <https://w3id.org/narn/to/Interval> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://w3id.org/narn/to/startsAt> ;
                                                              owl:someValuesFrom <https://w3id.org/narn/to/Instant>
                                                            ] ;
                                            rdfs:comment "An interval bounded by a distinct starting instant but lacking a defined ending point."@en ;
                                            rdfs:label "starting interval"@en ;
                                            <http://www.w3.org/2004/02/skos/core#altLabel> "begins with"@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "The life of an Elf exemplifies a starting interval since it begins at birth but possesses no natural conclusion."@en .


###  https://w3id.org/narn/to/TemporalEntity
<https://w3id.org/narn/to/TemporalEntity> rdf:type owl:Class ;
                                          rdfs:comment "An entity existing within a specific temporal dimension."@en ;
                                          rdfs:label "temporal entity"@en ;
                                          <http://www.w3.org/2004/02/skos/core#altLabel> "time entity"@en ;
                                          <http://www.w3.org/2004/02/skos/core#example> "The moment of Túrin's birth and the span of his life represent temporal entities."@en .


