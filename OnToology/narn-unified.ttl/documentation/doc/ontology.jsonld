  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Morgoth's curse foreshadows the death of Turambar."
  } ]
}, {
  "@id" : "https://w3id.org/narn/plot/hasAuthor",
