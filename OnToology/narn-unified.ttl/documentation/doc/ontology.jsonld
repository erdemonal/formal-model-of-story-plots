    "@language" : "en",
    "@value" : "negative"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "negative sentiment"
  } ]
}, {
  "@id" : "https://w3id.org/narn/social/positive",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Represents a constructive and affirmative emotional state."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "positive"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "positive sentiment"
  } ]
}, {
  "@id" : "https://w3id.org/narn/social/ruled",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Functions as an equivalent property signifying sovereign rule over a domain."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ruled"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentProperty" : [ {
    "@id" : "https://w3id.org/narn/social/wasTheKingOf"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "governed"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Thingol governed and ruled Doriath."
  } ]
}, {
  "@id" : "https://w3id.org/narn/social/served",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#AsymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicates a hierarchical relationship where one character acts as a subordinate to another."
