  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "The Narn has author J.R.R. Tolkien."
  } ]
}, {
  "@id" : "https://w3id.org/narn/plot/hasConflict",
