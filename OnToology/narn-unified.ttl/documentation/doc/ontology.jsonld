  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/narn/plot/NarrativeUnit"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "comes after"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Part II follows Part I in the Narn."
  } ]
}, {
  "@id" : "https://w3id.org/narn/plot/foreshadowsEvent",
