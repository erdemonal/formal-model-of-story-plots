    //
    // General axioms
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointProperties"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/DC"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/EC"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/EQ"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/NTPP"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/NTPPi"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/PO"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/TPP"/>
            <rdf:Description rdf:about="https://w3id.org/narn/rcc/TPPi"/>
        </owl:members>
    </rdf:Description>
</rdf:RDF>



