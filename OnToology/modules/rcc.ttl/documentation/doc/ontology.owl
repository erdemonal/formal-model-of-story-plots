     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="https://purl.org/vocab/vann/"
     xmlns:terms="https://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/narn/rcc/">
        <owl:imports rdf:resource="https://w3id.org/narn/location/"/>
        <rdfs:comment xml:lang="en">An OWL encoding of the Region Connection Calculus.</rdfs:comment>
        <rdfs:label xml:lang="en">RCC Ontology</rdfs:label>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-13</terms:created>
        <terms:creator rdf:resource="https://w3id.org/people/erdemonal/me"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-17</terms:modified>
        <vann:preferredNamespacePrefix>rcc</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/narn/rcc/</vann:preferredNamespaceUri>
    </owl:Ontology>
    


