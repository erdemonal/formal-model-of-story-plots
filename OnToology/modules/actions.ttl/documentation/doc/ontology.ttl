@prefix : <https://w3id.org/narn/action/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/narn/action/> .

<https://w3id.org/narn/action/> rdf:type owl:Ontology ;
                                 owl:imports <https://w3id.org/narn/event/> ,
                                             <https://w3id.org/narn/location/> ;
                                 rdfs:comment "An ontology for describing actions in story plots."@en ;
                                 rdfs:label "Actions Ontology"@en ;
                                 <https://purl.org/dc/terms/created> "2026-03-11"^^xsd:date ;
                                 <https://purl.org/dc/terms/creator> <https://w3id.org/people/erdemonal/me> ;
                                 <https://purl.org/dc/terms/modified> "2026-03-19"^^xsd:date ;
                                 <https://purl.org/vocab/vann/preferredNamespacePrefix> "act" ;
                                 <https://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/narn/action/" .

