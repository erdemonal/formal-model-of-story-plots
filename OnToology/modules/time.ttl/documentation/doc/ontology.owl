<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/narn/to/"
     xml:base="https://w3id.org/narn/to/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="https://purl.org/vocab/vann/"
     xmlns:terms="https://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/narn/to/">
        <rdfs:comment xml:lang="en">A formal ontology defining temporal entities and the relations of Allen interval algebra.</rdfs:comment>
        <rdfs:label xml:lang="en">Temporal Ontology</rdfs:label>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-13</terms:created>
        <terms:creator rdf:resource="https://w3id.org/people/erdemonal/me"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-19</terms:modified>
        <vann:preferredNamespacePrefix>to</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/narn/to/</vann:preferredNamespaceUri>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#example -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#example"/>
    


    <!-- https://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="https://purl.org/dc/terms/created"/>
    


    <!-- https://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="https://purl.org/dc/terms/creator"/>
    


    <!-- https://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="https://purl.org/dc/terms/modified"/>
    


    <!-- https://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="https://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- https://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="https://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#duration -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#duration"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/narn/to/after -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/after">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/before"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval commences strictly subsequent to the conclusion of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">after</rdfs:label>
        <skos:altLabel xml:lang="en">follows</skos:altLabel>
        <skos:example xml:lang="en">The interval of Nienor&apos;s birth occurs strictly after the conclusion of the Nirnaeth Arnoediad.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/before -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/before">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/precedes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <owl:propertyDisjointWith rdf:resource="https://w3id.org/narn/to/overlaps"/>
        <rdfs:comment xml:lang="en">The primary interval concludes strictly prior to the commencement of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">before</rdfs:label>
        <skos:altLabel xml:lang="en">precedes</skos:altLabel>
        <skos:example xml:lang="en">The interval of Túrin&apos;s birth occurs strictly before the interval of Lalaith&apos;s birth.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/containsInterval -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/containsInterval">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/during"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval strictly and completely encloses the chronological boundaries of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">contains interval</rdfs:label>
        <skos:altLabel xml:lang="en">temporally contains</skos:altLabel>
        <skos:example xml:lang="en">The overarching timeline of the Narn temporally contains the interval of Túrin&apos;s time in Doriath.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/during -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/during">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval is strictly and completely enclosed within the chronological boundaries of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">during</rdfs:label>
        <skos:altLabel xml:lang="en">contained in</skos:altLabel>
        <skos:example xml:lang="en">The interval representing the killing of Khîm occurs strictly during Túrin&apos;s habitation at Amon Rûdh.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/endsAt -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/endsAt">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/hasInstant"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Interval"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Instant"/>
        <owl:propertyDisjointWith rdf:resource="https://w3id.org/narn/to/startsAt"/>
        <rdfs:comment xml:lang="en">The absolute ending instant bounding the conclusion of a temporal interval.</rdfs:comment>
        <rdfs:label xml:lang="en">ends at</rdfs:label>
        <skos:altLabel xml:lang="en">ending point</skos:altLabel>
        <skos:example xml:lang="en">The Battle of Unnumbered Tears ends at the precise instant of the final retreat.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/equals -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/equals">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
        <rdfs:comment xml:lang="en">Absolute chronological equivalence where two intervals share identical starting and ending instants.</rdfs:comment>
        <rdfs:label xml:lang="en">equals</rdfs:label>
        <skos:altLabel xml:lang="en">same time as</skos:altLabel>
        <skos:example xml:lang="en">The temporal span of the Siege of Nargothrond equals the chronological span of the Fall of Nargothrond.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/finishedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/finishedBy">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/finishes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Both intervals share identical ending instants while the primary interval commences strictly before the secondary interval begins.</rdfs:comment>
        <rdfs:label xml:lang="en">finished by</rdfs:label>
        <skos:altLabel xml:lang="en">ended by</skos:altLabel>
        <skos:example xml:lang="en">The overarching timeline of the Narn is finished by the interval representing the death of Turambar.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/finishes -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/finishes">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Both intervals share identical ending instants while the primary interval commences strictly after the secondary interval begins.</rdfs:comment>
        <rdfs:label xml:lang="en">finishes</rdfs:label>
        <skos:altLabel xml:lang="en">ends with</skos:altLabel>
        <skos:example xml:lang="en">The interval representing the death of Turambar finishes the overarching timeline of the Narn.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/hasInstant -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/hasInstant">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Interval"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:comment xml:lang="en">The association between a temporal interval and a specific instant contained within or bounding it.</rdfs:comment>
        <rdfs:label xml:lang="en">has instant</rdfs:label>
        <skos:altLabel xml:lang="en">at instant</skos:altLabel>
        <skos:example xml:lang="en">The overarching timeline of the Narn has an instant mapped to the moment of Túrin&apos;s birth.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/intervalRelation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/intervalRelation">
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Interval"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Interval"/>
        <rdfs:comment xml:lang="en">A topological temporal relation between two distinct intervals.</rdfs:comment>
        <rdfs:label xml:lang="en">interval relation</rdfs:label>
        <skos:altLabel xml:lang="en">Allen relation</skos:altLabel>
        <skos:example xml:lang="en">The relational mapping between the birth of Túrin and the birth of Lalaith constitutes an interval relation.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/meets -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/meets">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/precedes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <owl:propertyDisjointWith rdf:resource="https://w3id.org/narn/to/overlaps"/>
        <rdfs:comment xml:lang="en">The ending instant of the primary interval is chronologically identical to the starting instant of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">meets</rdfs:label>
        <skos:altLabel xml:lang="en">immediately before</skos:altLabel>
        <skos:example xml:lang="en">The chronological span of the Nirnaeth Arnoediad meets the interval of Húrin&apos;s captivity without any intervening gap.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/metBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/metBy">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/meets"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">The starting instant of the primary interval is chronologically identical to the ending instant of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">met by</rdfs:label>
        <skos:altLabel xml:lang="en">immediately after</skos:altLabel>
        <skos:example xml:lang="en">The interval of Húrin&apos;s captivity is met by the conclusion of the Nirnaeth Arnoediad.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/occursAfter -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/occursAfter">
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/occursBefore"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:comment xml:lang="en">A temporal relation placing the first instant chronologically subsequent to the second.</rdfs:comment>
        <rdfs:label xml:lang="en">occurs after</rdfs:label>
        <skos:altLabel xml:lang="en">later than</skos:altLabel>
        <skos:example xml:lang="en">The moment of Nienor&apos;s birth occurs after the moment of Lalaith&apos;s birth.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/occursBefore -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/occursBefore">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Instant"/>
        <owl:propertyDisjointWith rdf:resource="https://w3id.org/narn/to/occursSimultaneouslyTo"/>
        <rdfs:comment xml:lang="en">A temporal relation placing the first instant chronologically prior to the second.</rdfs:comment>
        <rdfs:label xml:lang="en">occurs before</rdfs:label>
        <skos:altLabel xml:lang="en">earlier than</skos:altLabel>
        <skos:example xml:lang="en">The moment of Túrin&apos;s birth occurs before the moment of Lalaith&apos;s birth.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/occursDuring -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/occursDuring">
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Interval"/>
        <rdfs:comment xml:lang="en">The enclosure of a specific instant strictly within the temporal boundaries of an interval.</rdfs:comment>
        <rdfs:label xml:lang="en">occurs during</rdfs:label>
        <skos:altLabel xml:lang="en">within timeframe of</skos:altLabel>
        <skos:example xml:lang="en">The precise moment of Khîm&apos;s death occurs during the interval of Túrin&apos;s habitation at Amon Rûdh.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/occursSimultaneouslyTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/occursSimultaneouslyTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:comment xml:lang="en">A temporal relation linking two distinct instants that occupy the exact same chronological position.</rdfs:comment>
        <rdfs:label xml:lang="en">occurs simultaneously to</rdfs:label>
        <skos:altLabel xml:lang="en">at same time as</skos:altLabel>
        <skos:example xml:lang="en">Two separate observations mapping to the exact same chronological instant occur simultaneously.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/overlappedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/overlappedBy">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/overlaps"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval begins strictly within the duration of the secondary interval and concludes after it.</rdfs:comment>
        <rdfs:label xml:lang="en">overlapped by</rdfs:label>
        <skos:altLabel xml:lang="en">partially after</skos:altLabel>
        <skos:example xml:lang="en">Túrin&apos;s time at Amon Rûdh is overlapped by the preceding interval of his time among the outlaws.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/overlaps -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/overlaps">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval begins before the secondary interval and concludes strictly within its duration.</rdfs:comment>
        <rdfs:label xml:lang="en">overlaps</rdfs:label>
        <skos:altLabel xml:lang="en">partially before</skos:altLabel>
        <skos:example xml:lang="en">The interval of Túrin&apos;s time among the outlaws overlaps with the beginning of his time at Amon Rûdh.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/precededBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/precededBy">
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/precedes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval commences either strictly subsequent to or exactly at the conclusion of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">preceded by</rdfs:label>
        <skos:altLabel xml:lang="en">happens after</skos:altLabel>
        <skos:example xml:lang="en">Túrin&apos;s journey to Doriath is temporally preceded by the span of the Nirnaeth Arnoediad.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/precedes -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/precedes">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">The primary interval concludes either strictly prior to or exactly at the commencement of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">precedes</rdfs:label>
        <skos:altLabel xml:lang="en">happens before</skos:altLabel>
        <skos:example xml:lang="en">The span of the Nirnaeth Arnoediad temporally precedes Túrin&apos;s journey to Doriath.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/startedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/startedBy">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/narn/to/starts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Both intervals share identical starting instants while the primary interval extends strictly beyond the conclusion of the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">started by</rdfs:label>
        <skos:altLabel xml:lang="en">begun by</skos:altLabel>
        <skos:example xml:lang="en">The overarching timeline of the Narn is started by the interval representing the birth of Túrin.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/starts -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/starts">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/intervalRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Both intervals share identical starting instants while the primary interval concludes strictly before the secondary interval.</rdfs:comment>
        <rdfs:label xml:lang="en">starts</rdfs:label>
        <skos:altLabel xml:lang="en">begins with</skos:altLabel>
        <skos:example xml:lang="en">The interval representing the birth of Túrin starts the overarching timeline of the Narn.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/narn/to/startsAt -->


    <owl:ObjectProperty rdf:about="https://w3id.org/narn/to/startsAt">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/narn/to/hasInstant"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/narn/to/Interval"/>
        <rdfs:range rdf:resource="https://w3id.org/narn/to/Instant"/>
        <rdfs:comment xml:lang="en">The absolute starting instant bounding the beginning of a temporal interval.</rdfs:comment>
        <rdfs:label xml:lang="en">starts at</rdfs:label>
        <skos:altLabel xml:lang="en">beginning point</skos:altLabel>
        <skos:example xml:lang="en">The chronological span of the Narn starts at the moment of Túrin&apos;s birth.</skos:example>
