#################################################################

###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
<http://www.w3.org/2004/02/skos/core#example> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/created
<https://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/creator
<https://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/modified
<https://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  https://purl.org/vocab/vann/preferredNamespacePrefix
<https://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  https://purl.org/vocab/vann/preferredNamespaceUri
<https://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#duration
xsd:duration rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/narn/to/after
:after rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :intervalRelation ;
       owl:inverseOf :before ;
       rdf:type owl:TransitiveProperty ;
       rdfs:comment "The primary interval commences strictly subsequent to the conclusion of the secondary interval."@en ;
       rdfs:label "after"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "follows"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The interval of Nienor's birth occurs strictly after the conclusion of the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/to/before
:before rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :intervalRelation ,
                           :precedes ;
        rdf:type owl:TransitiveProperty ;
        owl:propertyDisjointWith :overlaps ;
        rdfs:comment "The primary interval concludes strictly prior to the commencement of the secondary interval."@en ;
        rdfs:label "before"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "precedes"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The interval of Túrin's birth occurs strictly before the interval of Lalaith's birth."@en .


###  https://w3id.org/narn/to/containsInterval
:containsInterval rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :intervalRelation ;
                  owl:inverseOf :during ;
                  rdf:type owl:TransitiveProperty ;
                  rdfs:comment "The primary interval strictly and completely encloses the chronological boundaries of the secondary interval."@en ;
                  rdfs:label "contains interval"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "temporally contains"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn temporally contains the interval of Túrin's time in Doriath."@en .


###  https://w3id.org/narn/to/during
:during rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :intervalRelation ;
        rdf:type owl:TransitiveProperty ;
        rdfs:comment "The primary interval is strictly and completely enclosed within the chronological boundaries of the secondary interval."@en ;
        rdfs:label "during"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "contained in"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The interval representing the killing of Khîm occurs strictly during Túrin's habitation at Amon Rûdh."@en .


###  https://w3id.org/narn/to/endsAt
:endsAt rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :hasInstant ;
        rdf:type owl:FunctionalProperty ,
                 owl:AsymmetricProperty ,
                 owl:IrreflexiveProperty ;
        rdfs:domain :Interval ;
        rdfs:range :Instant ;
        owl:propertyDisjointWith :startsAt ;
        rdfs:comment "The absolute ending instant bounding the conclusion of a temporal interval."@en ;
        rdfs:label "ends at"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "ending point"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears ends at the precise instant of the final retreat."@en .


###  https://w3id.org/narn/to/equals
:equals rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :intervalRelation ;
        rdf:type owl:SymmetricProperty ,
                 owl:TransitiveProperty ,
                 owl:ReflexiveProperty ;
        rdfs:comment "Absolute chronological equivalence where two intervals share identical starting and ending instants."@en ;
        rdfs:label "equals"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "same time as"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The temporal span of the Siege of Nargothrond equals the chronological span of the Fall of Nargothrond."@en .


###  https://w3id.org/narn/to/finishedBy
:finishedBy rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :intervalRelation ;
            owl:inverseOf :finishes ;
            rdf:type owl:AsymmetricProperty ,
                     owl:TransitiveProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:comment "Both intervals share identical ending instants while the primary interval commences strictly before the secondary interval begins."@en ;
            rdfs:label "finished by"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "ended by"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn is finished by the interval representing the death of Turambar."@en .


###  https://w3id.org/narn/to/finishes
:finishes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :intervalRelation ;
          rdf:type owl:AsymmetricProperty ,
                   owl:TransitiveProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:comment "Both intervals share identical ending instants while the primary interval commences strictly after the secondary interval begins."@en ;
          rdfs:label "finishes"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "ends with"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The interval representing the death of Turambar finishes the overarching timeline of the Narn."@en .


###  https://w3id.org/narn/to/hasInstant
:hasInstant rdf:type owl:ObjectProperty ,
                     owl:AsymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:domain :Interval ;
            rdfs:range :Instant ;
            rdfs:comment "The association between a temporal interval and a specific instant contained within or bounding it."@en ;
            rdfs:label "has instant"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "at instant"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn has an instant mapped to the moment of Túrin's birth."@en .


###  https://w3id.org/narn/to/intervalRelation
:intervalRelation rdf:type owl:ObjectProperty ;
                  rdfs:domain :Interval ;
                  rdfs:range :Interval ;
                  rdfs:comment "A topological temporal relation between two distinct intervals."@en ;
                  rdfs:label "interval relation"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "Allen relation"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "The relational mapping between the birth of Túrin and the birth of Lalaith constitutes an interval relation."@en .


###  https://w3id.org/narn/to/meets
:meets rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :intervalRelation ,
                          :precedes ;
       rdf:type owl:AsymmetricProperty ,
                owl:IrreflexiveProperty ;
       owl:propertyDisjointWith :overlaps ;
       rdfs:comment "The ending instant of the primary interval is chronologically identical to the starting instant of the secondary interval."@en ;
       rdfs:label "meets"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "immediately before"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The chronological span of the Nirnaeth Arnoediad meets the interval of Húrin's captivity without any intervening gap."@en .


###  https://w3id.org/narn/to/metBy
:metBy rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :intervalRelation ;
       owl:inverseOf :meets ;
       rdf:type owl:AsymmetricProperty ,
                owl:IrreflexiveProperty ;
       rdfs:comment "The starting instant of the primary interval is chronologically identical to the ending instant of the secondary interval."@en ;
       rdfs:label "met by"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "immediately after"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The interval of Húrin's captivity is met by the conclusion of the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/to/occursAfter
:occursAfter rdf:type owl:ObjectProperty ;
             owl:inverseOf :occursBefore ;
             rdf:type owl:TransitiveProperty ;
             rdfs:domain :Instant ;
             rdfs:range :Instant ;
             rdfs:comment "A temporal relation placing the first instant chronologically subsequent to the second."@en ;
             rdfs:label "occurs after"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "later than"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "The moment of Nienor's birth occurs after the moment of Lalaith's birth."@en .


###  https://w3id.org/narn/to/occursBefore
:occursBefore rdf:type owl:ObjectProperty ,
                       owl:TransitiveProperty ;
              rdfs:domain :Instant ;
              rdfs:range :Instant ;
              owl:propertyDisjointWith :occursSimultaneouslyTo ;
              rdfs:comment "A temporal relation placing the first instant chronologically prior to the second."@en ;
              rdfs:label "occurs before"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "earlier than"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "The moment of Túrin's birth occurs before the moment of Lalaith's birth."@en .


###  https://w3id.org/narn/to/occursDuring
:occursDuring rdf:type owl:ObjectProperty ;
              rdfs:domain :Instant ;
              rdfs:range :Interval ;
              rdfs:comment "The enclosure of a specific instant strictly within the temporal boundaries of an interval."@en ;
              rdfs:label "occurs during"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "within timeframe of"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "The precise moment of Khîm's death occurs during the interval of Túrin's habitation at Amon Rûdh."@en .


###  https://w3id.org/narn/to/occursSimultaneouslyTo
:occursSimultaneouslyTo rdf:type owl:ObjectProperty ,
                                 owl:SymmetricProperty ,
                                 owl:TransitiveProperty ,
                                 owl:ReflexiveProperty ;
                        rdfs:domain :Instant ;
                        rdfs:range :Instant ;
                        rdfs:comment "A temporal relation linking two distinct instants that occupy the exact same chronological position."@en ;
                        rdfs:label "occurs simultaneously to"@en ;
                        <http://www.w3.org/2004/02/skos/core#altLabel> "at same time as"@en ;
                        <http://www.w3.org/2004/02/skos/core#example> "Two separate observations mapping to the exact same chronological instant occur simultaneously."@en .


###  https://w3id.org/narn/to/overlappedBy
:overlappedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :intervalRelation ;
              owl:inverseOf :overlaps ;
              rdf:type owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:comment "The primary interval begins strictly within the duration of the secondary interval and concludes after it."@en ;
              rdfs:label "overlapped by"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "partially after"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Túrin's time at Amon Rûdh is overlapped by the preceding interval of his time among the outlaws."@en .


###  https://w3id.org/narn/to/overlaps
:overlaps rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :intervalRelation ;
          rdf:type owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:comment "The primary interval begins before the secondary interval and concludes strictly within its duration."@en ;
          rdfs:label "overlaps"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "partially before"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The interval of Túrin's time among the outlaws overlaps with the beginning of his time at Amon Rûdh."@en .


###  https://w3id.org/narn/to/precededBy
:precededBy rdf:type owl:ObjectProperty ;
            owl:inverseOf :precedes ;
            rdf:type owl:TransitiveProperty ;
            rdfs:comment "The primary interval commences either strictly subsequent to or exactly at the conclusion of the secondary interval."@en ;
            rdfs:label "preceded by"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "happens after"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Túrin's journey to Doriath is temporally preceded by the span of the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/to/precedes
:precedes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :intervalRelation ;
          rdf:type owl:TransitiveProperty ;
          rdfs:comment "The primary interval concludes either strictly prior to or exactly at the commencement of the secondary interval."@en ;
          rdfs:label "precedes"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "happens before"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The span of the Nirnaeth Arnoediad temporally precedes Túrin's journey to Doriath."@en .


###  https://w3id.org/narn/to/startedBy
:startedBy rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :intervalRelation ;
           owl:inverseOf :starts ;
           rdf:type owl:AsymmetricProperty ,
                    owl:TransitiveProperty ,
                    owl:IrreflexiveProperty ;
           rdfs:comment "Both intervals share identical starting instants while the primary interval extends strictly beyond the conclusion of the secondary interval."@en ;
           rdfs:label "started by"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "begun by"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "The overarching timeline of the Narn is started by the interval representing the birth of Túrin."@en .


###  https://w3id.org/narn/to/starts
:starts rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :intervalRelation ;
        rdf:type owl:AsymmetricProperty ,
                 owl:TransitiveProperty ,
                 owl:IrreflexiveProperty ;
        rdfs:comment "Both intervals share identical starting instants while the primary interval concludes strictly before the secondary interval."@en ;
        rdfs:label "starts"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "begins with"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The interval representing the birth of Túrin starts the overarching timeline of the Narn."@en .


###  https://w3id.org/narn/to/startsAt
:startsAt rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasInstant ;
          rdf:type owl:FunctionalProperty ,
                   owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Interval ;
          rdfs:range :Instant ;
          rdfs:comment "The absolute starting instant bounding the beginning of a temporal interval."@en ;
          rdfs:label "starts at"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "beginning point"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The chronological span of the Narn starts at the moment of Túrin's birth."@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/narn/to/hasDateTime
:hasDateTime rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Instant ;
             rdfs:range xsd:dateTime ;
             rdfs:comment "The standardized chronological date and time value of a specific temporal instant."@en ;
             rdfs:label "has date time"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "dateTime value"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "The instant of publication maps to a specific dateTime value in the standard calendar."@en .


###  https://w3id.org/narn/to/hasDuration
:hasDuration rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Interval ;
             rdfs:range xsd:duration ;
             rdfs:comment "The absolute temporal length spanned by a defined interval."@en ;
             rdfs:label "has duration"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "time length"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "The interval representing Túrin's time in Doriath has a duration measured in several years."@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/narn/to/EndingInterval
:EndingInterval rdf:type owl:Class ;
                rdfs:subClassOf :Interval ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :endsAt ;
                                  owl:someValuesFrom :Instant
                                ] ;
                rdfs:comment "An interval bounded by a distinct ending instant but lacking a defined starting point."@en ;
                rdfs:label "ending interval"@en ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "ending point"@en ;
                <http://www.w3.org/2004/02/skos/core#example> "A historical epoch stretching back indefinitely but concluding at a specific catastrophe represents an ending interval."@en .


###  https://w3id.org/narn/to/EternalInterval
:EternalInterval rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :InfiniteInterval
                                                            [ rdf:type owl:Class ;
                                                              owl:complementOf :EndingInterval
                                                            ]
                                                            [ rdf:type owl:Class ;
                                                              owl:complementOf :StartingInterval
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf :InfiniteInterval ;
                 owl:disjointWith :FiniteInterval ;
                 rdfs:comment "A temporally unbounded interval extending infinitely into both the past and the future."@en ;
                 rdfs:label "eternal interval"@en ;
                 <http://www.w3.org/2004/02/skos/core#altLabel> "everlasting interval"@en ;
                 <http://www.w3.org/2004/02/skos/core#example> "The continuous existence of the universe Eä serves as an eternal interval."@en .


###  https://w3id.org/narn/to/FiniteInterval
:FiniteInterval rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Interval
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :endsAt ;
                                                             owl:someValuesFrom :Instant
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :startsAt ;
                                                             owl:someValuesFrom :Instant
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :EndingInterval ,
                                :Interval ,
                                :StartingInterval ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :startsAt ;
                                  owl:allValuesFrom :Instant
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :endsAt ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Instant
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :startsAt ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Instant
                                ] ;
                owl:disjointWith :InfiniteInterval ;
                rdfs:comment "A bounded temporal interval defined by both a distinct starting instant and a distinct ending instant."@en ;
                rdfs:label "finite interval"@en ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "bounded interval"@en ;
                <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears constitutes a finite interval possessing defined chronological boundaries."@en .


###  https://w3id.org/narn/to/InfiniteInterval
:InfiniteInterval rdf:type owl:Class ;
                  rdfs:subClassOf :Interval ;
                  rdfs:comment "A temporal interval extending infinitely in at least one direction."@en ;
                  rdfs:label "infinite interval"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "unbounded interval"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "The lifespan of an immortal Elf represents an infinite interval extending continuously into the future."@en .


###  https://w3id.org/narn/to/Instant
:Instant rdf:type owl:Class ;
         rdfs:subClassOf :TemporalEntity ;
         owl:disjointWith :Interval ;
         rdfs:comment "A temporal entity representing a single point in time with a duration of strictly zero."@en ;
         rdfs:label "instant"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "time point"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "The precise moment of Túrin's birth constitutes an instant."@en .


###  https://w3id.org/narn/to/Interval
:Interval rdf:type owl:Class ;
          rdfs:subClassOf :TemporalEntity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasInstant ;
                            owl:allValuesFrom :Instant
                          ] ;
          rdfs:comment "A continuous temporal entity characterized by a strictly positive duration."@en ;
          rdfs:label "interval"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "time span"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The complete timeline of the Narn represents a temporal interval."@en .


###  https://w3id.org/narn/to/StartingInterval
:StartingInterval rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Interval
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :startsAt ;
                                                               owl:someValuesFrom :Instant
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :Interval ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :startsAt ;
                                    owl:someValuesFrom :Instant
                                  ] ;
                  rdfs:comment "An interval bounded by a distinct starting instant but lacking a defined ending point."@en ;
                  rdfs:label "starting interval"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "begins with"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "The life of an Elf exemplifies a starting interval since it begins at birth but possesses no natural conclusion."@en .


###  https://w3id.org/narn/to/TemporalEntity
:TemporalEntity rdf:type owl:Class ;
                rdfs:comment "An entity existing within a specific temporal dimension."@en ;
                rdfs:label "temporal entity"@en ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "time entity"@en ;
                <http://www.w3.org/2004/02/skos/core#example> "The moment of Túrin's birth and the span of his life represent temporal entities."@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointProperties ;
  owl:members ( :after
                :before
                :containsInterval
                :during
                :equals
                :finishedBy
                :finishes
                :meets
                :metBy
                :overlappedBy
                :overlaps
                :startedBy
                :starts
              )
] .


