    "@language" : "en",
    "@value" : "was killed by"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://w3id.org/narn/social/killed"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "slain by"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Beleg suffered a tragic fate and was killed by Gorthol."
  } ]
}, {
  "@id" : "https://w3id.org/narn/social/wasServedBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The inverse relation designating the superior who receives service."
  } ],
