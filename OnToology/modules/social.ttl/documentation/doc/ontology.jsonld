    "@language" : "en",
    "@value" : "killed"
  } ],
  "http://www.w3.org/2002/07/owl#propertyDisjointWith" : [ {
    "@id" : "https://w3id.org/narn/social/served"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "slew"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Túrin engaged in a fatal conflict and killed Saeros."
  } ]
}, {
  "@id" : "https://w3id.org/narn/social/livedIn",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicates a geographical location where a character resided for a significant duration."
