@prefix : <https://w3id.org/narn/social/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/narn/social/> .

<https://w3id.org/narn/social/> rdf:type owl:Ontology ;
                                 owl:imports <https://w3id.org/narn/location/> ;
                                 rdfs:comment "An ontology defining structural social relationships and hierarchies between characters in narratives."@en ;
                                 rdfs:label "Social Relations Ontology"@en ;
                                 <https://purl.org/dc/terms/created> "2026-03-14"^^xsd:date ;
                                 <https://purl.org/dc/terms/creator> <https://w3id.org/people/erdemonal/me> ;
                                 <https://purl.org/dc/terms/modified> "2026-03-19"^^xsd:date ;
                                 <https://purl.org/vocab/vann/preferredNamespacePrefix> "soc" ;
                                 <https://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/narn/social/" .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/narn/social/committedSuicide
:committedSuicide rdf:type owl:ObjectProperty ;
                  rdfs:comment "Denotes the tragic act of a character intentionally taking their own life."@en ;
                  rdfs:label "committed suicide"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "took own life"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "Túrin fell into despair and committed suicide with his sword Gurthang."@en .


###  https://w3id.org/narn/social/cursed
:cursed rdf:type owl:ObjectProperty ;
        rdfs:comment "Describes an act where a character invokes supernatural malevolence or a curse upon another."@en ;
        rdfs:label "cursed"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "placed a curse on"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Mîm sought revenge and cursed Andróg after the killing of Khîm."@en .


###  https://w3id.org/narn/social/feared
:feared rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :hasEmotionalRelationWith ;
        rdfs:comment "Denotes a state of dread or apprehension regarding another character."@en ;
        rdfs:label "feared"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "had fear of"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Glaurung recognized the threat and feared Túrin."@en .


###  https://w3id.org/narn/social/hasEmotionalRelationWith
:hasEmotionalRelationWith rdf:type owl:ObjectProperty ;
                          rdfs:domain owl:Thing ;
                          rdfs:range owl:Thing ;
                          rdfs:comment "Defines a broad emotional directedness or sentiment from one character toward another."@en ;
                          rdfs:label "has emotional relation with"@en ;
                          <http://www.w3.org/2004/02/skos/core#altLabel> "feels towards"@en ;
                          <http://www.w3.org/2004/02/skos/core#example> "Saeros holds a deep emotional relation rooted in hatred towards Túrin."@en .


###  https://w3id.org/narn/social/hasFriend
:hasFriend rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasEmotionalRelationWith ;
           rdf:type owl:SymmetricProperty ,
                    owl:IrreflexiveProperty ;
           owl:propertyDisjointWith :isAnEnemyOf ;
           rdfs:comment "Represents a symmetric and mutual bond of friendship between two entities."@en ;
           rdfs:label "has friend"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "is a friend of"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "Túrin maintains a mutual friendship and has friend Sador."@en .


###  https://w3id.org/narn/social/hasValence
:hasValence rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:range :EmotionalValence ;
            rdfs:comment "Functionally assigns a specific emotional state or valence to a relational entity."@en ;
            rdfs:label "has valence"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "has sentiment"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Húrin acts functionally and has valence positive."@en .


###  https://w3id.org/narn/social/hated
:hated rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :hasEmotionalRelationWith ;
       rdfs:comment "Indicates a profound sentiment of malice or hatred directed at another entity."@en ;
       rdfs:label "hated"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "had hatred for"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "Saeros harbored intense resentment and hated Túrin."@en .


###  https://w3id.org/narn/social/hypnotised
:hypnotised rdf:type owl:ObjectProperty ;
            rdfs:comment "Indicates the act of subjecting another character to a mental spell or hypnotic enchantment."@en ;
            rdfs:label "hypnotised"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "cast a spell on"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Glaurung used his power and hypnotised Níniel."@en .


###  https://w3id.org/narn/social/isAKinsmanOf
:isAKinsmanOf rdf:type owl:ObjectProperty ,
                       owl:SymmetricProperty ;
              rdfs:comment "Represents a symmetric bond based on shared familial lineage or blood relation."@en ;
              rdfs:label "is a kinsman of"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "kin of"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Túrin shares a bloodline and is a kinsman of Nienor."@en .


###  https://w3id.org/narn/social/isAnEnemyOf
:isAnEnemyOf rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ,
                      owl:IrreflexiveProperty ;
             owl:propertyDisjointWith :wasServedBy ;
             rdfs:comment "Defines a fundamentally antagonistic and hostile relationship."@en ;
             rdfs:label "is an enemy of"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "foe of"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "Morgoth stands as a prime antagonist and is an enemy of Húrin."@en .


###  https://w3id.org/narn/social/isMarriedTo
:isMarriedTo rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ,
                      owl:IrreflexiveProperty ;
             rdfs:comment "Denotes a formal and symmetric matrimonial relationship between two entities."@en ;
             rdfs:label "is married to"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "wed to"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "Turambar formalized his bond and is married to Níniel."@en .


###  https://w3id.org/narn/social/killed
:killed rdf:type owl:ObjectProperty ,
                 owl:AsymmetricProperty ,
                 owl:IrreflexiveProperty ;
        owl:propertyDisjointWith :served ;
        rdfs:comment "Indicates a fatal action where the subject directly causes the death of the object."@en ;
        rdfs:label "killed"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "slew"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Túrin engaged in a fatal conflict and killed Saeros."@en .


###  https://w3id.org/narn/social/livedIn
:livedIn rdf:type owl:ObjectProperty ;
         rdfs:range <https://w3id.org/narn/location/Place> ;
         owl:propertyChainAxiom ( :served
                                  :wasTheKingOf
                                ) ;
         rdfs:comment "Indicates a geographical location where a character resided for a significant duration."@en ;
         rdfs:label "lived in"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "dwelt in"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "Túrin spent parts of his life and lived in Dor-lómin and Doriath."@en .


###  https://w3id.org/narn/social/loved
:loved rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :hasEmotionalRelationWith ;
       rdfs:comment "Indicates a profound sentiment of affection or love directed at another entity."@en ;
       rdfs:label "loved"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "had love for"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "Húrin held a deep affection and loved Morwen."@en .


###  https://w3id.org/narn/social/mutuallyLoved
:mutuallyLoved rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :loved ;
               rdf:type owl:SymmetricProperty ;
               rdfs:comment "Describes a symmetric emotional state where two characters share reciprocal affection."@en ;
               rdfs:label "mutually loved"@en ;
               <http://www.w3.org/2004/02/skos/core#altLabel> "reciprocally loved"@en ;
               <http://www.w3.org/2004/02/skos/core#example> "Turambar and Níniel shared a bond and mutually loved each other."@en .


###  https://w3id.org/narn/social/ruled
:ruled rdf:type owl:ObjectProperty ;
       owl:equivalentProperty :wasTheKingOf ;
       rdfs:comment "Functions as an equivalent property signifying sovereign rule over a domain."@en ;
       rdfs:label "ruled"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "governed"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "Thingol governed and ruled Doriath."@en .


###  https://w3id.org/narn/social/served
:served rdf:type owl:ObjectProperty ,
                 owl:AsymmetricProperty ,
                 owl:IrreflexiveProperty ;
        rdfs:domain owl:Thing ;
        rdfs:range owl:Thing ;
        rdfs:comment "Indicates a hierarchical relationship where one character acts as a subordinate to another."@en ;
        rdfs:label "served"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "was in service of"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Sador was loyal and served Húrin."@en .


###  https://w3id.org/narn/social/wasHeldCaptiveIn
:wasHeldCaptiveIn rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :livedIn ;
                  rdfs:range <https://w3id.org/narn/location/Place> ;
                  rdfs:comment "Specifies a location where a character was forcibly imprisoned or contained."@en ;
                  rdfs:label "was held captive in"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "imprisoned in"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "Húrin suffered greatly and was held captive in Angband."@en .


###  https://w3id.org/narn/social/wasKilledBy
:wasKilledBy rdf:type owl:ObjectProperty ;
             owl:inverseOf :killed ;
             rdfs:comment "The inverse relation specifying the perpetrator of a fatal action against the subject."@en ;
             rdfs:label "was killed by"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "slain by"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "Beleg suffered a tragic fate and was killed by Gorthol."@en .


###  https://w3id.org/narn/social/wasServedBy
:wasServedBy rdf:type owl:ObjectProperty ;
             owl:inverseOf :served ;
             rdfs:comment "The inverse relation designating the superior who receives service."@en ;
             rdfs:label "was served by"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "had as servant"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "Húrin held authority and was served by Sador."@en .


###  https://w3id.org/narn/social/wasTheBestFriendOf
:wasTheBestFriendOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasFriend ;
                    rdf:type owl:SymmetricProperty ;
                    rdfs:comment "Specifies an exceptionally close and prioritized bond of mutual friendship."@en ;
                    rdfs:label "was the best friend of"@en ;
                    <http://www.w3.org/2004/02/skos/core#altLabel> "closest companion of"@en ;
                    <http://www.w3.org/2004/02/skos/core#example> "Beleg proved his loyalty and was the best friend of Túrin."@en .


###  https://w3id.org/narn/social/wasTheChieftainOf
:wasTheChieftainOf rdf:type owl:ObjectProperty ;
                   rdfs:range <https://w3id.org/narn/location/Place> ;
                   rdfs:comment "Specifies the domain or people over which a character exercised tribal leadership."@en ;
                   rdfs:label "was the chieftain of"@en ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "led as chief"@en ;
                   <http://www.w3.org/2004/02/skos/core#example> "Brandir guided his people and was the chieftain of Brethil."@en .


###  https://w3id.org/narn/social/wasTheKingOf
:wasTheKingOf rdf:type owl:ObjectProperty ,
                       owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:range <https://w3id.org/narn/location/Place> ;
              rdfs:comment "Specifies the geographical or political domain over which a character held absolute royal authority."@en ;
              rdfs:label "was the king of"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "reigned over"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Thingol held supreme authority and was the king of Doriath."@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/narn/social/Ally
:Ally rdf:type owl:Class ;
      rdfs:subClassOf :SocialRole ;
      owl:disjointWith :Outlaw ;
      rdfs:comment "Represents an individual united with others in a formal or informal alliance."@en ;
      rdfs:label "ally"@en ;
      <http://www.w3.org/2004/02/skos/core#altLabel> "companion"@en ;
      <http://www.w3.org/2004/02/skos/core#example> "Beleg stands as a steadfast ally to Túrin."@en .


###  https://w3id.org/narn/social/Chieftain
:Chieftain rdf:type owl:Class ;
           rdfs:subClassOf :PoliticalRole ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :wasTheChieftainOf ;
                             owl:someValuesFrom <https://w3id.org/narn/location/Place>
                           ] ;
           rdfs:comment "Denotes the principal leader or head of a specific people or tribal group."@en ;
           rdfs:label "chieftain"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "chief"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "Brandir acts as the chieftain leading the people of Brethil."@en .


###  https://w3id.org/narn/social/EmotionalValence
:EmotionalValence rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Class ;
                                        owl:oneOf ( :ambivalent
                                                    :negative
                                                    :positive
                                                  )
                                      ] ;
                  rdfs:comment "Defines a classification of emotional sentiments comprising positive negative or ambivalent states."@en ;
                  rdfs:label "emotional valence"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "sentiment type"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "Húrin possesses a positive valence whereas Glaurung possesses a negative valence."@en .


###  https://w3id.org/narn/social/King
:King rdf:type owl:Class ;
      rdfs:subClassOf :PoliticalRole ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :wasTheKingOf ;
                        owl:someValuesFrom <https://w3id.org/narn/location/Place>
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :wasServedBy ;
                        owl:allValuesFrom :Servant
                      ] ;
      owl:disjointWith :Servant ;
      rdfs:comment "Designates the supreme sovereign or monarch of a defined realm or kingdom."@en ;
      rdfs:label "king"@en ;
      <http://www.w3.org/2004/02/skos/core#altLabel> "monarch"@en ;
      <http://www.w3.org/2004/02/skos/core#example> "Thingol serves as the King governing the realm of Doriath."@en .


###  https://w3id.org/narn/social/Leader
:Leader rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:unionOf ( :Chieftain
                                            :King
                                          )
                            ] ;
        rdfs:comment "A general classification encompassing sovereign figures such as a King or a Chieftain."@en ;
        rdfs:label "leader"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "ruler"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Figures such as King Thingol and Chieftain Brandir act as leaders."@en .


###  https://w3id.org/narn/social/MilitaryRole
:MilitaryRole rdf:type owl:Class ;
              rdfs:subClassOf :SocialRole ;
              rdfs:comment "A social role structurally related to military leadership or combat functions."@en ;
              rdfs:label "military role"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "military position"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Serving as a captain or general in the armies of Beleriand represents a military role."@en .


###  https://w3id.org/narn/social/NonLeader
:NonLeader rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:complementOf :Leader
                               ] ;
           rdfs:comment "Categorizes individuals who hold no sovereign or primary leadership authority."@en ;
           rdfs:label "non-leader"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "non-ruler"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "A servant like Sador is classified as a non-leader."@en .


###  https://w3id.org/narn/social/Outlaw
:Outlaw rdf:type owl:Class ;
        rdfs:subClassOf :SocialRole ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isAnEnemyOf ;
                          owl:minCardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        rdfs:comment "Classifies an individual existing outside the protection and constraints of organized legal structures."@en ;
        rdfs:label "outlaw"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "fugitive"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Forweg and Andróg operate as outlaws in the wild lands."@en .


###  https://w3id.org/narn/social/PoliticalRole
:PoliticalRole rdf:type owl:Class ;
               rdfs:subClassOf :SocialRole ;
               rdfs:comment "A specific social role involving governance or formal political authority."@en ;
               rdfs:label "political role"@en ;
               <http://www.w3.org/2004/02/skos/core#altLabel> "political position"@en ;
               <http://www.w3.org/2004/02/skos/core#example> "The positions of King and Chieftain serve as political roles."@en .


###  https://w3id.org/narn/social/PositiveRelation
:PositiveRelation rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty :hasValence ;
                                        owl:hasValue :positive
                                      ] ;
                  rdfs:comment "Denotes a relational bond characterized by a strictly positive emotional valence."@en ;
                  rdfs:label "positive relation"@en ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "positive bond"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "Húrin maintains a positive relation due to his affirmative emotional valence."@en .


###  https://w3id.org/narn/social/RoyalServant
:RoyalServant rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Servant
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :served ;
                                                           owl:someValuesFrom :King
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:comment "Designates a servant specifically sworn to the service of a royal monarch."@en ;
              rdfs:label "royal servant"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "royal attendant"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Beleg qualifies as a royal servant by virtue of serving King Thingol."@en .


###  https://w3id.org/narn/social/Servant
:Servant rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( :SocialRole
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :served ;
                                                      owl:someValuesFrom owl:Thing
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf :SocialRole ;
         rdfs:comment "Identifies an individual bound to the service and assistance of another figure."@en ;
         rdfs:label "servant"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "attendant"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "Sador operates as a servant in the household of Húrin."@en .


###  https://w3id.org/narn/social/SocialRole
:SocialRole rdf:type owl:Class ;
            rdfs:comment "A defined structural position that a character occupies within a social context."@en ;
            rdfs:label "social role"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "role"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Thingol occupies the social role of a King."@en .


###  https://w3id.org/narn/social/SuicidalCharacter
:SuicidalCharacter rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Restriction ;
                                         owl:onProperty :committedSuicide ;
                                         owl:hasSelf "true"^^xsd:boolean
                                       ] ;
                   rdfs:comment "Identifies a narrative figure who intentionally caused their own death."@en ;
                   rdfs:label "suicidal character"@en ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "self slain character"@en ;
                   <http://www.w3.org/2004/02/skos/core#example> "Both Túrin and Níniel are categorized as suicidal characters."@en .


#################################################################
#    Individuals
#################################################################

###  https://w3id.org/narn/social/ambivalent
:ambivalent rdf:type owl:NamedIndividual ;
            rdfs:comment "Represents a mixed or unresolved emotional state."@en ;
            rdfs:label "ambivalent"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "mixed sentiment"@en .


###  https://w3id.org/narn/social/negative
:negative rdf:type owl:NamedIndividual ;
          rdfs:comment "Represents a destructive or hostile emotional state."@en ;
          rdfs:label "negative"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "negative sentiment"@en .


###  https://w3id.org/narn/social/positive
:positive rdf:type owl:NamedIndividual ;
          rdfs:comment "Represents a constructive and affirmative emotional state."@en ;
          rdfs:label "positive"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "positive sentiment"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointProperties ;
  owl:members ( :feared
                :hated
                :loved
              )
] .


###  Generated by the OWL API (version 5.1.18) https://github.com/owlcs/owlapi/
