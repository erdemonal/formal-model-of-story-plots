     -->


    


    <!-- http://purl.org/meo/Eru -->


    <owl:NamedIndividual rdf:about="http://purl.org/meo/Eru"/>
    


    <!-- http://purl.org/meo/eru -->


    <owl:NamedIndividual rdf:about="http://purl.org/meo/eru">
        <rdf:type rdf:resource="http://purl.org/meo/God"/>
        <rdfs:comment xml:lang="en">The one God creator of everything.</rdfs:comment>
        <rdfs:label xml:lang="qya">Eru</rdfs:label>
        <rdfs:label xml:lang="en">The One</rdfs:label>
        <skos:altLabel xml:lang="qya">Eru Ilúvatar</skos:altLabel>
        <skos:altLabel xml:lang="en">God</skos:altLabel>
        <skos:altLabel xml:lang="qya">Ilúvatar</skos:altLabel>
        <skos:altLabel xml:lang="en">The Allfather</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/meo/melkor -->


    <owl:NamedIndividual rdf:about="http://purl.org/meo/melkor">
        <rdf:type rdf:resource="http://purl.org/meo/Vala"/>
        <owl:sameAs rdf:resource="http://purl.org/meo/morgoth"/>
        <rdfs:comment xml:lang="en">The greatest of the Ainur.</rdfs:comment>
        <rdfs:label xml:lang="en">He who arises in might</rdfs:label>
        <rdfs:label xml:lang="qya">Melkor</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/meo/morgoth -->


    <owl:NamedIndividual rdf:about="http://purl.org/meo/morgoth"/>
    


    <!-- http://purl.org/meo/morgoth -->


    <owl:NamedIndividual rdf:about="http://purl.org/meo/morgoth">
        <rdf:type rdf:resource="http://purl.org/meo/EvilBeing"/>
        <rdfs:comment xml:lang="en">The only Vala who became evil. The enemy of all other Valar.</rdfs:comment>
        <rdfs:label xml:lang="sjn">Morgoth</rdfs:label>
        <rdfs:label xml:lang="en">The Black Enemy</rdfs:label>
        <skos:altLabel xml:lang="sjn">Bauglir</skos:altLabel>
        <skos:altLabel xml:lang="en">The Constrainer</skos:altLabel>
    </owl:NamedIndividual>
    


