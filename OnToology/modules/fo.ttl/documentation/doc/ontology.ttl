@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/family/> .

<http://purl.org/family/> rdf:type owl:Ontology ;
                           <http://purl.org/dc/terms/created> "2023-11-19T14:42:42+01:00"^^xsd:dateTime ;
                           <http://purl.org/dc/terms/creator> <https://w3id.org/people/az/me> ;
                           <http://purl.org/dc/terms/modified> "2026-01-23T13:42:42+01:00"^^xsd:dateTime ;
                           <http://purl.org/dc/terms/title> "The Family Ontology"@en ;
                           rdfs:comment "An ontology for family relationships."@en ;
                           rdfs:label "The family ontology"@en .

#################################################################
