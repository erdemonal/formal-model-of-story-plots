@prefix : <https://w3id.org/narn/event/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/narn/event/> .

<https://w3id.org/narn/event/> rdf:type owl:Ontology ;
                                owl:imports <https://w3id.org/narn/location/> ,
                                            <https://w3id.org/narn/to/> ;
                                rdfs:comment "An ontology for describing events in story plots."@en ;
                                rdfs:label "Event Ontology"@en ;
                                <https://purl.org/dc/terms/created> "2026-03-15"^^xsd:date ;
                                <https://purl.org/dc/terms/creator> <https://w3id.org/people/erdemonal/me> ;
                                <https://purl.org/dc/terms/modified> "2026-03-19"^^xsd:date ;
                                <https://purl.org/vocab/vann/preferredNamespacePrefix> "evnt" ;
                                <https://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/narn/event/" .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
<http://www.w3.org/2004/02/skos/core#example> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/created
<https://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/creator
<https://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  https://purl.org/dc/terms/modified
<https://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  https://purl.org/vocab/vann/preferredNamespacePrefix
<https://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  https://purl.org/vocab/vann/preferredNamespaceUri
<https://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/narn/event/begets
:begets rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :hasParticipant ;
        rdfs:domain :Birth ;
        rdfs:comment "The character brought into existence by a birth event."@en ;
        rdfs:label "begets"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "brings forth"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The birth of Túrin begets Túrin."@en .


###  https://w3id.org/narn/event/causes
:causes rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :precedes ;
        rdf:type owl:AsymmetricProperty ,
                 owl:TransitiveProperty ,
                 owl:IrreflexiveProperty ;
        rdfs:domain :Event ;
        rdfs:range :Event ;
        rdfs:comment "This event causally leads to another event."@en ;
        rdfs:label "causes"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "leads to"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The death of Saeros causes the exile of Túrin from Doriath."@en .


###  https://w3id.org/narn/event/creates
:creates rdf:type owl:ObjectProperty ;
         rdfs:domain :Event ;
         rdfs:comment "An entity produced or created by the event."@en ;
         rdfs:label "creates"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "results in"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "The reforging of Anglachel creates Gurthang."@en .


###  https://w3id.org/narn/event/hasAgent
:hasAgent rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasParticipant ;
          rdf:type owl:IrreflexiveProperty ;
          rdfs:domain :Event ;
          owl:propertyDisjointWith :hasWitness ;
          rdfs:comment "The entity that intentionally causes or performs the event."@en ;
          rdfs:label "has agent"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "done by"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The death of Saeros has agent Túrin."@en .


###  https://w3id.org/narn/event/hasCause
:hasCause rdf:type owl:ObjectProperty ;
          rdfs:domain :Event ;
          rdfs:comment "An entity involved as a contributing cause in the event."@en ;
          rdfs:label "has cause"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "caused by"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The death of Beleg has cause Anglachel."@en .


###  https://w3id.org/narn/event/hasDestination
:hasDestination rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :occursAt ;
                rdfs:domain :MovementEvent ;
                rdfs:range <https://w3id.org/narn/location/Place> ;
                owl:propertyDisjointWith :hasOrigin ;
                rdfs:comment "The ending place of a movement event."@en ;
                rdfs:label "has destination"@en ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "arrives at"@en ;
                <http://www.w3.org/2004/02/skos/core#example> "Túrin's journey has destination Doriath."@en .


###  https://w3id.org/narn/event/hasOrigin
:hasOrigin rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :occursAt ;
           rdfs:domain :MovementEvent ;
           rdfs:range <https://w3id.org/narn/location/Place> ;
           rdfs:comment "The starting place of a movement event."@en ;
           rdfs:label "has origin"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "departs from"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "Túrin's journey to Doriath has origin Dor-lómin."@en .


###  https://w3id.org/narn/event/hasParticipant
:hasParticipant rdf:type owl:ObjectProperty ;
                rdfs:domain :Event ;
                rdfs:comment "An entity that takes part in the event."@en ;
                rdfs:label "has participant"@en ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "involves"@en ;
                <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears has participant Húrin."@en .


###  https://w3id.org/narn/event/hasPatient
:hasPatient rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasParticipant ;
            rdfs:domain :Event ;
            rdfs:comment "The entity affected by the event."@en ;
            rdfs:label "has patient"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "affects"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Glaurung hypnotises Níniel, with Níniel as the patient."@en .


###  https://w3id.org/narn/event/hasSubEvent
:hasSubEvent rdf:type owl:ObjectProperty ,
                      owl:AsymmetricProperty ,
                      owl:TransitiveProperty ,
                      owl:IrreflexiveProperty ;
             rdfs:domain :Event ;
             rdfs:range :Event ;
             rdfs:comment "A smaller event that occurs as part of this one."@en ;
             rdfs:label "has subevent"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "contains event"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "The Wars of Beleriand has subevent the Nirnaeth Arnoediad."@en .


###  https://w3id.org/narn/event/hasTraveller
:hasTraveller rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasParticipant ;
              rdfs:domain :Travel ;
              rdfs:comment "The character who undertakes the travel."@en ;
              rdfs:label "has traveller"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "travelled by"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Túrin, Gethron and Grithnir are travellers in the journey to Doriath."@en .


###  https://w3id.org/narn/event/hasVictim
:hasVictim rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasPatient ;
           rdfs:domain :Event ;
           rdfs:comment "The entity that suffers harm in the event."@en ;
           rdfs:label "has victim"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "harms"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "The death of Beleg has victim Beleg."@en .


###  https://w3id.org/narn/event/hasWitness
:hasWitness rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasParticipant ;
            rdfs:domain :Event ;
            rdfs:comment "An entity that observes the event without acting."@en ;
            rdfs:label "has witness"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "observed by"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Mîm's betrayal has witness Andróg."@en .


###  https://w3id.org/narn/event/isBegottenIn
:isBegottenIn rdf:type owl:ObjectProperty ;
              owl:inverseOf :begets ;
              rdfs:domain owl:Thing ;
              rdfs:range :Birth ;
              rdfs:comment "Inverse of begets. Links a character to the birth event that brings them into existence."@en ;
              rdfs:label "is begotten in"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "Túrin is begotten in the birth of Túrin."@en .


###  https://w3id.org/narn/event/isCausedBy
:isCausedBy rdf:type owl:ObjectProperty ;
            owl:inverseOf :causes ;
            rdfs:comment "Inverse of causes. This event results from another."@en ;
            rdfs:label "is caused by"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "results from"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "The exile of Túrin is caused by the death of Saeros."@en .


###  https://w3id.org/narn/event/isSubEventOf
:isSubEventOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf <https://w3id.org/narn/to/during> ;
              owl:inverseOf :hasSubEvent ;
              rdfs:comment "This event is part of a larger event."@en ;
              rdfs:label "is subevent of"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "part of event"@en ;
              <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad is a subevent of the Wars of Beleriand."@en .


###  https://w3id.org/narn/event/occursAt
:occursAt rdf:type owl:ObjectProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Event ;
          rdfs:range <https://w3id.org/narn/location/Place> ;
          rdfs:comment "The place where the event occurs."@en ;
          rdfs:label "occurs at"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "takes place at"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The Captivity of Húrin occurs at Angband."@en .


###  https://w3id.org/narn/event/precedes
:precedes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <https://w3id.org/narn/to/precedes> ;
          rdf:type owl:AsymmetricProperty ,
                   owl:TransitiveProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Event ;
          rdfs:range :Event ;
          rdfs:comment "This event occurs before another event."@en ;
          rdfs:label "precedes"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "comes before"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad precedes Túrin's journey to Doriath."@en .


###  https://w3id.org/narn/to/during
<https://w3id.org/narn/to/during> rdf:type owl:ObjectProperty .


###  https://w3id.org/narn/to/precedes
<https://w3id.org/narn/to/precedes> rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/narn/event/Battle
:Battle rdf:type owl:Class ;
        rdfs:subClassOf :ConflictEvent ;
        rdfs:comment "A large scale violent confrontation."@en ;
        rdfs:label "battle"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "armed conflict"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad is the Battle of Unnumbered Tears."@en .


###  https://w3id.org/narn/event/Betrayal
:Betrayal rdf:type owl:Class ;
          rdfs:subClassOf :Event ;
          owl:disjointWith :Meeting ;
          rdfs:comment "An act of disloyalty involving betrayal of trust."@en ;
          rdfs:label "betrayal"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "treachery"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "Mîm betrays Túrin to the Orcs at Amon Rûdh."@en .


###  https://w3id.org/narn/event/Birth
:Birth rdf:type owl:Class ;
       rdfs:subClassOf :LifeEvent ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :begets ;
                         owl:someValuesFrom owl:Thing
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :occursAt ;
                         owl:allValuesFrom <https://w3id.org/narn/location/Place>
                       ] ;
       owl:disjointWith :Death ,
                        :Marriage ,
                        :Murder ;
       rdfs:comment "The coming into existence of a character."@en ;
       rdfs:label "birth"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "nativity"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The birth of Túrin takes place in Dor-lómin."@en .


###  https://w3id.org/narn/event/Captivity
:Captivity rdf:type owl:Class ;
           rdfs:subClassOf :Event ;
           rdfs:comment "An event in which a character is held as a prisoner."@en ;
           rdfs:label "captivity"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "imprisonment"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "The captivity of Húrin in Angband by Morgoth."@en .


###  https://w3id.org/narn/event/ConflictEvent
:ConflictEvent rdf:type owl:Class ;
               rdfs:subClassOf :Event ;
               owl:disjointWith :MovementEvent ,
                                :SocialEvent ;
               rdfs:comment "An event characterised by antagonism or violence."@en ;
               rdfs:label "conflict event"@en ;
               <http://www.w3.org/2004/02/skos/core#altLabel> "clash"@en ;
               <http://www.w3.org/2004/02/skos/core#example> "The Nirnaeth Arnoediad is a conflict event in Beleriand."@en .


###  https://w3id.org/narn/event/Coronation
:Coronation rdf:type owl:Class ;
            rdfs:subClassOf :SocialEvent ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasAgent ;
                              owl:cardinality "1"^^xsd:nonNegativeInteger
                            ] ;
            rdfs:comment "A ceremony of crowning a ruler."@en ;
            rdfs:label "coronation"@en ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "crowning ceremony"@en ;
            <http://www.w3.org/2004/02/skos/core#example> "Turgon is crowned King of Gondolin."@en .


###  https://w3id.org/narn/event/Council
:Council rdf:type owl:Class ;
         rdfs:subClassOf :SocialEvent ;
         rdfs:comment "A formal meeting for deliberation or the reaching of a consensus."@en ;
         rdfs:label "council"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "deliberation"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "A council of the Elves in Nargothrond."@en .


###  https://w3id.org/narn/event/Curse
:Curse rdf:type owl:Class ;
       rdfs:subClassOf :Event ;
       owl:disjointWith :Prophecy ;
       rdfs:comment "A supernatural imprecation bringing misfortune."@en ;
       rdfs:label "curse"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "malediction"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "Mîm curses Andróg after the killing of Khîm."@en .


###  https://w3id.org/narn/event/Death
:Death rdf:type owl:Class ;
       rdfs:subClassOf :LifeEvent ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasVictim ;
                         owl:someValuesFrom owl:Thing
                       ] ;
       rdfs:comment "The death of a character."@en ;
       rdfs:label "death"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "demise"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The death of Beleg is caused by Túrin."@en .


###  https://w3id.org/narn/event/Discovery
:Discovery rdf:type owl:Class ;
           rdfs:subClassOf :Event ;
           rdfs:comment "An event where something hidden is found or revealed."@en ;
           rdfs:label "discovery"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "revelation"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "The truth about Níniel's identity is revealed."@en .


###  https://w3id.org/narn/event/Duel
:Duel rdf:type owl:Class ;
      rdfs:subClassOf :ConflictEvent ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasParticipant ;
                        owl:cardinality "2"^^xsd:nonNegativeInteger
                      ] ;
      rdfs:comment "A fight between exactly two combatants."@en ;
      rdfs:label "duel"@en ;
      <http://www.w3.org/2004/02/skos/core#altLabel> "single combat"@en ;
      <http://www.w3.org/2004/02/skos/core#example> "The duel between Turambar and Glaurung at Cabed-en-Aras."@en .


###  https://w3id.org/narn/event/Enchantment
:Enchantment rdf:type owl:Class ;
             rdfs:subClassOf :Event ;
             rdfs:comment "A magical effect imposed on a character."@en ;
             rdfs:label "enchantment"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "spell"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "Glaurung hypnotises Níniel at Nargothrond."@en .


###  https://w3id.org/narn/event/Event
:Event rdf:type owl:Class ;
       rdfs:subClassOf <https://w3id.org/narn/to/FiniteInterval> ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasParticipant ;
                         owl:someValuesFrom owl:Thing
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :occursAt ;
                         owl:someValuesFrom <https://w3id.org/narn/location/Place>
                       ] ;
       rdfs:comment "A spatio-temporal occurrence involving participants and locations. Every event is a finite temporal interval."@en ;
       rdfs:label "event"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "occurrence"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The Battle of Unnumbered Tears is an event occurring in Beleriand."@en .


###  https://w3id.org/narn/event/Exile
:Exile rdf:type owl:Class ;
       rdfs:subClassOf :MovementEvent ;
       rdfs:comment "A forced departure from the homeland."@en ;
       rdfs:label "exile"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "banishment"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The exile of Túrin from Doriath after the death of Saeros."@en .


###  https://w3id.org/narn/event/Feast
:Feast rdf:type owl:Class ;
       rdfs:subClassOf :SocialEvent ;
       rdfs:comment "A large celebratory meal or banquet."@en ;
       rdfs:label "feast"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "banquet"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "A feast held in the halls of Menegroth."@en .


###  https://w3id.org/narn/event/Flight
:Flight rdf:type owl:Class ;
        rdfs:subClassOf :MovementEvent ;
        rdfs:comment "An event in which characters flee from danger."@en ;
        rdfs:label "flight"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "escape"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The flight of survivors from the fall of Nargothrond."@en .


###  https://w3id.org/narn/event/LifeEvent
:LifeEvent rdf:type owl:Class ;
           rdfs:subClassOf :Event ;
           rdfs:comment "A significant moment in a character's life."@en ;
           rdfs:label "life event"@en ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "life occurrence"@en ;
           <http://www.w3.org/2004/02/skos/core#example> "The birth of Túrin in Dor-lómin is a life event."@en .


###  https://w3id.org/narn/event/Marriage
:Marriage rdf:type owl:Class ;
          rdfs:subClassOf :LifeEvent ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasParticipant ;
                            owl:cardinality "2"^^xsd:nonNegativeInteger
                          ] ;
          rdfs:comment "A formal union between two characters."@en ;
          rdfs:label "marriage"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "wedding"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "The marriage of Turambar and Níniel in Brethil."@en .


###  https://w3id.org/narn/event/Meeting
:Meeting rdf:type owl:Class ;
         rdfs:subClassOf :SocialEvent ;
         rdfs:comment "An encounter or gathering of characters."@en ;
         rdfs:label "meeting"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "encounter"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "Túrin meets Beleg in the wild."@en .


###  https://w3id.org/narn/event/MovementEvent
:MovementEvent rdf:type owl:Class ;
               rdfs:subClassOf :Event ;
               rdfs:comment "An event involving physical movement of characters between places."@en ;
               rdfs:label "movement event"@en ;
               <http://www.w3.org/2004/02/skos/core#altLabel> "movement"@en ;
               <http://www.w3.org/2004/02/skos/core#example> "Túrin travels from Dor-lómin to Doriath."@en .


###  https://w3id.org/narn/event/Murder
:Murder rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Death
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasAgent ;
                                                     owl:someValuesFrom owl:Thing
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf :Death ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasAgent ;
                          owl:someValuesFrom owl:Thing
                        ] ;
        owl:disjointWith :Suicide ;
        rdfs:comment "A death caused intentionally by another."@en ;
        rdfs:label "murder"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "homicide"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "The death of Saeros is caused by Túrin."@en .


###  https://w3id.org/narn/event/Prophecy
:Prophecy rdf:type owl:Class ;
          rdfs:subClassOf :Event ;
          rdfs:comment "A prediction of future events, often supernatural."@en ;
          rdfs:label "prophecy"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "foretelling"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "Morgoth's doom: thou shalt see with my eyes."@en .


###  https://w3id.org/narn/event/Siege
:Siege rdf:type owl:Class ;
       rdfs:subClassOf :ConflictEvent ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :occursAt ;
                         owl:allValuesFrom <https://w3id.org/narn/location/Settlement>
                       ] ;
       rdfs:comment "A military blockade of a city or fortress."@en ;
       rdfs:label "siege"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "blockade"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The siege and sack of Nargothrond."@en .


###  https://w3id.org/narn/event/SocialEvent
:SocialEvent rdf:type owl:Class ;
             rdfs:subClassOf :Event ;
             rdfs:comment "An event involving social interaction between characters."@en ;
             rdfs:label "social event"@en ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "social gathering"@en ;
             <http://www.w3.org/2004/02/skos/core#example> "The trial of Túrin in absence at Menegroth."@en .


###  https://w3id.org/narn/event/Suicide
:Suicide rdf:type owl:Class ;
         rdfs:subClassOf :Death ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasVictim ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasAgent ;
                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                         ] ;
         rdfs:comment "A form of death in which the agent and the victim are identical."@en ;
         rdfs:label "suicide"@en ;
         <http://www.w3.org/2004/02/skos/core#altLabel> "self-destruction"@en ;
         <http://www.w3.org/2004/02/skos/core#example> "Turambar dies by falling on his own sword Gurthang."@en .


###  https://w3id.org/narn/event/Travel
:Travel rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :MovementEvent
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasDestination ;
                                                     owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                   ]
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasOrigin ;
                                                     owl:someValuesFrom <https://w3id.org/narn/location/Place>
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf :MovementEvent ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDestination ;
                          owl:someValuesFrom <https://w3id.org/narn/location/Place>
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasOrigin ;
                          owl:someValuesFrom <https://w3id.org/narn/location/Place>
                        ] ;
        rdfs:comment "A journey. Every travel has origin and destination."@en ;
        rdfs:label "travel"@en ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "journey"@en ;
        <http://www.w3.org/2004/02/skos/core#example> "Túrin travels from Dor-lómin to Doriath."@en .


###  https://w3id.org/narn/event/Trial
:Trial rdf:type owl:Class ;
       rdfs:subClassOf :SocialEvent ;
       rdfs:comment "A judicial examination or hearing."@en ;
       rdfs:label "trial"@en ;
       <http://www.w3.org/2004/02/skos/core#altLabel> "judgement"@en ;
       <http://www.w3.org/2004/02/skos/core#example> "The trial of Túrin in absence, where Nellas testifies."@en .


###  https://w3id.org/narn/event/War
:War rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( :ConflictEvent
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :hasSubEvent ;
                                                  owl:someValuesFrom :Battle
                                                ]
                                              ) ;
                           rdf:type owl:Class
                         ] ;
     rdfs:subClassOf :ConflictEvent ;
     rdfs:comment "A prolonged conflict composed of multiple battles."@en ;
     rdfs:label "war"@en ;
     <http://www.w3.org/2004/02/skos/core#altLabel> "prolonged conflict"@en ;
     <http://www.w3.org/2004/02/skos/core#example> "The Wars of Beleriand include the Nirnaeth Arnoediad."@en .


