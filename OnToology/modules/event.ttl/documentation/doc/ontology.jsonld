    "@value" : "occurrence"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "The Battle of Unnumbered Tears is an event occurring in Beleriand."
  } ]
}, {
  "@id" : "https://w3id.org/narn/event/Exile",
